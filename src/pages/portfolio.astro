---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import data from '../data/portfolio.json';
import { breadcrumbSchema } from '../lib/schema';

const IDX_BASE = 'https://cposeyrealestate.idxbroker.com/idx/details/listing/a023';

type Current = {
  placeholder?: boolean;
  source?: 'idx' | 'internal';
  mlsId?: string;
  slug: string;
  status: string;
  price: string;
  address: string;
  city: string;
  beds?: number;
  baths?: number;
  sqft?: string;
  acres?: string;
  propertyType?: string;
  img: string;
  gallery?: string[];
  description?: string;
};

type Past = {
  placeholder?: boolean;
  status: string;
  soldPrice?: string;
  soldDate?: string;
  address: string;
  city: string;
  beds?: number;
  baths?: number;
  sqft?: string;
  acres?: string;
  propertyType?: string;
  highlight?: string;
  role?: string;
  img: string;
};

const currentListings = (data.currentListings as Current[]).map((l) => ({
  ...l,
  url: l.source === 'internal' ? `/portfolio/${l.slug}` : `${IDX_BASE}/${l.mlsId}/${l.slug}`,
  external: l.source !== 'internal',
}));

// Past sales sorted newest-first
const pastSales = [...(data.pastSales as Past[])].sort(
  (a, b) => new Date(b.soldDate).getTime() - new Date(a.soldDate).getTime(),
);

function fmtSoldDate(iso: string) {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return '';
  return d.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
}
---

<Layout
  title="Portfolio | Current Listings & Recent Sales in New Braunfels"
  description="Cody Posey's current listings and recent closings across New Braunfels, Canyon Lake, Seguin, and the Texas Hill Country."
  schema={breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Portfolio', url: '/portfolio' },
  ])}
>
  <Navbar />

  <main class="portfolio-page">
    <header class="portfolio-page__hero">
      <div class="container">
        <h1>My <span class="accent">Portfolio</span></h1>
        <p>Current listings and recent closings across the Texas Hill Country.</p>
      </div>
    </header>

    <!-- Current Listings -->
    <section class="portfolio-page__section">
      <div class="container">
        <div class="section-heading">
          <h2>Current Listings</h2>
          <span class="section-heading__count">{currentListings.length}</span>
        </div>

        {currentListings.length === 0 ? (
          <p class="portfolio-page__empty">No active listings at the moment.</p>
        ) : (
          <div class="portfolio-grid">
            {currentListings.map((l) => (
              <a href={l.url} target={l.external ? '_blank' : '_self'} rel={l.external ? 'noopener' : undefined} class="p-card">
                <div class="p-card__img-wrap">
                  <img src={l.img} alt={l.address} class="p-card__img" loading="lazy" />
                  <span class={`p-card__status ${String(l.status).toLowerCase()}`}>{l.status}</span>
                </div>
                <div class="p-card__body">
                  <div class="p-card__price">{l.price}</div>
                  <div class="p-card__address">{l.address}</div>
                  <div class="p-card__city">{l.city}</div>
                  <div class="p-card__details">
                    {l.beds && <span>{l.beds} Beds</span>}
                    {l.baths && <span>{l.baths} Baths</span>}
                    {l.sqft && <span>{l.sqft} sqft</span>}
                    {'acres' in l && l.acres && <span>{l.acres} Acres</span>}
                  </div>
                  <span class="p-card__cta">View Listing →</span>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- Past Sales -->
    <section class="portfolio-page__section portfolio-page__section--dark" id="recent-sales">
      <div class="container">
        <div class="section-heading">
          <h2>Recent Sales</h2>
        </div>

        {pastSales.length === 0 ? (
          <p class="portfolio-page__empty">Past sales will appear here.</p>
        ) : (
          <div class="portfolio-grid" data-past-grid>
            {pastSales.map((l, i) => (
              <div class="p-card p-card--sold" data-page={Math.floor(i / 12) + 1}>
                <div class="p-card__img-wrap">
                  <img src={l.img} alt={l.address} class="p-card__img" loading="lazy" />
                  <span class={`p-card__status ${String(l.status).toLowerCase()}`}>{l.status}</span>
                  {l.soldDate && <span class="p-card__sold-date">Closed {fmtSoldDate(l.soldDate)}</span>}
                </div>
                <div class="p-card__body">
                  <div class="p-card__price">Price Upon Request</div>
                  <div class="p-card__address">{l.address}</div>
                  <div class="p-card__city">{l.city}</div>
                  <div class="p-card__details">
                    {l.propertyType && <span>{l.propertyType}</span>}
                    {l.beds && <span>{l.beds} Beds</span>}
                    {l.baths && <span>{l.baths} Baths</span>}
                    {l.sqft && <span>{l.sqft} sqft</span>}
                    {l.acres && <span>{l.acres} Acres</span>}
                  </div>
                  {l.role && <div class="p-card__role">Represented as {l.role}</div>}
                </div>
              </div>
            ))}
          </div>
          <nav class="portfolio-pagination" data-past-pagination aria-label="Recent sales pages"></nav>
        )}
      </div>
    </section>

    <section class="portfolio-page__cta">
      <div class="container">
        <h2>Looking for your next home — or thinking of selling?</h2>
        <div class="portfolio-page__cta-buttons">
          <a href="/search" class="btn btn-primary">Search Homes</a>
          <a href="/home-value" class="btn btn-outline-dark">Get Your Home's Value</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .portfolio-page {
    padding-top: 76px;
    background: #fafafa;
  }

  /* Hero */
  .portfolio-page__hero {
    background: #000;
    color: #fff;
    padding: 4rem 0 3rem;
    text-align: center;
  }
  .portfolio-page__hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    margin-bottom: 0.75rem;
  }
  .portfolio-page__hero p {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.75);
    max-width: 620px;
    margin: 0 auto;
  }

  /* Sections */
  .portfolio-page__section {
    padding: 3rem 0;
  }
  .portfolio-page__section--dark {
    background: #f0f0f0;
  }

  .section-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .section-heading h2 {
    font-size: 1.6rem;
    color: #111;
  }
  .section-heading__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 32px;
    height: 26px;
    padding: 0 10px;
    background: #FF1616;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    border-radius: 999px;
  }

  .portfolio-page__empty {
    color: #777;
    font-style: italic;
  }

  /* Grid */
  .portfolio-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 960px) {
    .portfolio-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .portfolio-grid { grid-template-columns: 1fr; }
  }

  /* Cards */
  .p-card {
    background: #fff;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
    overflow: hidden;
    transition: transform 0.25s, box-shadow 0.25s;
    display: block;
    color: inherit;
    text-decoration: none;
  }
  a.p-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 32px rgba(0, 0, 0, 0.15);
  }
  .p-card--sold { cursor: default; }

  .p-card__img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }
  .p-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }
  a.p-card:hover .p-card__img { transform: scale(1.05); }

  .p-card__status {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.3rem 0.8rem;
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
  }
  .p-card__status.active { background: #FF1616; }
  .p-card__status.pending { background: #e07b00; }
  .p-card__status.sold { background: #111; }
  .p-card__status.leased { background: #333; }

  .p-card__sold-date {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    padding: 0.25rem 0.7rem;
    background: rgba(0, 0, 0, 0.75);
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .p-card__body { padding: 1.25rem; }
  .p-card__price {
    font-family: 'Poppins', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #FF1616;
    margin-bottom: 0.3rem;
  }
  .p-card__highlight {
    font-family: 'Poppins', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    color: #FF1616;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.4rem;
  }
  .p-card__role {
    margin-top: 0.25rem;
    padding-top: 0.6rem;
    border-top: 1px solid #eee;
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: #777;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .p-card__address { font-weight: 600; font-size: 0.9rem; margin-bottom: 0.2rem; }
  .p-card__city { font-size: 0.8rem; color: #777; margin-bottom: 1rem; }
  .p-card__details {
    display: flex; gap: 1rem; flex-wrap: wrap;
    font-size: 0.78rem; color: #555; margin-bottom: 1rem;
  }
  .p-card__cta {
    font-family: 'Poppins', sans-serif;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #FF1616;
  }

  /* Pagination (recent sales) */
  .portfolio-pagination {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 2.5rem;
    flex-wrap: wrap;
  }
  .portfolio-pagination:empty { display: none; }
  .portfolio-pagination button {
    min-width: 38px;
    height: 38px;
    padding: 0 12px;
    background: #fff;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    font-family: 'Poppins', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #111;
    cursor: pointer;
    transition: border-color .15s, background .15s, color .15s;
  }
  .portfolio-pagination button:hover:not(:disabled):not(.active) { border-color: #111; }
  .portfolio-pagination button.active {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }
  .portfolio-pagination button:disabled { opacity: 0.35; cursor: default; }
  .portfolio-pagination button[data-dir] { font-weight: 600; }

  /* Bottom CTA */
  .portfolio-page__cta {
    background: #000;
    color: #fff;
    padding: 4rem 0;
    text-align: center;
  }
  .portfolio-page__cta h2 {
    color: #fff;
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    margin-bottom: 2rem;
  }
  .portfolio-page__cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

<script is:inline>
  (function () {
    var grid = document.querySelector('[data-past-grid]');
    var pagination = document.querySelector('[data-past-pagination]');
    if (!grid || !pagination) return;

    var cards = Array.prototype.slice.call(grid.querySelectorAll('[data-page]'));
    if (cards.length === 0) return;

    var totalPages = cards.reduce(function (max, c) {
      var p = parseInt(c.getAttribute('data-page'), 10);
      return p > max ? p : max;
    }, 1);

    if (totalPages <= 1) return;

    function showPage(page) {
      cards.forEach(function (c) {
        c.style.display = parseInt(c.getAttribute('data-page'), 10) === page ? '' : 'none';
      });
      pagination.querySelectorAll('button[data-goto]').forEach(function (b) {
        b.classList.toggle('active', parseInt(b.getAttribute('data-goto'), 10) === page);
      });
      var prev = pagination.querySelector('button[data-dir="prev"]');
      var next = pagination.querySelector('button[data-dir="next"]');
      if (prev) prev.disabled = page === 1;
      if (next) next.disabled = page === totalPages;
      pagination._currentPage = page;
    }

    // Build controls: Prev · 1 · 2 · … · Next
    var html = '<button type="button" data-dir="prev" aria-label="Previous page">‹</button>';
    for (var p = 1; p <= totalPages; p++) {
      html += '<button type="button" data-goto="' + p + '">' + p + '</button>';
    }
    html += '<button type="button" data-dir="next" aria-label="Next page">›</button>';
    pagination.innerHTML = html;

    pagination.addEventListener('click', function (e) {
      var btn = e.target.closest('button');
      if (!btn) return;
      var current = pagination._currentPage || 1;
      if (btn.hasAttribute('data-goto')) {
        showPage(parseInt(btn.getAttribute('data-goto'), 10));
      } else if (btn.getAttribute('data-dir') === 'prev' && current > 1) {
        showPage(current - 1);
      } else if (btn.getAttribute('data-dir') === 'next' && current < totalPages) {
        showPage(current + 1);
      }
      // Bring the section heading back into view so users see page top
      var heading = document.getElementById('recent-sales');
      if (heading) heading.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    showPage(1);
  })();
</script>
