---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';
import { collectionPageSchema, breadcrumbSchema } from '../lib/schema';

const sections = [
  {
    title: 'The Home Buying Process',
    description: 'A step-by-step walkthrough from finding an agent to getting your keys on closing day.',
    href: '/buyers-guide/home-buying-process',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>`,
  },
  {
    title: 'Why Work with a REALTOR\u00AE',
    description: 'Learn why partnering with a licensed REALTOR\u00AE gives you a major advantage in the home buying process.',
    href: '/buyers-guide/why-use-a-realtor',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
  },
  {
    title: 'Mortgage Checklist',
    description: 'The documents and information you\'ll need to provide your lender to get pre-approved for a home loan.',
    href: '/buyers-guide/mortgage-checklist',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    title: 'Common Real Estate Terms',
    description: 'A glossary of the most common terms you\'ll encounter during a real estate transaction.',
    href: '/buyers-guide/real-estate-terms',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 016.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 014 19.5v-15A2.5 2.5 0 016.5 2z"/></svg>`,
  },
  {
    title: 'New Braunfels Utility Providers',
    description: 'Contact information for electric, water, sewer, gas, trash, internet, and phone providers in the area.',
    href: '/buyers-guide/utility-providers',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>`,
  },
];

const pageTitle = "Buyer's Guide | New Braunfels Home Buying | Cody Posey";
const pageDescription = 'The complete guide to buying a home in New Braunfels, TX — step-by-step process, mortgage checklist, real estate terms, and local utility provider contacts.';
const pageSchema = [
  collectionPageSchema({
    name: "New Braunfels Buyer's Guide",
    description: pageDescription,
    url: '/buyers-guide',
    hasPart: [
      { name: 'The Home Buying Process', url: '/buyers-guide/home-buying-process' },
      { name: 'Why Work with a REALTOR', url: '/buyers-guide/why-use-a-realtor' },
      { name: 'Mortgage Checklist', url: '/buyers-guide/mortgage-checklist' },
      { name: 'Common Real Estate Terms', url: '/buyers-guide/real-estate-terms' },
      { name: 'New Braunfels Utility Providers', url: '/buyers-guide/utility-providers' },
    ],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: "Buyer's Guide", url: '/buyers-guide' },
  ]),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={pageSchema}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="bg-hero">
      <div class="bg-hero__overlay"></div>
      <div class="bg-hero__content">
        <h1>Buyer's <span style="color:#FF1616;">Guide</span></h1>
        <p>Everything you need to know before buying a home in New Braunfels &amp; the surrounding Hill Country area</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="bg-intro">Buying a home is one of the biggest financial decisions you'll make. Whether you're a first-time buyer or have been through the process before, having the right information upfront can make all the difference. Explore the guides below to get prepared.</p>

        <div class="bg-expanded-content">
          <h2>Your Complete Guide to Buying a Home in <span class="accent">New Braunfels</span></h2>
          <p>New Braunfels is one of the fastest-growing cities in Texas, and for good reason. Nestled between San Antonio and Austin along the I-35 corridor, this Hill Country community offers a rare combination of small-town charm, strong schools, outdoor recreation, and a thriving local economy. Whether you are relocating from out of state, moving up from your first home, or buying your very first property, this guide was built to help you navigate the process with confidence.</p>

          <p>The New Braunfels real estate market moves quickly. Homes in popular neighborhoods like Vintage Oaks, River Chase, Mission Hills Ranch, and Gruene can receive multiple offers within days of being listed. Understanding the home buying timeline, knowing what documents your lender needs, and working with a knowledgeable local REALTOR can mean the difference between landing the home you want and watching it slip away.</p>

          <h3>Why New Braunfels Continues to Attract Buyers</h3>
          <p>With attractions like the Guadalupe River, Schlitterbahn Waterpark, the historic Gruene Hall, and Landa Park, New Braunfels draws visitors year-round. But what keeps people here is the quality of life. Comal ISD and New Braunfels ISD both earn strong ratings, property tax rates remain competitive compared to other fast-growing Texas metros, and the community continues to invest in infrastructure, parks, and public amenities. The city also benefits from no state income tax, making it even more appealing for families and retirees alike.</p>

          <p>For buyers considering the surrounding area, communities like Canyon Lake, Gruene, Schertz, and Garden Ridge offer additional options with easy access to New Braunfels amenities. Each of these areas has its own character and price range, so understanding the local landscape is critical before you start your search.</p>

          <h3>What to Expect as a Buyer in Today's Market</h3>
          <p>Texas uses a standardized set of real estate contracts written by the Texas Real Estate Commission, which provides a layer of protection for both buyers and sellers. As a buyer, you will typically have an option period — a negotiated number of days during which you can have the home inspected and back out for any reason. This is one of the most important protections available to Texas buyers, and your REALTOR will help you use it wisely.</p>

          <p>Financing is another area where preparation pays off. Getting pre-approved before you start touring homes tells sellers you are a serious, qualified buyer. It also gives you a realistic picture of your budget, so you do not waste time looking at homes outside your range. In the guides below, you will find a detailed mortgage checklist, a full walkthrough of the buying process, a glossary of common terms, and local utility provider information to make your transition as smooth as possible.</p>

          <p>Whether you are buying a starter home, a forever home, or an investment property in the New Braunfels area, these resources will give you the knowledge you need. And when you are ready to take the next step, I am here to help you every step of the way.</p>
        </div>
      </div>
    </section>

    <!-- Section Cards -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="bg-cards">
          {sections.map((s) => (
            <a href={s.href} class="bg-card">
              <div class="bg-card__icon" set:html={s.icon} />
              <h3>{s.title}</h3>
              <p>{s.description}</p>
              <span class="bg-card__link">Learn More &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="bg-cta">
      <div class="bg-cta__overlay"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <h2>Ready to Start Your <span class="accent">Home Search</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Whether you're just starting to think about buying or you're ready to tour homes this weekend — I'm here to guide you every step of the way.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="/search" class="btn btn-primary">Search Homes</a>
          <a href="#contact" class="btn btn-outline">Let's Connect</a>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About Buying a Home in New Braunfels</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Is New Braunfels a good place to buy a home right now?</summary>
            <p>New Braunfels continues to be one of the most desirable markets in Central Texas. The city's strong school districts, growing economy, proximity to both San Antonio and Austin, and exceptional quality of life make it a solid choice for buyers. Home values in the area have shown steady appreciation over the past several years, and ongoing development in infrastructure and commercial amenities supports long-term growth. Whether you are buying for your family or as an investment, New Braunfels offers strong fundamentals.</p>
          </details>
          <details class="faq-item">
            <summary>How much do I need for a down payment on a home in Texas?</summary>
            <p>Down payment requirements vary based on the type of loan you choose. Conventional loans typically require between 3 and 20 percent down, while FHA loans can go as low as 3.5 percent. VA loans, available to eligible veterans and active-duty service members, often require zero down payment. There are also down payment assistance programs available in Texas for qualifying buyers. I recommend connecting with a local lender early in the process to explore your options and find the best fit for your financial situation.</p>
          </details>
          <details class="faq-item">
            <summary>Do I need a REALTOR to buy a home, or can I do it myself?</summary>
            <p>While it is technically possible to purchase a home without representation, having a REALTOR on your side provides significant advantages. A buyer's agent negotiates on your behalf, helps you navigate the complex Texas real estate contracts, coordinates inspections and appraisals, and ensures deadlines are met throughout the transaction. In most cases, the seller pays the listing broker's commission, so working with a buyer's agent typically costs you nothing out of pocket. Having professional guidance protects your interests and often saves you money in the long run.</p>
          </details>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/guadalupe-river.png" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Is New Braunfels a good place to buy a home right now?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "New Braunfels continues to be one of the most desirable markets in Central Texas. The city's strong school districts, growing economy, proximity to both San Antonio and Austin, and exceptional quality of life make it a solid choice for buyers. Home values in the area have shown steady appreciation over the past several years, and ongoing development in infrastructure and commercial amenities supports long-term growth. Whether you are buying for your family or as an investment, New Braunfels offers strong fundamentals."
        }
      },
      {
        "@type": "Question",
        "name": "How much do I need for a down payment on a home in Texas?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Down payment requirements vary based on the type of loan you choose. Conventional loans typically require between 3 and 20 percent down, while FHA loans can go as low as 3.5 percent. VA loans, available to eligible veterans and active-duty service members, often require zero down payment. There are also down payment assistance programs available in Texas for qualifying buyers. I recommend connecting with a local lender early in the process to explore your options and find the best fit for your financial situation."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need a REALTOR to buy a home, or can I do it myself?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "While it is technically possible to purchase a home without representation, having a REALTOR on your side provides significant advantages. A buyer's agent negotiates on your behalf, helps you navigate the complex Texas real estate contracts, coordinates inspections and appraisals, and ensures deadlines are met throughout the transaction. In most cases, the seller pays the listing broker's commission, so working with a buyer's agent typically costs you nothing out of pocket. Having professional guidance protects your interests and often saves you money in the long run."
        }
      }
    ]
  }
  </script>

  <ContactForm context="I'm interested in buying a home in the New Braunfels area..." />
  <Footer />
</Layout>

<style>
  /* Hero */
  .bg-hero {
    position: relative;
    height: 320px;
    background: url('/images/generated/family-new-home.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .bg-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
  }

  .bg-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .bg-hero__content h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .bg-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    max-width: 550px;
    margin: 0 auto;
  }

  /* Intro */
  .bg-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 750px;
    text-align: center;
    margin: 0 auto;
    font-weight: 600;
  }

  /* Cards */
  .bg-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .bg-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    text-align: center;
  }

  .bg-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  }

  .bg-card__icon {
    margin: 0 auto 1.25rem;
  }

  .bg-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    color: #000;
  }

  .bg-card p {
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .bg-card__link {
    display: inline-block;
    margin-top: 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #FF1616;
    transition: letter-spacing 0.2s;
  }

  .bg-card:hover .bg-card__link {
    letter-spacing: 0.14em;
  }

  /* CTA Parallax */
  .bg-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .bg-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
  }

  .bg-cta h2 {
    color: #fff;
  }

  @media (max-width: 900px) {
    .bg-cards {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .bg-cards {
      grid-template-columns: 1fr;
    }

    .bg-cta {
      background-attachment: scroll;
    }
  }

  /* Expanded Content */
  .bg-expanded-content {
    max-width: 800px;
    margin: 2.5rem auto 0;
  }

  .bg-expanded-content h2 {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .bg-expanded-content h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 2rem 0 0.75rem;
  }

  .bg-expanded-content p {
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  /* FAQ */
  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }
</style>
