---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Explore Area | New Braunfels & Texas Hill Country | Cody Posey Real Estate"
  description="Explore neighborhoods, homes for sale, new construction, schools, and lifestyle in New Braunfels and the Texas Hill Country."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="ea-hero">
      <div class="ea-hero__overlay"></div>
      <div class="ea-hero__content">
        <h1>Explore the <span style="color:#FF1616;">Area</span></h1>
        <p>Your guide to neighborhoods, homes, and lifestyle in New Braunfels and the Texas Hill Country</p>
      </div>
    </div>

    <!-- New Braunfels Section -->
    <section class="section">
      <div class="container">
        <div class="ea-city">
          <div class="ea-city__header">
            <h2>New <span class="accent">Braunfels</span></h2>
            <p>One of the fastest-growing cities in Texas, located between Austin and San Antonio along the I-35 corridor. Explore everything New Braunfels has to offer — from neighborhoods and schools to new construction and daily life.</p>
            <a href="/new-braunfels/" class="btn btn-outline-dark">New Braunfels Overview</a>
          </div>

          <div class="ea-links__grid">
            <a href="/new-braunfels/neighborhoods/" class="ea-link-card">
              <div class="ea-link-card__icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              </div>
              <h3>Neighborhoods</h3>
              <p>Gruene, Downtown, West of I-35, North NB, East of I-35 — understand how the city is laid out and where you might fit.</p>
            </a>

            <a href="/new-braunfels/new-construction/" class="ea-link-card">
              <div class="ea-link-card__icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="6" width="22" height="16" rx="2"/><path d="M1 10h22"/><path d="M12 6V2"/><path d="M8 6V4"/><path d="M16 6V4"/></svg>
              </div>
              <h3>New Construction</h3>
              <p>Veramendi, Vintage Oaks, Meyer Ranch, Mayfair, Legacy at Lake Dunlap — explore builder communities and what to know before buying new.</p>
            </a>

            <a href="/new-braunfels/homes-for-sale/" class="ea-link-card">
              <div class="ea-link-card__icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
              </div>
              <h3>Homes for Sale</h3>
              <p>Search current MLS listings in New Braunfels. Filter by location, price, and property type.</p>
            </a>

            <a href="/new-braunfels/living-in-new-braunfels/" class="ea-link-card">
              <div class="ea-link-card__icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
              </div>
              <h3>Living Here</h3>
              <p>What daily life actually looks like — commutes, culture, growth, weather, and who New Braunfels is best for.</p>
            </a>

            <a href="/new-braunfels/schools/" class="ea-link-card">
              <div class="ea-link-card__icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/></svg>
              </div>
              <h3>Schools</h3>
              <p>New Braunfels ISD and Comal ISD overview. Understand how attendance boundaries affect your home search.</p>
            </a>

            <a href="/new-braunfels/faq/" class="ea-link-card">
              <div class="ea-link-card__icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </div>
              <h3>FAQ</h3>
              <p>Answers to the most common questions buyers ask about moving to and living in New Braunfels.</p>
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Coming Soon -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container" style="text-align: center;">
        <h2>More Areas <span class="accent">Coming Soon</span></h2>
        <p style="color: var(--gray); max-width: 600px; margin: 1rem auto 0;">Guides for San Marcos, Seguin, Canyon Lake, and other Texas Hill Country communities are in the works. Check back soon or reach out if you have questions about a specific area.</p>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" style="background: #000; color: #fff; text-align: center;">
      <div class="container">
        <h2>Not Sure Where to <span class="accent">Start</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Tell me what matters most — commute, schools, budget, lifestyle — and I'll help you narrow down the areas that make sense.</p>
        <a href="#contact" class="btn btn-outline">Get Help Finding Your Area</a>
      </div>
    </section>

  </main>
  <ContactForm context="I'm exploring areas in the Texas Hill Country..." />
  <Footer />
</Layout>

<style>
  .ea-hero {
    position: relative;
    height: 320px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .ea-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #000 0%, #1a0000 100%);
    opacity: 0.9;
  }

  .ea-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .ea-hero__content h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 0.75rem;
  }

  .ea-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    max-width: 600px;
    margin: 0 auto;
  }

  /* City Section */
  .ea-city__header {
    margin-bottom: 2.5rem;
  }

  .ea-city__header p {
    color: var(--gray);
    line-height: 1.7;
    max-width: 700px;
    margin: 1rem 0 1.5rem;
  }

  /* Link Cards Grid */
  .ea-links__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .ea-link-card {
    display: block;
    background: #fff;
    border: 1px solid var(--light-gray);
    padding: 2rem;
    border-radius: 8px;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .ea-link-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .ea-link-card__icon {
    margin-bottom: 1rem;
  }

  .ea-link-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    color: #000;
  }

  .ea-link-card:hover h3 {
    color: #FF1616;
  }

  .ea-link-card p {
    color: var(--gray);
    font-size: 0.85rem;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .ea-links__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
