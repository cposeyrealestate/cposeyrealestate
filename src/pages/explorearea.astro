---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';

const areas = [
  {
    name: 'New Braunfels',
    slug: 'new-braunfels',
    tagline: 'Where Texas Heritage Meets Hill Country Living',
    description: "One of the fastest-growing cities in the nation. Spring-fed rivers, historic Gruene, top-rated schools, and a thriving local economy between Austin and San Antonio.",
    stats: ['100K+ Pop.', '30 min to SA', '$370K Median'],
    highlights: ['Comal & Guadalupe Rivers', 'Gruene Historic District', 'Schlitterbahn', 'Two Top School Districts'],
  },
  {
    name: 'Canyon Lake',
    slug: 'canyon-lake',
    tagline: 'Hill Country Lakeside Living at Its Best',
    description: "Scenic community built around the 8,230-acre Canyon Lake reservoir. Known for waterfront living, boating, fishing, and a laid-back Hill Country lifestyle.",
    stats: ['33K+ Pop.', '20 min to NB', '$406K Median'],
    highlights: ['8,230-Acre Lake', 'Whitewater Amphitheater', 'Boating & Fishing', 'Hill Country Views'],
  },
  {
    name: 'Seguin',
    slug: 'seguin',
    tagline: 'Affordable Living with Small-Town Texas Charm',
    description: "Historic city on the Guadalupe River with the most affordable housing in the region. Growing job market, charming downtown, and Michelin-recognized BBQ.",
    stats: ['33K+ Pop.', '35 min to SA', '$313K Median'],
    highlights: ['Most Affordable Area', 'Burnt Bean Co. BBQ', 'Max Starcke Park', 'Strong Job Market'],
  },
  {
    name: 'Cibolo / Schertz',
    slug: 'cibolo-schertz',
    tagline: 'Family-Friendly Communities Between SA & NB',
    description: "Two of the most desirable suburban communities in the I-35 corridor. A-rated schools, safe neighborhoods, and proximity to Randolph Air Force Base.",
    stats: ['75K+ Pop.', '20 min to SA', '$372K Median'],
    highlights: ['A-Rated SCUCISD', 'Near Randolph AFB', '85+ Acres of Parks', 'Military-Friendly'],
  },
  {
    name: 'Bulverde',
    slug: 'bulverde',
    tagline: 'Quiet Hill Country Living on Acreage',
    description: "Rural Hill Country community known for larger lots, scenic views, and a quieter pace. Close to Guadalupe River State Park and the JW Marriott Resort.",
    stats: ['6K+ Pop.', '25 min to SA', '$406K Median'],
    highlights: ['Large Lots & Acreage', 'Guadalupe River State Park', 'Hill Country Views', 'Comal ISD'],
  },
];
---

<Layout
  title="Explore Area | New Braunfels & Texas Hill Country | Cody Posey Real Estate"
  description="Explore neighborhoods, homes for sale, restaurants, things to do, and lifestyle across New Braunfels, Canyon Lake, Seguin, Cibolo/Schertz, and Bulverde."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="ea-hero" style="background-image:url('/images/generated/hill-country-aerial.png');">
      <div class="ea-hero__overlay"></div>
      <div class="ea-hero__content">
        <h1>Explore the <span style="color:#FF1616;">Area</span></h1>
        <p>Your guide to neighborhoods, homes, and lifestyle across the Texas Hill Country</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="ea-intro">The Texas Hill Country offers something for everyone — from river towns and lakeside communities to family-friendly suburbs and quiet acreage. I cover five distinct areas, each with its own character, price points, and lifestyle. Explore below to find the one that fits you.</p>
      </div>
    </section>

    <!-- Area Cards -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        {areas.map((area, i) => (
          <div class={`ea-area ${i > 0 ? 'ea-area--spaced' : ''}`}>
            <div class="ea-area__content">
              <span class="ea-area__tagline">{area.tagline}</span>
              <h2><a href={`/${area.slug}/`}>{area.name}</a></h2>
              <p class="ea-area__desc">{area.description}</p>
              <div class="ea-area__stats">
                {area.stats.map(stat => (
                  <span class="ea-area__stat">{stat}</span>
                ))}
              </div>
              <div class="ea-area__highlights">
                {area.highlights.map(h => (
                  <span class="ea-area__highlight">&#10003; {h}</span>
                ))}
              </div>
              <div class="ea-area__links">
                <a href={`/${area.slug}/`}>Overview</a>
                <a href={`/${area.slug}/neighborhoods/`}>Neighborhoods</a>
                <a href="/search">Home Search</a>
                <a href={`/${area.slug}/restaurants/`}>Restaurants</a>
                <a href={`/${area.slug}/things-to-do/`}>Things to Do</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Educational Content -->
    <section class="section">
      <div class="container">
        <div style="max-width:800px;margin:0 auto;">
          <h2>Choosing the Right <span class="accent">Area</span></h2>
          <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">The Texas Hill Country is one of the most diverse real estate markets in the state, and choosing the right area is about much more than price. Each community has its own character, school districts, commute patterns, and lifestyle. The five areas I serve — New Braunfels, Canyon Lake, Seguin, Cibolo/Schertz, and Bulverde — represent a wide range of options, from walkable downtown living to lakeside retreats to quiet acreage on a hilltop.</p>
          <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">When helping clients narrow down their search, I focus on a few key factors. First, commute: where do you work, and how far are you willing to drive? If you commute to San Antonio daily, the south side of New Braunfels or Cibolo/Schertz may be the best fit. If you work remotely, the options open up significantly. Second, schools: if you have school-age children, the specific school district and campus assignments can shape your search area. Third, lifestyle: do you want to be close to restaurants and entertainment, or do you prefer space and quiet? Each area offers something different.</p>
          <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">I have deep knowledge of all five areas and the neighborhoods within them. I can tell you which subdivisions are in which school zones, where the traffic bottlenecks are, which areas are likely to see the most appreciation, and where you get the best value for your budget. If you are relocating from out of the area, I can also help you understand the cultural differences between communities and what daily life actually looks like in each one.</p>
          <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">Explore the area profiles above to get started, and reach out when you are ready to take the next step. I am happy to have a no-pressure conversation about which area fits your needs.</p>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About the Texas Hill Country</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Which area has the most affordable homes?</summary>
            <p>Seguin currently offers the most affordable housing in the region, with a median home price well below New Braunfels and Canyon Lake. The south side of New Braunfels along the I-35 corridor also offers newer construction at accessible price points, particularly in master-planned communities with builder incentives.</p>
          </details>
          <details class="faq-item">
            <summary>Where should military families look for homes?</summary>
            <p>Cibolo and Schertz are popular with military families due to their proximity to Randolph Air Force Base and the A-rated Schertz-Cibolo-Universal City ISD. New Braunfels is also a strong option for families stationed at Fort Sam Houston or Lackland, with a 30-40 minute commute to JBSA installations. VA loans are widely accepted throughout all five areas.</p>
          </details>
          <details class="faq-item">
            <summary>What is the best area for retirees?</summary>
            <p>All five areas attract retirees, but Bulverde and Canyon Lake are particularly popular for their quiet, scenic settings and larger lot sizes. New Braunfels offers the best combination of amenities, healthcare access, and community activities. Texas has no state income tax, and property tax exemptions for veterans and seniors can significantly reduce costs.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="ea-cta">
      <div class="ea-cta__overlay"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <h2>Not Sure Which Area Is <span class="accent">Right for You</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Tell me what matters most — schools, commute, budget, lifestyle — and I'll help you narrow it down.</p>
        <a href="#contact" class="btn btn-primary">Let's Talk</a>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/hill-country-sunset.png" />

  <ContactForm context="I'm exploring areas in the Texas Hill Country and need guidance..." />
  <Footer />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Which area has the most affordable homes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Seguin currently offers the most affordable housing in the region. The south side of New Braunfels along the I-35 corridor also offers newer construction at accessible price points."
        }
      },
      {
        "@type": "Question",
        "name": "Where should military families look for homes?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Cibolo and Schertz are popular with military families due to their proximity to Randolph Air Force Base and A-rated SCUCISD. New Braunfels is also strong for families at Fort Sam Houston or Lackland."
        }
      },
      {
        "@type": "Question",
        "name": "What is the best area for retirees?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bulverde and Canyon Lake are popular for quiet, scenic settings. New Braunfels offers the best combination of amenities, healthcare access, and community activities. Texas has no state income tax."
        }
      }
    ]
  }
  </script>
</Layout>

<style>
  /* Hero */
  .ea-hero {
    position: relative;
    height: 320px;
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .ea-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .ea-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .ea-hero__content h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 0.75rem;
  }

  .ea-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    max-width: 550px;
    margin: 0 auto;
  }

  /* Intro */
  .ea-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
    text-align: center;
    margin: 0 auto;
    font-weight: 600;
  }

  /* Area Cards */
  .ea-area {
    background: #fff;
    border-radius: 12px;
    padding: 2.5rem;
    box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  }

  .ea-area--spaced {
    margin-top: 2rem;
  }

  .ea-area__tagline {
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #FF1616;
    margin-bottom: 0.5rem;
  }

  .ea-area__content h2 {
    margin-bottom: 0.75rem;
  }

  .ea-area__content h2 a {
    color: #000;
    transition: color 0.2s;
  }

  .ea-area__content h2 a:hover {
    color: #FF1616;
  }

  .ea-area__desc {
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.7;
    max-width: 700px;
    margin-bottom: 1.25rem;
  }

  .ea-area__stats {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.25rem;
    flex-wrap: wrap;
  }

  .ea-area__stat {
    background: var(--light-gray);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    color: #333;
  }

  .ea-area__highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
    margin-bottom: 1.5rem;
  }

  .ea-area__highlight {
    font-size: 0.82rem;
    color: var(--gray);
  }

  .ea-area__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .ea-area__links a {
    padding: 0.5rem 1.25rem;
    border: 2px solid #FF1616;
    border-radius: 6px;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #FF1616;
    transition: all 0.2s;
  }

  .ea-area__links a:hover {
    background: #FF1616;
    color: #fff;
  }

  /* CTA */
  .ea-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .ea-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
  }

  .ea-cta h2 { color: #fff; }

  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }

  @media (max-width: 600px) {
    .ea-area {
      padding: 1.5rem;
    }

    .ea-area__links {
      flex-direction: column;
    }

    .ea-area__links a {
      text-align: center;
    }

    .ea-cta { background-attachment: scroll; }
  }
</style>
