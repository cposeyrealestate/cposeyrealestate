---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import blogPosts from '../../data/blog-posts.json';
import { breadcrumbSchema } from '../../lib/schema';
import seo from '../../data/seo.json';

const POSTS_PER_PAGE = 12;
const posts = [...blogPosts].sort((a, b) => (b.dateRaw || '').localeCompare(a.dateRaw || ''));
const totalPages = Math.max(1, Math.ceil(posts.length / POSTS_PER_PAGE));

// Blog index schema: a Blog entity that lists the most recent posts.
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': 'https://cposeyrealestate.com/blog#blog',
  name: 'Cody Posey Real Estate Blog',
  description:
    'Market updates, neighborhood guides, and expert insight for buyers and sellers in New Braunfels and the Texas Hill Country.',
  url: 'https://cposeyrealestate.com/blog',
  publisher: { '@id': `${seo.site.url}#business` },
  blogPost: posts.slice(0, 10).map((p) => ({
    '@type': 'BlogPosting',
    headline: p.title,
    url: `https://cposeyrealestate.com/blog/${p.slug}`,
    datePublished: p.dateRaw,
    image: p.featuredImage,
  })),
};
---

<Layout
  title="New Braunfels Real Estate Blog | Cody Posey"
  description="Market updates, neighborhood guides, and expert buyer + seller insights for New Braunfels, Canyon Lake, and the Texas Hill Country."
  schema={[
    blogSchema,
    breadcrumbSchema([
      { name: 'Home', url: '/' },
      { name: 'Blog', url: '/blog' },
    ]),
  ]}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="blog-hero">
      <div class="blog-hero__overlay"></div>
      <div class="blog-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <span>Blog</span>
        </nav>
        <h1>Cody Posey <span style="color:#FF1616;">Real Estate Blog</span></h1>
        <p>Insights on buying, selling, and living in the New Braunfels area</p>
      </div>
    </div>

    <!-- Blog Grid -->
    <section class="section" id="blog-list">
      <div class="container">
        <div class="blog-grid" data-blog-grid>
          {posts.map((post, i) => (
            <article class="blog-card" data-page={Math.floor(i / POSTS_PER_PAGE) + 1}>
              <a href={`/blog/${post.slug}`} class="blog-card__img-link">
                <img src={post.featuredImage} alt={post.title} class="blog-card__img" loading="lazy" />
              </a>
              <div class="blog-card__body">
                <span class="blog-card__cat">{post.category}</span>
                <h3 class="blog-card__title">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h3>
                <p class="blog-card__excerpt">{post.excerpt.slice(0, 150)}...</p>
                <p class="blog-card__meta">Cody Posey &nbsp;|&nbsp; {post.date}</p>
              </div>
            </article>
          ))}
        </div>
        {totalPages > 1 && <nav class="blog-pagination" data-blog-pagination aria-label="Blog pages"></nav>}
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .blog-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/porch-view.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .blog-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .blog-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .blog-hero__content h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 0.75rem;
  }

  .blog-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #FF1616;
  }

  .breadcrumb span {
    margin: 0 0.3rem;
  }

  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--light-gray);
    border-radius: 8px;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.1);
  }

  .blog-card__img-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .blog-card:hover .blog-card__img {
    transform: scale(1.05);
  }

  .blog-card__body {
    padding: 1.25rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .blog-card__cat {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #FF1616;
    margin-bottom: 0.5rem;
  }

  .blog-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 0.5rem;
  }

  .blog-card__title a {
    color: #000;
    transition: color 0.2s;
  }

  .blog-card__title a:hover {
    color: #FF1616;
  }

  .blog-card__excerpt {
    font-size: 0.8rem;
    color: var(--gray);
    line-height: 1.5;
    margin-bottom: 0.75rem;
    flex: 1;
  }

  .blog-card__meta {
    font-size: 0.7rem;
    color: #999;
    margin-top: auto;
  }

  @media (max-width: 900px) {
    .blog-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .blog-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Pagination */
  .blog-pagination {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 3rem;
    flex-wrap: wrap;
  }
  .blog-pagination:empty { display: none; }
  /* Buttons are created at runtime via JS — use :global() so the scoped
     CSS hash isn't required to match them. */
  .blog-pagination :global(button) {
    min-width: 38px;
    height: 38px;
    padding: 0 12px;
    background: #fff;
    border: 1px solid #d9d9d9;
    border-radius: 6px;
    font-family: 'Poppins', sans-serif;
    font-size: 0.85rem;
    font-weight: 500;
    color: #111;
    cursor: pointer;
    transition: border-color .15s, background .15s, color .15s;
  }
  .blog-pagination :global(button:hover:not(:disabled):not(.active)) { border-color: #111; }
  .blog-pagination :global(button.active) {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }
  .blog-pagination :global(button:disabled) { opacity: 0.35; cursor: default; }
  .blog-pagination :global(button[data-dir]) { font-weight: 600; }
</style>

<script is:inline>
  (function () {
    var grid = document.querySelector('[data-blog-grid]');
    var pagination = document.querySelector('[data-blog-pagination]');
    if (!grid || !pagination) return;

    var cards = Array.prototype.slice.call(grid.querySelectorAll('[data-page]'));
    if (cards.length === 0) return;
    var totalPages = cards.reduce(function (m, c) {
      var p = parseInt(c.getAttribute('data-page'), 10);
      return p > m ? p : m;
    }, 1);
    if (totalPages <= 1) return;

    function showPage(page) {
      cards.forEach(function (c) {
        c.style.display = parseInt(c.getAttribute('data-page'), 10) === page ? '' : 'none';
      });
      pagination.querySelectorAll('button[data-goto]').forEach(function (b) {
        b.classList.toggle('active', parseInt(b.getAttribute('data-goto'), 10) === page);
      });
      var prev = pagination.querySelector('button[data-dir="prev"]');
      var next = pagination.querySelector('button[data-dir="next"]');
      if (prev) prev.disabled = page === 1;
      if (next) next.disabled = page === totalPages;
      pagination._currentPage = page;
    }

    var html = '<button type="button" data-dir="prev" aria-label="Previous page">‹</button>';
    for (var p = 1; p <= totalPages; p++) {
      html += '<button type="button" data-goto="' + p + '">' + p + '</button>';
    }
    html += '<button type="button" data-dir="next" aria-label="Next page">›</button>';
    pagination.innerHTML = html;

    pagination.addEventListener('click', function (e) {
      var btn = e.target.closest('button');
      if (!btn) return;
      var current = pagination._currentPage || 1;
      if (btn.hasAttribute('data-goto')) {
        showPage(parseInt(btn.getAttribute('data-goto'), 10));
      } else if (btn.getAttribute('data-dir') === 'prev' && current > 1) {
        showPage(current - 1);
      } else if (btn.getAttribute('data-dir') === 'next' && current < totalPages) {
        showPage(current + 1);
      }
      var section = document.getElementById('blog-list');
      if (section) section.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });

    showPage(1);
  })();
</script>
