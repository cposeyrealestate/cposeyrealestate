---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Home Search | Cody Posey Real Estate"
  description="Search homes for sale in New Braunfels and the Texas Hill Country."
>
  <Navbar />
  <main style="padding-top: 100px; min-height: 60vh;">
    <div style="max-width: 900px; margin: 0 auto; padding: 4rem 1.5rem; text-align: center;">
      <h1 style="font-family: 'Poppins', sans-serif; text-transform: uppercase; letter-spacing: .05em; margin-bottom: 1rem;">
        Home Search
      </h1>
      <p style="color: #555; font-size: 1rem;">
        Coming soon.
      </p>
    </div>
  </main>
  <Footer />
</Layout>
