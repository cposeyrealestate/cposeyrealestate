---
// /search redirects to the IDX-hosted live search.
// IDX wraps that URL with our site nav/footer, so the user sees a native experience.
// Once `search.cposeyrealestate.com` CNAME is configured, update this URL.
const IDX_SEARCH_URL = 'https://cposeyrealestate.idxbroker.com/idx/search/advanced';
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="refresh" content={`0; url=${IDX_SEARCH_URL}`} />
  <link rel="canonical" href={IDX_SEARCH_URL} />
  <title>Home Search | Cody Posey Real Estate</title>
  <script is:inline define:vars={{ url: IDX_SEARCH_URL }}>
    window.location.replace(url);
  </script>
</head>
<body>
  <p style="font-family:sans-serif;text-align:center;padding:4rem;">
    Loading home search&hellip; If you aren't redirected, <a href={IDX_SEARCH_URL}>click here</a>.
  </p>
</body>
</html>
