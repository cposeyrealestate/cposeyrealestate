---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Home Search | Cody Posey Real Estate"
  description="Search homes for sale in New Braunfels and the Texas Hill Country."
>
  <Navbar />
  <main class="search-main">
    <section class="search-hero">
      <div class="container">
        <h1>Home <span class="accent">Search</span></h1>
        <p>Browse active listings across New Braunfels and the Texas Hill Country.</p>
      </div>
    </section>

    <section class="search-embed">
      <div class="container">
        <div class="search-embed__frame">
          <iframe
            src="https://codyposey.popbyrealty.com/wide.php"
            title="Home Search"
            allowtransparency="true"
            frameborder="0"
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .search-main {
    padding-top: 80px;
    background: #0b0b0b;
  }

  .search-hero {
    background: #000;
    color: #fff;
    padding: 3rem 1.5rem 2rem;
    text-align: center;
  }

  .search-hero h1 {
    font-family: 'Poppins', sans-serif;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .search-hero .accent {
    color: #FF1616;
  }

  .search-hero p {
    color: #aaa;
    font-size: 0.95rem;
  }

  .search-embed {
    padding: 2.5rem 1.5rem 4rem;
    background: #0b0b0b;
  }

  .search-embed__frame {
    display: flex;
    justify-content: center;
  }

  .search-embed iframe {
    width: 100%;
    max-width: 960px;
    height: 300px;
    border: 0;
    background: transparent;
    border-radius: 8px;
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.5);
  }
</style>
