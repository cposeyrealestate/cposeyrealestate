    color: var(--gray);
    font-size: 0.85rem;
    line-height: 1.5;
    margin-bottom: 0.3rem;
  }

  .utility-contact {
    font-size: 0.85rem;
  }

  .utility-contact a {
    color: #FF1616;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .utility-contact a:hover { opacity: 0.7; }

  .utility-note {
    color: var(--gray);
    font-size: 0.85rem;
    font-style: italic;
    line-height: 1.6;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid #e8e8e8;
  }

  .sub-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .sub-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
  }

  .sub-cta h2 { color: #fff; }

  .utility-intro-detail {
    max-width: 800px;
    margin: 0 auto 2rem;
  }

  .utility-intro-detail h2 {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .utility-intro-detail h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 2rem 0 0.75rem;
  }

  .utility-intro-detail p {
    color: var(--gray);
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  /* FAQ */
  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
