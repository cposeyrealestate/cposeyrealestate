---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';
---

<Layout
  title="Mortgage Checklist | Buyer's Guide | Cody Posey Real Estate"
  description="Documents and information you'll need to get pre-approved for a mortgage when buying a home in New Braunfels, TX."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="sub-hero">
      <div class="sub-hero__overlay"></div>
      <div class="sub-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/buyers-guide">Buyer's Guide</a> <span>/</span> <span>Mortgage Checklist</span>
        </nav>
        <h1>Mortgage <span style="color:#FF1616;">Checklist</span></h1>
        <p>What your lender will need to validate your pre-approval</p>
      </div>
    </div>

    <!-- Content -->
    <section class="section">
      <div class="container">
        <div class="checklist-wrapper">
          <p class="page-intro">Providing a complete package to your mortgage lender initially allows them to validate your pre-approval. Missing items will cause a delay. Gather these documents before your first meeting with a lender to keep the process moving smoothly.</p>

          <div class="checklist-group">
            <h2>Required <span class="accent">Documents</span></h2>
            <ul class="checklist">
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Last 2 Pay-Stubs</strong>
                  <p>For each borrower, covering 30 days</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Last 2 Bank Statements</strong>
                  <p>ALL pages — must list client's name and full account number</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>401(k) Statement</strong>
                  <p>Most recent quarterly — ONLY if using for purchase of home or requested</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Last 2 Years Tax Returns</strong>
                  <p>ALL schedules, ALL pages, FULL SET</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Last 2 Years W-2's and 1099's</strong>
                  <p>For all borrowers on the loan</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Driver's License &amp; Social Security Cards</strong>
                  <p>Copy for all parties on the loan</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Employer HR Phone Number</strong>
                  <p>To verify employment for each borrower</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Most Recent Mortgage Statement</strong>
                  <p>For all property currently owned</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Hazard Insurance &amp; Tax Bill</strong>
                  <p>If mortgage is not escrowed, provide recent copy of hazard insurance statement and most recent tax bill</p>
                </div>
              </li>
            </ul>
          </div>

          <div class="checklist-group">
            <h2>If <span class="accent">Applicable</span></h2>
            <ul class="checklist">
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Student Loans</strong>
                  <p>If in forbearance/deferment, provide letter showing estimated payment once deferment ends. This is required and cannot be completed without it.</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Divorce Decree</strong>
                  <p>ALL PAGES of the complete decree</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Child Support Income</strong>
                  <p>Last 12 months printout from OAG online</p>
                </div>
              </li>
              <li>
                <div class="checklist__check">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                </div>
                <div>
                  <strong>Bankruptcy Documents</strong>
                  <p>Copy of all documents and discharge notices</p>
                </div>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="sub-cta">
      <div class="sub-cta__overlay"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <h2>Need Help Getting <span class="accent">Pre-Approved</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">I can connect you with trusted local lenders who will walk you through the process.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="#contact" class="btn btn-primary">Let's Connect</a>
          <a href="/buyers-guide" class="btn btn-outline">Back to Buyer's Guide</a>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/guadalupe-river.png" />

  <ContactForm context="I need help getting pre-approved for a mortgage..." />
  <Footer />
</Layout>

<style>
  .sub-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/home-nb-ranch.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .sub-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .sub-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .sub-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 0.75rem;
  }

  .sub-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: #FF1616; }
  .breadcrumb span { margin: 0 0.3rem; }

  .checklist-wrapper {
    max-width: 750px;
    margin: 0 auto;
  }

  .page-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    text-align: center;
    margin-bottom: 3rem;
    font-weight: 600;
  }

  .checklist-group {
    margin-bottom: 3rem;
  }

  .checklist-group h2 {
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 2px solid #FF1616;
  }

  .checklist {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .checklist li {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding: 1rem 1.25rem;
    background: #fafafa;
    border-radius: 8px;
    transition: background 0.2s;
  }

  .checklist li:hover {
    background: #f0f0f0;
  }

  .checklist__check {
    flex-shrink: 0;
    margin-top: 2px;
  }

  .checklist li strong {
    display: block;
    font-size: 0.95rem;
    margin-bottom: 0.2rem;
  }

  .checklist li p {
    color: var(--gray);
    font-size: 0.88rem;
    line-height: 1.5;
  }

  .sub-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .sub-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
  }

  .sub-cta h2 { color: #fff; }

  @media (max-width: 600px) {
    .sub-cta { background-attachment: scroll; }
  }
</style>
