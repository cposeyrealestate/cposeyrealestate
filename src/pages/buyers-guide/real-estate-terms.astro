    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
    text-align: center;
    margin: 0 auto 3rem;
    font-weight: 600;
  }

  .terms-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .term-card {
    background: #fafafa;
    padding: 1.5rem;
    border-radius: 8px;
    border-top: 3px solid #FF1616;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .term-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.08);
  }

  .term-card h3 {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.4rem;
  }

  .term-card p {
    color: var(--gray);
    font-size: 0.85rem;
