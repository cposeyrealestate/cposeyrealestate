---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';
import { articleSchema, breadcrumbSchema } from '../lib/schema';

const pageTitle = "What's My Home Worth? | Free Home Valuation | Cody Posey";
const pageDescription = 'Request a free, personalized home valuation in New Braunfels, San Antonio, and the Texas Hill Country — a real comparative market analysis from a local agent.';
const pageSchema = [
  articleSchema({ title: pageTitle, description: pageDescription, url: '/home-value' }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Home Value', url: '/home-value' },
  ]),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={pageSchema}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <section class="valuation-hero">
      <div class="valuation-hero__overlay"></div>
      <div class="valuation-hero__content">
        <h1>What's Your Home <span class="accent">Worth?</span></h1>
        <p>Request a free, personalized home valuation from a local expert who knows your neighborhood.</p>
      </div>
    </section>

    <!-- Valuation Form -->
    <section class="valuation-form-section">
      <div class="valuation-form__container">
        <div class="valuation-form__card">
          <h2>Request Your Free Valuation</h2>
          <p class="valuation-form__subtitle">Fill out the form below and I'll send you a comprehensive market report for your property as soon as possible — typically within 24 hours.</p>

          <form class="valuation-form" id="valuationForm" novalidate>
            <div class="valuation-form__field">
              <label for="vf-name">Full Name <span class="req">*</span></label>
              <input type="text" id="vf-name" name="name" required placeholder="Your full name" />
            </div>
            <div class="valuation-form__field">
              <label for="vf-address">Property Address <span class="req">*</span></label>
              <input type="text" id="vf-address" name="address" required placeholder="123 Main St, New Braunfels, TX 78130" />
            </div>
            <div class="valuation-form__row">
              <div class="valuation-form__field">
                <label for="vf-email">Email <span class="req">*</span></label>
                <input type="email" id="vf-email" name="email" required placeholder="you@example.com" />
              </div>
              <div class="valuation-form__field">
                <label for="vf-phone">Phone <span class="req">*</span></label>
                <input type="tel" id="vf-phone" name="phone" required placeholder="(555) 555-5555" />
              </div>
            </div>
            <button type="submit" class="valuation-form__submit">Get My Home Value</button>
          </form>

          <div class="valuation-form__success" id="valuationSuccess" style="display: none;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#28a745" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <div>
              <p class="valuation-form__success-title">Request received!</p>
              <p class="valuation-form__success-text">Thank you — I'll get back to you as soon as I can with a full, personalized home valuation report for your property.</p>
            </div>
          </div>

          <div class="valuation-form__error" id="valuationError" style="display: none;">
            <p class="valuation-form__error-title">Something went wrong</p>
            <p class="valuation-form__error-text">We couldn't submit your request. Please try again, or call <a href="tel:+18303605569">(830) 360-5569</a> directly.</p>
          </div>

          <p class="valuation-form__disclaimer">By submitting, you agree to be contacted by Cody Posey at Popby Realty. We respect your privacy and will never share your information.</p>
        </div>
      </div>
    </section>

    <!-- Educational Content -->
    <section style="padding:60px 20px;background:#fff;">
      <div style="max-width:800px;margin:0 auto;">
        <h2 style="font-size:24px;font-weight:700;margin-bottom:16px;color:#111;">How Home Valuations <span style="color:#FF1616;">Work</span></h2>
        <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">A home valuation — also called a comparative market analysis or CMA — is an estimate of your home's current market value based on recent sales of similar properties in your area. Unlike an automated online estimate from sites like Zillow or Redfin, a CMA is prepared by a local real estate professional who understands the nuances of your specific neighborhood, street, and property.</p>
        <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">Online home value estimates (often called AVMs or automated valuation models) can be useful as a starting point, but they have significant limitations. They do not account for your home's condition, upgrades, lot characteristics, or view. They cannot assess the quality of your finishes, the layout of your floor plan, or how your property compares to the homes that have recently sold nearby. In the Hill Country, where properties vary widely in lot size, topography, and style, these automated estimates can be off by tens of thousands of dollars.</p>
        <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">When I prepare a home valuation, I analyze recently sold comparable properties, active listings, and pending sales in your area. I consider factors like square footage, lot size, age, condition, upgrades, school district, and location relative to amenities. The result is a data-driven, market-specific estimate that reflects what a buyer would realistically pay for your home in the current market.</p>
        <p style="color:#555;line-height:1.8;font-size:0.95rem;margin-bottom:1.25rem;">Whether you are thinking about selling, curious about your equity, considering a refinance, or just want to stay informed about your largest asset, requesting a home valuation is a smart move. There is no cost and no obligation — just honest, useful information from a local agent who knows your market.</p>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About Home Valuations</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>How is a home valuation different from an appraisal?</summary>
            <p>A home valuation or CMA is an informal estimate prepared by a real estate agent based on comparable sales data. It is free and used to help sellers price their home or understand their equity. An appraisal is a formal assessment conducted by a licensed appraiser, typically ordered by a lender during the mortgage process. Appraisals cost $450-$650 and carry legal weight in the transaction.</p>
          </details>
          <details class="faq-item">
            <summary>How accurate are online home value estimates?</summary>
            <p>Online estimates from sites like Zillow, Redfin, and Realtor.com can vary widely. They are generated by algorithms that analyze public data, but they cannot account for your home's specific condition, upgrades, or unique features. In the Hill Country, where properties vary significantly, these estimates can be off by 5-15% or more. A local CMA prepared by an agent who knows your area is far more reliable.</p>
          </details>
          <details class="faq-item">
            <summary>How long does it take to receive my home valuation?</summary>
            <p>I typically deliver a comprehensive home valuation report within 24 to 48 hours of receiving your request. The report includes comparable sales, market trends, and a recommended price range for your property. If you prefer a walkthrough of the home for a more detailed assessment, I can schedule that at your convenience.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- Why Get a Valuation -->
    <section class="valuation-why">
      <div class="valuation-why__container">
        <h2>Why Get a Home Valuation?</h2>
        <div class="valuation-why__grid">
          <div class="valuation-why__item">
            <div class="valuation-why__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
              </svg>
            </div>
            <h3>Know Your Equity</h3>
            <p>Understand how much equity you've built and how it fits into your financial picture.</p>
          </div>
          <div class="valuation-why__item">
            <div class="valuation-why__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M3 3v18h18"/>
                <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/>
              </svg>
            </div>
            <h3>Track Market Trends</h3>
            <p>See how your local market is performing and whether it's a good time to sell.</p>
          </div>
          <div class="valuation-why__item">
            <div class="valuation-why__icon">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                <circle cx="12" cy="7" r="4"/>
              </svg>
            </div>
            <h3>Personalized Report</h3>
            <p>Not an algorithm — a real, comprehensive market analysis prepared by a local REALTOR who knows your area.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="valuation-cta">
      <div class="valuation-cta__container">
        <h2>Prefer to Talk Directly?</h2>
        <p>Call or text me anytime — I'm happy to discuss your home's value and answer any questions about the current market.</p>
        <a href="tel:+18303605569" class="valuation-cta__btn">Call (830) 360-5569</a>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/home-nb-ranch.png" />
  <Footer />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How is a home valuation different from an appraisal?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "A home valuation or CMA is an informal estimate prepared by a real estate agent based on comparable sales. An appraisal is a formal assessment by a licensed appraiser, typically ordered by a lender during the mortgage process."
        }
      },
      {
        "@type": "Question",
        "name": "How accurate are online home value estimates?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Online estimates from Zillow, Redfin, and similar sites can be off by 5-15% or more in the Hill Country. A local CMA prepared by an agent who knows your area is far more reliable."
        }
      },
      {
        "@type": "Question",
        "name": "How long does it take to receive my home valuation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "I typically deliver a comprehensive home valuation report within 24 to 48 hours of receiving your request, including comparable sales, market trends, and a recommended price range."
        }
      }
    ]
  }
  </script>
</Layout>

<style>
  /* ── Hero ── */
  .valuation-hero {
    position: relative;
    height: 320px;
    background: url('/images/generated/home-valuation-hero.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }
  .valuation-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0,0,0,0.55), rgba(0,0,0,0.7));
  }
  .valuation-hero__content {
    position: relative;
    z-index: 1;
    color: #fff;
    max-width: 600px;
    padding: 0 20px;
  }
  .valuation-hero__content h1 {
    font-size: 36px;
    font-weight: 800;
    margin-bottom: 12px;
    line-height: 1.2;
  }
  .valuation-hero__content p {
    font-size: 16px;
    opacity: 0.9;
    line-height: 1.6;
  }
  .accent { color: #FF1616; }

  /* ── Form Section ── */
  .valuation-form-section {
    padding: 60px 20px;
    background: #f9f9f9;
  }
  .valuation-form__container {
    max-width: 600px;
    margin: 0 auto;
  }
  .valuation-form__card {
    background: #fff;
    border-radius: 12px;
    padding: 40px 32px;
    box-shadow: 0 4px 24px rgba(0,0,0,0.08);
  }
  .valuation-form__card h2 {
    font-size: 24px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #111;
    text-align: center;
  }
  .valuation-form__subtitle {
    font-size: 14px;
    color: #666;
    margin-bottom: 28px;
    line-height: 1.6;
    text-align: center;
  }

  .valuation-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .valuation-form__row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .valuation-form__field label {
    display: block;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #555;
    margin-bottom: 6px;
  }
  .req { color: #FF1616; }
  .valuation-form__field input {
    width: 100%;
    padding: 12px 14px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 15px;
    font-family: inherit;
    color: #111;
    transition: border-color 0.2s;
    background: #fff;
  }
  .valuation-form__field input::placeholder {
    color: #aaa;
  }
  .valuation-form__field input:focus {
    outline: none;
    border-color: #FF1616;
  }
  .valuation-form__field input.error {
    border-color: #FF1616;
  }

  .valuation-form__submit {
    width: 100%;
    padding: 14px;
    background: #111;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, transform 0.1s;
    margin-top: 4px;
  }
  .valuation-form__submit:hover {
    background: #333;
    transform: translateY(-1px);
  }

  .valuation-form__success {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 20px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 10px;
    margin-top: 8px;
  }
  .valuation-form__success svg {
    flex-shrink: 0;
    margin-top: 2px;
  }
  .valuation-form__success-title {
    font-size: 16px;
    font-weight: 700;
    color: #111;
    margin-bottom: 4px;
  }
  .valuation-form__success-text {
    font-size: 14px;
    color: #555;
    line-height: 1.5;
  }

  .valuation-form__error {
    padding: 16px 18px;
    background: #fef2f2;
    border: 1px solid #fecaca;
    border-left: 4px solid #FF1616;
    border-radius: 8px;
    margin-top: 12px;
  }
  .valuation-form__error-title {
    font-size: 14px;
    font-weight: 700;
    color: #991b1b;
    margin-bottom: 4px;
  }
  .valuation-form__error-text {
    font-size: 13px;
    color: #555;
    line-height: 1.5;
  }
  .valuation-form__error-text a {
    color: #FF1616;
    font-weight: 600;
    text-decoration: none;
  }
  .valuation-form__error-text a:hover {
    text-decoration: underline;
  }

  .valuation-form__disclaimer {
    font-size: 11px;
    color: #999;
    text-align: center;
    margin-top: 16px;
    line-height: 1.5;
  }

  /* ── Why Section ── */
  .valuation-why {
    padding: 72px 20px;
    background: #fff;
  }
  .valuation-why__container {
    max-width: 960px;
    margin: 0 auto;
    text-align: center;
  }
  .valuation-why__container h2 {
    font-size: 28px;
    font-weight: 700;
    margin-bottom: 40px;
    color: #111;
  }
  .valuation-why__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
    text-align: center;
  }
  .valuation-why__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #fef2f2;
    color: #FF1616;
    margin-bottom: 16px;
  }
  .valuation-why__item h3 {
    font-size: 17px;
    font-weight: 700;
    margin-bottom: 8px;
    color: #111;
  }
  .valuation-why__item p {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
  }

  /* ── CTA ── */
  .valuation-cta {
    padding: 60px 20px;
    background: #111;
    text-align: center;
  }
  .valuation-cta__container {
    max-width: 600px;
    margin: 0 auto;
  }
  .valuation-cta__container h2 {
    font-size: 26px;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }
  .valuation-cta__container p {
    font-size: 15px;
    color: #aaa;
    line-height: 1.6;
    margin-bottom: 28px;
  }
  .valuation-cta__btn {
    display: inline-block;
    padding: 14px 36px;
    background: #FF1616;
    color: #fff;
    font-size: 15px;
    font-weight: 600;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.2s, transform 0.1s;
  }
  .valuation-cta__btn:hover {
    background: #e01212;
    transform: translateY(-1px);
  }

  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .valuation-hero { height: 260px; }
    .valuation-hero__content h1 { font-size: 28px; }
    .valuation-why__grid { grid-template-columns: 1fr; gap: 24px; }
    .valuation-form__card { padding: 28px 20px; }
    .valuation-form__row { grid-template-columns: 1fr; }
  }
</style>

<script is:inline>
  const form = document.getElementById('valuationForm');
  const success = document.getElementById('valuationSuccess');
  const errorBox = document.getElementById('valuationError');

  form?.addEventListener('submit', function(e) {
    e.preventDefault();

    // Clear previous errors
    form.querySelectorAll('.error').forEach(function(el) { el.classList.remove('error'); });
    if (errorBox) errorBox.style.display = 'none';

    var name = form.querySelector('#vf-name');
    var address = form.querySelector('#vf-address');
    var email = form.querySelector('#vf-email');
    var phone = form.querySelector('#vf-phone');
    var valid = true;

    if (!name.value.trim()) { name.classList.add('error'); valid = false; }
    if (!address.value.trim()) { address.classList.add('error'); valid = false; }
    if (!email.value.trim() || !email.value.includes('@')) { email.classList.add('error'); valid = false; }
    if (!phone.value.trim()) { phone.classList.add('error'); valid = false; }

    if (valid) {
      var submitBtn = form.querySelector('.valuation-form__submit');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Submitting...';

      fetch('/api/lead', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          name: name.value.trim(),
          email: email.value.trim(),
          phone: phone.value.trim(),
          address: address.value.trim(),
          message: 'Home Valuation Request for: ' + address.value.trim(),
          source: 'Home Valuation Page'
        })
      })
      .then(function(res) {
        return res.json().then(function(data) { return { ok: res.ok, data: data }; });
      })
      .then(function(result) {
        if (result.ok && result.data && result.data.success) {
          form.style.display = 'none';
          success.style.display = 'flex';
        } else {
          throw new Error('lead-not-accepted');
        }
      })
      .catch(function() {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Get My Home Value';
        if (errorBox) errorBox.style.display = 'block';
      });
    }
  });
</script>
