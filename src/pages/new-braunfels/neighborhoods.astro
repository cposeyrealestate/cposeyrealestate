---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';
import ContactForm from '../../components/ContactForm.astro';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

const pageTitle = 'New Braunfels Neighborhoods | Cody Posey Real Estate';
const pageDescription = 'Explore New Braunfels, TX neighborhoods — from historic Gruene and downtown to the I-35 corridor, Hill Country retreats, and master-planned communities.';
const pageSchema = [
  articleSchema({ title: pageTitle, description: pageDescription, url: '/new-braunfels/neighborhoods' }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'New Braunfels', url: '/new-braunfels' },
    { name: 'Neighborhoods', url: '/new-braunfels/neighborhoods' },
  ]),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={pageSchema}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="nb-hero">
      <div class="nb-hero__overlay"></div>
      <div class="nb-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/new-braunfels/">New Braunfels</a> <span>/</span> <span>Neighborhoods</span>
        </nav>
        <h1>New Braunfels <span style="color:#FF1616;">Neighborhoods</span></h1>
        <p>Master-planned communities, historic districts, and Hill Country homesites</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="nb-page-intro nb-page-intro--centered">New Braunfels stretches from the historic Gruene district on the north side to the growing I-35 corridor in the east, with distinct neighborhoods that vary by lot size, price point, and lifestyle. Here's how the city breaks down by area.</p>
      </div>
    </section>

    <!-- West of I-35 -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>West of <span class="accent">I-35</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-river-chase.png" alt="River Chase neighborhood homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>River Chase</h3>
            <p>Private, peaceful Hill Country living with resort-style amenities including a clubhouse, fitness center, swimming pools, sports courts, butterfly garden, leisure pond, and walking trails. Custom-built homes sit on spacious lots, and the community features a private NBRC River Park with exclusive Guadalupe River access. Served by Comal ISD.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$550K - $1.5M</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-vintage-oaks.png" alt="Vintage Oaks neighborhood homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Vintage Oaks</h3>
            <p>A 3,900-acre luxury Hill Country community featuring spacious custom homes on generous lots ranging from 1 to 14+ acres. Resort-style amenities include a Tuscan-style clubhouse, multiple pools with an Olympic-sized pool and lazy river, fitness center, sports courts, and miles of nature trails. Known for panoramic Hill Country views throughout the community.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$500K - $2M+</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-copper-ridge.png" alt="Copper Ridge neighborhood homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Copper Ridge</h3>
            <p>A premier, gated and guarded community featuring expansive custom-built homes on 1-3 acre estate lots in a serene Hill Country setting with mature trees. Resort-style amenities include 24/7 gated entry, a community pool, clubhouse, and tennis courts. Served by Comal ISD.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$700K - $2M</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-manor-creek.png" alt="Manor Creek neighborhood homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Manor Creek</h3>
            <p>A gated community with a family-friendly atmosphere, featuring a community clubhouse, pool, and playground. Homes sit on generous ~1/3 acre lots with mature trees and offer various floor plans with a mix of stone, brick, and stucco exteriors in Hill Country traditional style.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$500K - $750K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-veramendi.png" alt="Veramendi neighborhood homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Veramendi</h3>
            <p>A 2,400-acre master-planned community blending Hill Country tranquility with modern convenience. Amenities include resort-style pools, splash pads, playgrounds, parks, sports courts, and miles of hiking and biking trails. Homes feature open-concept floor plans with stone and brick exteriors, primarily single-story options. Served by NBISD.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$350K - $800K</span>
              <span class="nb-neighborhood__tag">NBISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-mayfair.png" alt="Mayfair neighborhood homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Mayfair</h3>
            <p>A SouthStar Communities development spanning 300+ acres of parks with a 35-mile trail and bike lane network and a community lake. Amenities include Fairway Park, playscapes, a disc golf course, and a planned Midtown retail area. The community offers a modern small-town aesthetic.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$300K - $800K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gruene & Downtown -->
    <section class="section">
      <div class="container">
        <div class="section-title">
          <h2>Gruene & <span class="accent">Downtown</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-gruene.png" alt="Gruene Historic District homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Gruene & River Area</h3>
            <p>Historic charm meets a vibrant cultural scene, with walking distance to Gruene Hall, boutique shops, and restaurants. The area offers proximity to the Guadalupe River for tubing, kayaking, and fishing. Housing includes a diverse mix of renovated historic structures, cottages, and newer custom builds.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$400K - $2M+</span>
              <span class="nb-neighborhood__tag">NBISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-downtown.png" alt="Downtown New Braunfels homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Downtown & Central</h3>
            <p>Walkable neighborhoods near Main Plaza, local shops, and restaurants. Mix of historic homes and newer infill.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">Varies</span>
              <span class="nb-neighborhood__tag">NBISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- North New Braunfels -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>North <span class="accent">New Braunfels</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-legacy-lake-dunlap.png" alt="Legacy at Lake Dunlap homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Legacy at Lake Dunlap</h3>
            <p>Perry Homes, Toll Brothers, and Dreese Homes are building in this master-planned community with Lake Dunlap access and resort-style community amenities.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$350K - $550K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-creekside.png" alt="Creekside neighborhood homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Creekside</h3>
            <p>A rapidly growing community in north New Braunfels with a variety of housing options from builders like Centex Homes, Liberty Home Builders, KB Home, and Value Builders. Residents enjoy community pools, parks, and easy access to the Creekside Town Center for shopping, dining, and entertainment. Served by Comal ISD.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$280K - $500K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- East of I-35 -->
    <section class="section">
      <div class="container">
        <div class="section-title">
          <h2>East of I-35 <span class="accent">(Hwy 46 to FM 1044)</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-voss-farms.png" alt="Voss Farms homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Voss Farms</h3>
            <p>Large family-oriented community east of I-35. Multiple builders, parks, playgrounds, and community pool.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$280K - $400K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <img src="/images/generated/neighborhoods/nb-pecan-crossing.png" alt="Pecan Crossing homes" class="nb-neighborhood__img" loading="lazy" />
            <h3>Pecan Crossing</h3>
            <p>Affordable entry-level community east of I-35. Newer construction with easy highway access.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$270K - $500K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- School Districts -->
    <section class="section nb-schools">
      <div class="container">
        <div class="section-title">
          <h2>School <span class="accent">Districts</span></h2>
          <p>New Braunfels is served by two independent school districts. Which district a home falls in depends on its physical address.</p>
        </div>
        <div class="nb-schools__grid">
          <a href="https://www.nbisd.org" target="_blank" rel="noopener" class="nb-schools__card">
            <h3>New Braunfels ISD</h3>
            <p>Serves the central, downtown, and Gruene areas. A long-established district with strong community roots.</p>
            <span class="nb-schools__link">Visit NBISD Website &rarr;</span>
          </a>
          <a href="https://www.comalisd.org" target="_blank" rel="noopener" class="nb-schools__card">
            <h3>Comal ISD</h3>
            <p>One of the fastest-growing districts in Texas. Serves the west, north, and south sides of the New Braunfels area.</p>
            <span class="nb-schools__link">Visit Comal ISD Website &rarr;</span>
          </a>
        </div>
        <p class="nb-schools__note">Always verify school assignments directly with the district. Boundaries can change as new schools are built.</p>
      </div>
    </section>

    <!-- Parallax CTA -->
    <section class="nb-parallax-cta">
      <div class="nb-parallax-cta__overlay"></div>
      <div class="nb-parallax-cta__content">
        <h2>Need Help <span class="accent">Narrowing It Down</span>?</h2>
        <p>I can walk you through the differences between areas and help you focus your search on neighborhoods that match your priorities.</p>
        <a href="#contact" class="btn btn-outline">Get Help Choosing a Neighborhood</a>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/guadalupe-river.png" />

  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions About New Braunfels Neighborhoods</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What are the best neighborhoods in New Braunfels for families?</summary>
          <p>Veramendi and Voss Farms are two of the most popular choices for families in New Braunfels. Veramendi is a 2,400-acre master-planned community with resort-style pools, splash pads, playgrounds, parks, and miles of hiking and biking trails — all served by NBISD. Voss Farms east of I-35 offers a family-oriented atmosphere with parks, playgrounds, and a community pool at a more accessible price point within Comal ISD. For families with a larger budget, River Chase and Vintage Oaks provide Hill Country acreage with premium amenities including private river access and extensive trail systems.</p>
        </details>
        <details class="faq-item">
          <summary>What is the difference between Comal ISD and New Braunfels ISD?</summary>
          <p>New Braunfels is served by two independent school districts, and the one your home falls in depends entirely on its physical address. New Braunfels ISD covers the central, downtown, and Gruene areas and is a long-established district with deep community roots. Comal ISD serves the west, north, and south sides of the New Braunfels area and is one of the fastest-growing districts in Texas with modern facilities and strong academic programs. Both districts are well-regarded, so the choice often comes down to which neighborhoods and price points appeal to you. Always verify school zone assignments directly with the district before buying, as boundaries can shift when new campuses are built.</p>
        </details>
        <details class="faq-item">
          <summary>Where can I find affordable homes in New Braunfels?</summary>
          <p>The most affordable neighborhoods in New Braunfels are generally located east of I-35 along the Highway 46 and FM 1044 corridors. Voss Farms and Pecan Crossing both offer newer construction starting in the mid to high $200Ks, which is significantly less than west-side communities like Vintage Oaks or Copper Ridge. Creekside in north New Braunfels also provides competitive pricing starting around $280K with easy access to the Creekside Town Center for shopping and dining. These east-side and north-side neighborhoods provide solid value for first-time buyers and families looking to enter the New Braunfels market without paying Hill Country premium prices.</p>
        </details>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the best neighborhoods in New Braunfels for families?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Veramendi and Voss Farms are two of the most popular choices for families in New Braunfels. Veramendi is a 2,400-acre master-planned community with resort-style pools, splash pads, playgrounds, parks, and miles of hiking and biking trails. Voss Farms east of I-35 offers a family-oriented atmosphere with parks, playgrounds, and a community pool at a more accessible price point. For families with a larger budget, River Chase and Vintage Oaks provide Hill Country acreage with premium amenities."
        }
      },
      {
        "@type": "Question",
        "name": "What is the difference between Comal ISD and New Braunfels ISD?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "New Braunfels is served by two independent school districts, and the one your home falls in depends entirely on its physical address. New Braunfels ISD covers the central, downtown, and Gruene areas. Comal ISD serves the west, north, and south sides and is one of the fastest-growing districts in Texas. Both districts are well-regarded. Always verify school zone assignments directly with the district before buying."
        }
      },
      {
        "@type": "Question",
        "name": "Where can I find affordable homes in New Braunfels?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The most affordable neighborhoods in New Braunfels are generally located east of I-35 along the Highway 46 and FM 1044 corridors. Voss Farms and Pecan Crossing both offer newer construction starting in the mid to high $200Ks. Creekside in north New Braunfels also provides competitive pricing starting around $280K with easy access to shopping and dining."
        }
      }
    ]
  }
  </script>

  <ContactForm context="I'd like to learn more about New Braunfels neighborhoods..." />
  <Footer />
</Layout>

<style>
  /* Hero */
  .nb-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/home-nb-ranch.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .nb-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .nb-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .nb-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .nb-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #FF1616;
  }

  .breadcrumb span {
    margin: 0 0.3rem;
  }

  /* Page Intro */
  .nb-page-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
  }

  .nb-page-intro--centered {
    text-align: center;
    font-weight: 700;
    color: var(--black);
    margin: 0 auto;
  }

  /* Neighborhood Cards */
  .nb-neighborhood__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .nb-neighborhood__card {
    background: #fff;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .nb-neighborhood__img {
    width: 100%;
    height: 200px;
    object-fit: cover;
  }

  .nb-neighborhood__card h3,
  .nb-neighborhood__card p,
  .nb-neighborhood__tags {
    padding-left: 2rem;
    padding-right: 2rem;
  }

  .nb-neighborhood__tags {
    padding-bottom: 2rem;
  }

  .nb-neighborhood__card h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    padding-top: 1.5rem;
  }

  .nb-neighborhood__card p {
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 1rem;
    flex: 1;
  }

  .nb-neighborhood__tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .nb-neighborhood__tag {
    display: inline-block;
    background: var(--light-gray);
    color: var(--gray);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* School Districts */
  .nb-schools {
    background: var(--light-gray);
  }

  .nb-schools__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .nb-schools__card {
    background: #fff;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .nb-schools__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .nb-schools__card h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .nb-schools__card p {
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 1rem;
    flex: 1;
  }

  .nb-schools__link {
    color: #FF1616;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .nb-schools__note {
    text-align: center;
    font-style: italic;
    color: var(--gray);
    font-size: 0.85rem;
  }

  /* Parallax CTA */
  .nb-parallax-cta {
    position: relative;
    background: url('/images/testimonials-hero.jpg') center / cover no-repeat fixed;
    padding: 5rem 1.5rem;
    text-align: center;
    color: #fff;
  }

  .nb-parallax-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.7);
  }

  .nb-parallax-cta__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .nb-parallax-cta__content h2 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .nb-parallax-cta__content p {
    color: rgba(255,255,255,0.7);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  /* FAQ */
  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }

  @media (max-width: 768px) {
    .nb-neighborhood__grid {
      grid-template-columns: 1fr;
    }

    .nb-schools__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
