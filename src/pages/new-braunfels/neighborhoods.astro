---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="New Braunfels Neighborhoods | Cody Posey Real Estate"
  description="Explore New Braunfels neighborhoods by area and buyer type. From Gruene to the I-35 corridor — find the right fit for your lifestyle and budget."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="nb-hero">
      <div class="nb-hero__overlay"></div>
      <div class="nb-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/new-braunfels/">New Braunfels</a> <span>/</span> <span>Neighborhoods</span>
        </nav>
        <h1>New Braunfels <span style="color:#FF1616;">Neighborhoods</span></h1>
        <p>Master-planned communities, historic districts, and Hill Country homesites</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="nb-page-intro nb-page-intro--centered">New Braunfels stretches from the historic Gruene district on the north side to the growing I-35 corridor in the east, with distinct neighborhoods that vary by lot size, price point, and lifestyle. Here's how the city breaks down by area.</p>
      </div>
    </section>

    <!-- West of I-35 -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>West of <span class="accent">I-35</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <h3>River Chase</h3>
            <p>Master-planned community with pool, splash pad, and trails. Popular with families seeking newer construction and community amenities.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$350K - $550K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <h3>Vintage Oaks</h3>
            <p>3,900-acre luxury build-on-your-lot community in the Hill Country. Large homesites, resort-style amenities, and panoramic views.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$500K - $2M+</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <h3>Copper Ridge</h3>
            <p>Established neighborhood with mature trees, walking trails, and a strong sense of community. Popular move-up option.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$300K - $450K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <h3>Manor Creek</h3>
            <p>Hill Country lots with custom homes and scenic views. Smaller community with a private, secluded feel.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$400K - $600K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <h3>Veramendi</h3>
            <p>2,400-acre master-planned community with parks, trails, and mixed-use development. One of NB's largest new communities.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$290K - $600K</span>
              <span class="nb-neighborhood__tag">NBISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <h3>Mayfair</h3>
            <p>SouthStar Communities development with newer homes starting in the high $200Ks. Entry-level to move-up pricing.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$290K - $400K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gruene & Downtown -->
    <section class="section">
      <div class="container">
        <div class="section-title">
          <h2>Gruene & <span class="accent">Downtown</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <h3>Gruene & River Area</h3>
            <p>Historic area near Gruene Hall and the Guadalupe River. Older homes with character, river access, and walkability to shops and restaurants.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$400K - $1M+</span>
              <span class="nb-neighborhood__tag">NBISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <h3>Downtown & Central</h3>
            <p>Walkable neighborhoods near Main Plaza, local shops, and restaurants. Mix of historic homes and newer infill.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$250K - $500K</span>
              <span class="nb-neighborhood__tag">NBISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- North New Braunfels -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>North <span class="accent">New Braunfels</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <h3>Legacy at Lake Dunlap</h3>
            <p>Toll Brothers, Pulte, and other national builders. Lake Dunlap access, community amenities, from the high $300Ks.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$350K - $550K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- East of I-35 -->
    <section class="section">
      <div class="container">
        <div class="section-title">
          <h2>East of I-35 <span class="accent">(Hwy 46 to FM 1044)</span></h2>
        </div>

        <div class="nb-neighborhood__grid">
          <div class="nb-neighborhood__card">
            <h3>Voss Farms</h3>
            <p>Large family-oriented community east of I-35. Multiple builders, parks, playgrounds, and community pool.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$280K - $400K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>

          <div class="nb-neighborhood__card">
            <h3>Pecan Crossing</h3>
            <p>Affordable entry-level community east of I-35. Newer construction with easy highway access.</p>
            <div class="nb-neighborhood__tags">
              <span class="nb-neighborhood__tag">$270K - $380K</span>
              <span class="nb-neighborhood__tag">Comal ISD</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- School Districts -->
    <section class="section nb-schools">
      <div class="container">
        <div class="section-title">
          <h2>School <span class="accent">Districts</span></h2>
          <p>New Braunfels is served by two independent school districts. Which district a home falls in depends on its physical address.</p>
        </div>
        <div class="nb-schools__grid">
          <a href="https://www.nbisd.org" target="_blank" rel="noopener" class="nb-schools__card">
            <h3>New Braunfels ISD</h3>
            <p>Serves the central, downtown, and Gruene areas. A long-established district with strong community roots.</p>
            <span class="nb-schools__link">Visit NBISD Website &rarr;</span>
          </a>
          <a href="https://www.comalisd.org" target="_blank" rel="noopener" class="nb-schools__card">
            <h3>Comal ISD</h3>
            <p>One of the fastest-growing districts in Texas. Serves the west, north, and south sides of the New Braunfels area.</p>
            <span class="nb-schools__link">Visit Comal ISD Website &rarr;</span>
          </a>
        </div>
        <p class="nb-schools__note">Always verify school assignments directly with the district. Boundaries can change as new schools are built.</p>
      </div>
    </section>

    <!-- Parallax CTA -->
    <section class="nb-parallax-cta">
      <div class="nb-parallax-cta__overlay"></div>
      <div class="nb-parallax-cta__content">
        <h2>Need Help <span class="accent">Narrowing It Down</span>?</h2>
        <p>I can walk you through the differences between areas and help you focus your search on neighborhoods that match your priorities.</p>
        <a href="#contact" class="btn btn-outline">Get Help Choosing a Neighborhood</a>
      </div>
    </section>

  </main>
  <ContactForm context="I'd like to learn more about New Braunfels neighborhoods..." />
  <Footer />
</Layout>

<style>
  /* Hero */
  .nb-hero {
    position: relative;
    height: 280px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .nb-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #000 0%, #1a0000 100%);
    opacity: 0.9;
  }

  .nb-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .nb-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .nb-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  /* Breadcrumb */
  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #FF1616;
  }

  .breadcrumb span {
    margin: 0 0.3rem;
  }

  /* Page Intro */
  .nb-page-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
  }

  .nb-page-intro--centered {
    text-align: center;
    font-weight: 700;
    color: var(--black);
    margin: 0 auto;
  }

  /* Neighborhood Cards */
  .nb-neighborhood__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .nb-neighborhood__card {
    background: #fff;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    display: flex;
    flex-direction: column;
  }

  .nb-neighborhood__card h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .nb-neighborhood__card p {
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 1rem;
    flex: 1;
  }

  .nb-neighborhood__tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .nb-neighborhood__tag {
    display: inline-block;
    background: var(--light-gray);
    color: var(--gray);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* School Districts */
  .nb-schools {
    background: var(--light-gray);
  }

  .nb-schools__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .nb-schools__card {
    background: #fff;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .nb-schools__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .nb-schools__card h3 {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .nb-schools__card p {
    color: var(--gray);
    line-height: 1.7;
    margin-bottom: 1rem;
    flex: 1;
  }

  .nb-schools__link {
    color: #FF1616;
    font-weight: 600;
    font-size: 0.9rem;
  }

  .nb-schools__note {
    text-align: center;
    font-style: italic;
    color: var(--gray);
    font-size: 0.85rem;
  }

  /* Parallax CTA */
  .nb-parallax-cta {
    position: relative;
    background: url('/images/testimonials-hero.jpg') center / cover no-repeat fixed;
    padding: 5rem 1.5rem;
    text-align: center;
    color: #fff;
  }

  .nb-parallax-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.7);
  }

  .nb-parallax-cta__content {
    position: relative;
    z-index: 1;
    max-width: 700px;
    margin: 0 auto;
  }

  .nb-parallax-cta__content h2 {
    font-size: clamp(1.5rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .nb-parallax-cta__content p {
    color: rgba(255,255,255,0.7);
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .nb-neighborhood__grid {
      grid-template-columns: 1fr;
    }

    .nb-schools__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
