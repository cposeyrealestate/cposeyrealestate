---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

const pageTitle = 'Best Restaurants in New Braunfels, TX | Cody Posey';
const pageDescription = "A local's guide to the best restaurants in New Braunfels, TX — BBQ, Tex-Mex, German fare, craft breweries, fine dining, and family-friendly favorites.";
const pageSchema = [
  articleSchema({ title: pageTitle, description: pageDescription, url: '/new-braunfels/restaurants' }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'New Braunfels', url: '/new-braunfels' },
    { name: 'Restaurants', url: '/new-braunfels/restaurants' },
  ]),
];

const restaurants = [
  { name: "Cooper's Old Time Pit Bar-B-Que", cuisine: 'BBQ', description: "Classic Texas BBQ joint famous for its giant Big Chop pork chop and pit-smoked brisket, sausage, and ribs in a casual counter-service setting.", price: '$$', tags: ['bbq', 'casual'], address: '1125 TX-337 Loop, New Braunfels, TX 78130' },
  { name: "Black's Barbecue", cuisine: 'BBQ', description: "Outpost of the legendary Lockhart family spot, known for rich, smoky brisket, sausage, and classic sides. Real Texas barbecue.", price: '$$', tags: ['bbq', 'iconic'], address: '936 TX-337 Loop, New Braunfels, TX 78130' },
  { name: "Granzin Bar-B-Q", cuisine: 'BBQ', description: "Local favorite meat-market style BBQ known for tender pulled pork sandwiches, sausage, and no-frills plates at approachable prices.", price: '$', tags: ['bbq', 'local-favorite'], address: '660 W San Antonio St, New Braunfels, TX 78130' },
  { name: 'Adobe Cafe', cuisine: 'Tex-Mex', description: "Colorful neighborhood restaurant known for classic Tex-Mex combo plates, enchiladas, and margaritas. Great for groups and after-river dinners.", price: '$$', tags: ['tex-mex', 'groups'], address: '124 S Business IH 35, New Braunfels, TX 78130' },
  { name: 'Las Fontanas', cuisine: 'Tex-Mex', description: "An extensive menu mixing authentic Mexican flavors with South Texas flair — fajitas, fresh fish, quail, ribs, and Mexican street fare in a vibrant setting.", price: '$$', tags: ['tex-mex', 'family'], address: '1551 N Walnut Ave, Suite 10, New Braunfels, TX 78130' },
  { name: 'La Cosecha Mexican Table', cuisine: 'Mexican', description: "Interior Mexican cuisine blending traditional flavors with a modern touch. A refined take on Mexican dining that sets it apart from standard Tex-Mex.", price: '$$', tags: ['mexican', 'modern'], address: '505 N Business IH 35, New Braunfels, TX 78130' },
  { name: 'Alpine Haus Restaurant', cuisine: 'German', description: "Upscale, intimate German restaurant in a 160-year-old downtown house. Known for schnitzel, bratwurst, sauerbraten, and a strong German beer and wine list.", price: '$$$', tags: ['german', 'date-night'], address: '251 S Seguin Ave, New Braunfels, TX 78130' },
  { name: "Krause's Cafe", cuisine: 'German / Brewery', description: "Large beer-garden restaurant known for its huge German and local beer tap wall, jaeger schnitzel, bratwurst platters, and live music. Family-friendly with a big outdoor space.", price: '$$', tags: ['german', 'brewery', 'live-music', 'family'], address: '148 S Castell Ave, New Braunfels, TX 78130' },
  { name: 'New Braunfels Brewing Company', cuisine: 'Brewery', description: "Small brewery known for sour wheat beers and experimental brews, with a cozy taproom and beer garden popular with craft-beer enthusiasts.", price: '$$', tags: ['brewery', 'craft-beer'], address: '180 W Mill St, New Braunfels, TX 78130' },
  { name: 'Huisache Grill', cuisine: 'Fine Dining', description: "Intimate bistro-style restaurant known for contemporary American and Southwestern-leaning dishes, a solid wine list, and a cozy courtyard. One of NB's top date night spots.", price: '$$$', tags: ['fine-dining', 'date-night'], address: '303 W San Antonio St, New Braunfels, TX 78130' },
  { name: "McAdoo's Seafood Company", cuisine: 'Fine Dining', description: "Upscale seafood and Southern-influenced restaurant in a historic post office building. Gulf-focused seafood plates, craft cocktails, and a polished but lively atmosphere.", price: '$$$', tags: ['fine-dining', 'seafood'], address: '196 N Castell Ave, New Braunfels, TX 78130' },
  { name: "Myron's Prime Steakhouse", cuisine: 'Fine Dining', description: "Classic steakhouse known for prime steaks, big sides, and white-tablecloth service. One of NB's go-to special-occasion restaurants.", price: '$$$$', tags: ['fine-dining', 'steakhouse'], address: '136 N Castell Ave, New Braunfels, TX 78130' },
  { name: 'Gristmill River Restaurant & Bar', cuisine: 'American', description: "Iconic multi-level riverside spot next to Gruene Hall. Known for chicken-fried steak, burgers, and salads with spectacular river views and plenty of seating.", price: '$$', tags: ['american', 'river-views', 'iconic'], address: '1287 Gruene Rd, New Braunfels, TX 78130' },
  { name: 'Gruene River Grill', cuisine: 'American', description: "River-view restaurant near Gruene Hall serving American and Tex-Mex comfort dishes, burgers, and salads in a casual, family-friendly setting.", price: '$$', tags: ['american', 'family', 'river-views'], address: '1259 Gruene Rd, New Braunfels, TX 78130' },
];

const categories = [...new Set(restaurants.map(r => r.cuisine))];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={pageSchema}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="rest-hero">
      <div class="rest-hero__overlay"></div>
      <div class="rest-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/new-braunfels/">New Braunfels</a> <span>/</span> <span>Restaurants</span>
        </nav>
        <h1>New Braunfels <span style="color:#FF1616;">Restaurants</span></h1>
        <p>A local's guide to the best places to eat in town</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="rest-intro">New Braunfels has a food scene that punches well above its weight. From legendary Texas BBQ and authentic Tex-Mex to German beer halls that honor the city's heritage and upscale dining you'd expect in a much bigger city — there's something for every taste and occasion. Here are the spots the locals actually eat at.</p>
      </div>
    </section>

    <!-- Filter Tabs -->
    <section class="section" style="background: var(--light-gray); padding-top: 2rem; padding-bottom: 0;">
      <div class="container">
        <div class="rest-filters" id="restFilters">
          <button class="rest-filter rest-filter--active" data-filter="all">All</button>
          {categories.map(cat => (
            <button class="rest-filter" data-filter={cat}>{cat}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- Restaurant List -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="rest-grid" id="restGrid">
          {restaurants.map(r => (
            <div class="rest-card" data-cuisine={r.cuisine}>
              <div class="rest-card__header">
                <h3>{r.name}</h3>
                <span class="rest-card__cuisine">{r.cuisine}</span>
              </div>
              <p class="rest-card__desc">{r.description}</p>
              <a href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(r.name + ', ' + r.address)}`} target="_blank" rel="noopener" class="rest-card__address">{r.address}</a>
              <div class="rest-card__footer">
                <span class="rest-card__price">{r.price}</span>
                <div class="rest-card__tags">
                  {r.tags.map(tag => (
                    <span class="rest-card__tag">{tag.replace(/-/g, ' ')}</span>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="rest-cta">
      <div class="rest-cta__overlay"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <h2>Looking for a Home Near Your <span class="accent">Favorite Spots</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">I can help you find homes in the neighborhoods closest to the restaurants, shops, and nightlife you love.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="https://cposeyrealestate.idxbroker.com/idx/search/advanced" class="btn btn-primary">Search Homes</a>
          <a href="#contact" class="btn btn-outline">Let's Connect</a>
        </div>
      </div>
    </section>

  </main>
  <!-- FAQ Section -->
  <section class="faq-section">
    <div class="container">
      <h2>Frequently Asked Questions About Dining in New Braunfels</h2>
      <div class="faq-list">
        <details class="faq-item">
          <summary>What are the best restaurants in New Braunfels, TX?</summary>
          <p>New Braunfels has an outstanding dining scene with top picks across several categories. For BBQ, Cooper's Old Time Pit Bar-B-Que and Black's Barbecue are legendary. Huisache Grill and McAdoo's Seafood Company lead the fine dining options. Krause's Cafe is the go-to for German food and craft beer, and Gristmill River Restaurant is an iconic riverside spot near Gruene Hall. The city offers something for every taste and budget.</p>
        </details>
        <details class="faq-item">
          <summary>Where should families eat in New Braunfels?</summary>
          <p>New Braunfels has plenty of family-friendly restaurants. Krause's Cafe features a large outdoor beer garden with space for kids, and Gristmill River Restaurant offers multi-level riverside seating with a casual atmosphere. Gruene River Grill is another great family option near Gruene Historic District. For a quick and affordable meal, Granzin Bar-B-Q serves excellent pulled pork sandwiches and BBQ plates at approachable prices. Adobe Cafe and Las Fontanas are both solid Tex-Mex picks for groups.</p>
        </details>
        <details class="faq-item">
          <summary>Does New Braunfels have German restaurants?</summary>
          <p>Yes, New Braunfels has a strong German dining tradition that reflects the city's heritage as a German settlement founded in 1845. Alpine Haus Restaurant is an upscale German restaurant in a 160-year-old downtown building serving schnitzel, bratwurst, and sauerbraten. Krause's Cafe is a larger, more casual option with a massive beer-tap wall, German platters, and a family-friendly beer garden with live music. New Braunfels Brewing Company also contributes to the German-inspired craft beer culture in town.</p>
        </details>
      </div>
    </div>
  </section>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the best restaurants in New Braunfels, TX?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "New Braunfels has an outstanding dining scene with top picks across several categories. For BBQ, Cooper's Old Time Pit Bar-B-Que and Black's Barbecue are legendary. Huisache Grill and McAdoo's Seafood Company lead the fine dining options. Krause's Cafe is the go-to for German food and craft beer, and Gristmill River Restaurant is an iconic riverside spot near Gruene Hall. The city offers something for every taste and budget."
        }
      },
      {
        "@type": "Question",
        "name": "Where should families eat in New Braunfels?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "New Braunfels has plenty of family-friendly restaurants. Krause's Cafe features a large outdoor beer garden with space for kids, and Gristmill River Restaurant offers multi-level riverside seating with a casual atmosphere. Gruene River Grill is another great family option near Gruene Historic District. For a quick and affordable meal, Granzin Bar-B-Q serves excellent pulled pork sandwiches and BBQ plates at approachable prices. Adobe Cafe and Las Fontanas are both solid Tex-Mex picks for groups."
        }
      },
      {
        "@type": "Question",
        "name": "Does New Braunfels have German restaurants?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, New Braunfels has a strong German dining tradition that reflects the city's heritage as a German settlement founded in 1845. Alpine Haus Restaurant is an upscale German restaurant in a 160-year-old downtown building serving schnitzel, bratwurst, and sauerbraten. Krause's Cafe is a larger, more casual option with a massive beer-tap wall, German platters, and a family-friendly beer garden with live music. New Braunfels Brewing Company also contributes to the German-inspired craft beer culture in town."
        }
      }
    ]
  }
  </script>

  <ParallaxBanner image="/images/generated/guadalupe-river.png" />

  <ContactForm context="I'd like to find homes near the best restaurants in NB..." />
  <Footer />
</Layout>

<style>
  .rest-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/comal-river.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .rest-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .rest-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .rest-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 0.75rem;
  }

  .rest-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: #FF1616; }
  .breadcrumb span { margin: 0 0.3rem; }

  .rest-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
    text-align: center;
    margin: 0 auto;
    font-weight: 600;
  }

  /* Filters */
  .rest-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    padding-bottom: 2rem;
  }

  .rest-filter {
    padding: 0.5rem 1.25rem;
    border: 2px solid #ddd;
    border-radius: 25px;
    background: #fff;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.2s;
    color: #333;
  }

  .rest-filter:hover {
    border-color: #FF1616;
    color: #FF1616;
  }

  .rest-filter--active {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }

  .rest-filter--active:hover {
    color: #fff;
  }

  /* Cards */
  .rest-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .rest-card {
    background: #fff;
    padding: 2rem;
    border-radius: 8px;
    border-left: 3px solid #FF1616;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .rest-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .rest-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .rest-card__header h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .rest-card__cuisine {
    flex-shrink: 0;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #FF1616;
    background: rgba(255, 22, 22, 0.08);
    padding: 0.25rem 0.6rem;
    border-radius: 4px;
  }

  .rest-card__desc {
    color: var(--gray);
    font-size: 0.88rem;
    line-height: 1.7;
    margin-bottom: 1rem;
  }

  .rest-card__address {
    display: block;
    font-size: 0.82rem;
    color: #FF1616;
    margin-bottom: 1rem;
    transition: opacity 0.2s;
  }

  .rest-card__address:hover {
    opacity: 0.7;
  }

  .rest-card__footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid #f0f0f0;
    padding-top: 0.75rem;
  }

  .rest-card__price {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.9rem;
    color: #FF1616;
  }

  .rest-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .rest-card__tag {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--gray);
    background: #f5f5f5;
    padding: 0.2rem 0.5rem;
    border-radius: 3px;
  }

  /* CTA */
  .rest-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .rest-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
  }

  .rest-cta h2 { color: #fff; }

  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }

  @media (max-width: 768px) {
    .rest-grid { grid-template-columns: 1fr; }
    .rest-cta { background-attachment: scroll; }
  }
</style>

<script is:inline>
  // Filter functionality
  const filters = document.querySelectorAll('.rest-filter');
  const cards = document.querySelectorAll('.rest-card');

  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      filters.forEach(f => f.classList.remove('rest-filter--active'));
      btn.classList.add('rest-filter--active');

      cards.forEach(card => {
        if (filter === 'all' || card.dataset.cuisine === filter) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
