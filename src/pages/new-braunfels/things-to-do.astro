---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';

const activities = [
  { name: 'Comal River Tubing', category: 'outdoor', description: "Float the crystal-clear, spring-fed Comal River — the shortest river in Texas. A relaxing 2-hour journey with access points throughout the city, perfect for a lazy afternoon.", url: 'https://texastubes.com/' },
  { name: 'Guadalupe River Adventures', category: 'outdoor', description: "Kayaking, tubing, and paddleboarding on the Guadalupe River. Full-day trips through beautiful Hill Country scenery with outfitters ready to get you on the water.", url: 'https://rockinr.com/' },
  { name: 'Schlitterbahn Waterpark', category: 'family', description: "One of the best waterparks in the country, powered by natural spring water from the Comal River. Multiple water coasters, lazy rivers, and slides for all ages.", url: 'https://www.schlitterbahn.com/new-braunfels/' },
  { name: 'Gruene Hall', category: 'nightlife', description: "Texas' oldest continually operating dance hall, built in 1878. Live music every night — from up-and-coming Texas artists to national acts. A 6,000 sq ft dance floor with the original tin roof.", url: 'https://gruenehall.com/' },
  { name: 'Gruene Historic District', category: 'culture', description: "Shop, dine, and explore charming storefronts in this preserved 1800s German settlement. Wine tasting rooms, antique shops, and the famous Gristmill restaurant overlooking the river.", url: 'https://www.gruenetexas.com/' },
  { name: 'Natural Bridge Caverns', category: 'family', description: "The largest commercial caverns in Texas, 180 feet underground. Discovery Tour reveals massive formations, plus zip lines, a maze, and gem mining above ground.", url: 'https://naturalbridgecaverns.com/' },
  { name: 'Natural Bridge Wildlife Ranch', category: 'family', description: "A 500-acre drive-through safari park with over 500 animals. Feed giraffes from your car, see zebras, and explore walkabout exhibits with cheetahs and gibbons.", url: 'https://wildliferanchtexas.com/' },
  { name: 'Landa Park', category: 'outdoor', description: "A 51-acre city park along the Comal River with a spring-fed swimming pool, miniature train, paddle boats, disc golf, and walking trails. Free admission — a local favorite.", url: 'https://www.newbraunfels.gov/270/Landa-Park' },
  { name: 'The Cliff Carver Alpine Coaster', category: 'family', description: "Texas' first alpine coaster — a gravity-propelled sled that zooms through the Hill Country hillside at up to 25 mph. Fun for kids and adults alike.", url: 'https://cliffcarver.com/' },
  { name: 'Wurstfest', category: 'seasonal', description: "The annual 10-day salute to sausage drawing 240,000+ visitors every November. German food, 40+ bands on 5 stages, carnival rides, and beer. A New Braunfels tradition.", url: 'https://wurstfest.com/' },
  { name: 'Gruene Music & Wine Festival', category: 'seasonal', description: "A four-day celebration featuring 50+ Texas wineries and breweries with live music in the Gruene Historic District. Held annually in the fall.", url: 'https://www.gruenemusicandwinefest.org/' },
];

const categoryLabels = {
  outdoor: 'Outdoor & Nature',
  family: 'Family Fun',
  nightlife: 'Nightlife & Music',
  culture: 'Culture & History',
  seasonal: 'Seasonal Events',
};

const categories = [...new Set(activities.map(a => a.category))];
---

<Layout
  title="Things to Do in New Braunfels, TX | Cody Posey Real Estate"
  description="Discover the best things to do in New Braunfels — river tubing, Gruene Hall, Schlitterbahn, seasonal festivals, and everything that makes this city special."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="act-hero">
      <div class="act-hero__overlay"></div>
      <div class="act-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/new-braunfels/">New Braunfels</a> <span>/</span> <span>Things to Do</span>
        </nav>
        <h1>Things to Do in <span style="color:#FF1616;">New Braunfels</span></h1>
        <p>River adventures, live music, family fun, and Hill Country culture</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="act-intro">New Braunfels isn't just a great place to live — it's a destination. From floating the spring-fed rivers and dancing at the oldest dance hall in Texas to world-class waterparks and underground caverns, there's always something to do. And with events like Wurstfest drawing hundreds of thousands of visitors every year, the community knows how to have a good time.</p>
        <div class="nb-expanded-content">
          <p>Founded in 1845 by German immigrants led by Prince Carl of Solms-Braunfels, New Braunfels has grown from a small Hill Country settlement into one of the fastest-growing cities in the United States. Despite that growth, the city has managed to preserve the character, traditions, and natural beauty that drew people here in the first place. The Comal and Guadalupe rivers remain the lifeblood of the community, and the German heritage is still visible in everything from the architecture downtown to the annual festivals that define the local calendar.</p>
          <p>The Comal River is the shortest navigable river in Texas, and floating its crystal-clear, spring-fed waters is the quintessential New Braunfels experience. The river stays a cool 72 degrees year-round, fed by the Comal Springs at the headwaters in Landa Park. Tubing the Comal takes about two to three hours and passes through shaded stretches, gentle rapids, and the popular tube chute near downtown. Outfitters along the river offer tube rentals, shuttle services, and locker facilities, making it easy for both visitors and residents to enjoy a day on the water without any hassle.</p>
          <p>The Guadalupe River provides a longer, more adventurous alternative. Stretching through the Hill Country north of town, the Guadalupe offers full-day tubing and kayaking trips through scenic canyon terrain. The river is wider and more varied than the Comal, with deeper pools, faster currents, and plenty of spots to pull over for a swim or a picnic on a gravel bar. Outfitters like Rockin' R River Rides coordinate multi-hour trips with transportation and equipment, and the experience is a highlight of summer for thousands of visitors and locals each year.</p>
          <h3>Attractions and Family Fun</h3>
          <p>Schlitterbahn Waterpark is one of the most celebrated water parks in the country, and it sits right in the heart of New Braunfels. Powered by natural spring water from the Comal River, the park features water coasters, tube slides, lazy rivers, wave pools, and attractions for every age group. The original section of the park preserves a shaded, tree-covered layout that feels more like a river park than a commercial waterpark, which is a major part of its charm. Schlitterbahn is open seasonally from spring through early fall and employs thousands of local residents each year.</p>
          <p>Natural Bridge Caverns, located just north of town, offers a completely different kind of adventure. Guided tours descend 180 feet underground through massive chambers filled with stalactites, stalagmites, and other geological formations that took millions of years to form. Above ground, the adventure village features zip lines, a ropes course, gem mining, and a maze. Combined with the nearby Natural Bridge Wildlife Ranch, a drive-through safari with over 500 animals, this area provides a full day of family entertainment.</p>
          <p>Landa Park is the community's beloved 51-acre green space along the Comal River. The park offers a spring-fed swimming pool, miniature train rides, paddle boats, a disc golf course, playgrounds, and miles of walking trails. Admission is free, and it serves as the gathering place for families, joggers, dog walkers, and anyone looking to enjoy the outdoors in the middle of town. The park's location at the headwaters of the Comal River makes it one of the most scenic city parks in Texas.</p>
          <h3>History, Culture, and Downtown</h3>
          <p>The Gruene Historic District is a preserved 1800s German settlement that has become one of the most visited small-town destinations in Texas. Gruene Hall, built in 1878, is the oldest continually operating dance hall in Texas and hosts live music every night of the week. The 6,000-square-foot dance floor beneath the original tin roof has hosted legends from George Strait to Willie Nelson, and it remains the cultural anchor of the district. Surrounding Gruene Hall, the district features wine tasting rooms, antique shops, boutiques, and the Gristmill River Restaurant, which overlooks the Guadalupe River from a converted 1878 cotton gin.</p>
          <p>Downtown New Braunfels offers its own walkable district of shops, restaurants, and galleries centered around the historic town plaza. The Sophienburg Museum and Archives tells the story of the German settlers who founded the city, while the Museum of Texas Handmade Furniture showcases 19th-century craftsmanship. Local restaurants serve everything from traditional German fare and Texas barbecue to contemporary dining, and the craft brewery and winery scene continues to grow.</p>
          <h3>Seasonal Events and Festivals</h3>
          <p>Wurstfest is the crown jewel of the New Braunfels event calendar. This 10-day celebration of German culture, held every November at Landa Park, draws more than 240,000 visitors for live music on five stages, German food and beer, carnival rides, and dancing. It is one of the largest cultural festivals in the Southwest and a tradition that the community takes enormous pride in. The Gruene Music and Wine Festival, held each fall, brings together over 50 Texas wineries and breweries with four days of live music in the historic district. Other annual events include Wassailfest in December, the Comal County Fair, Fourth of July celebrations, and Folkfest in the spring. The city maintains a full calendar of community events that keep residents engaged year-round.</p>
        </div>
      </div>
    </section>

    <!-- Filter Tabs -->
    <section class="section" style="background: var(--light-gray); padding-top: 2rem; padding-bottom: 0;">
      <div class="container">
        <div class="act-filters" id="actFilters">
          <button class="act-filter act-filter--active" data-filter="all">All</button>
          {categories.map(cat => (
            <button class="act-filter" data-filter={cat}>{categoryLabels[cat]}</button>
          ))}
        </div>
      </div>
    </section>

    <!-- Activity Cards -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="act-grid" id="actGrid">
          {activities.map(a => (
            <a href={a.url} target="_blank" rel="noopener" class="act-card" data-category={a.category}>
              <span class="act-card__category">{categoryLabels[a.category]}</span>
              <h3>{a.name}</h3>
              <p>{a.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="act-cta">
      <div class="act-cta__overlay"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <h2>Want to Live Where the <span class="accent">Fun Is</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">I can help you find a home close to the rivers, Gruene, downtown, and all the activities that make NB special.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="https://cposeyrealestate.idxbroker.com/idx/search/advanced" class="btn btn-primary">Search Homes</a>
          <a href="#contact" class="btn btn-outline">Let's Connect</a>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/guadalupe-river.png" />

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About Things to Do in New Braunfels</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>What are the best outdoor activities in New Braunfels?</summary>
            <p>New Braunfels is best known for its river recreation. Tubing the spring-fed Comal River is the most popular activity, offering a relaxing two-to-three-hour float through town in crystal-clear, 72-degree water. The Guadalupe River provides longer kayaking and tubing trips through scenic Hill Country terrain. Landa Park offers a free 51-acre green space with a spring-fed pool, walking trails, disc golf, and paddle boats. Guadalupe River State Park is a short drive away with nearly 1,900 acres of hiking, swimming, and fishing. Cycling, birdwatching, and golf round out the outdoor options available to residents year-round.</p>
          </details>
          <details class="faq-item">
            <summary>What family-friendly attractions are in New Braunfels?</summary>
            <p>New Braunfels offers some of the best family attractions in Texas. Schlitterbahn Waterpark, powered by natural spring water, is consistently ranked among the top water parks in the country and features rides for all ages. Natural Bridge Caverns takes visitors 180 feet underground through massive geological formations, with zip lines and a maze above ground. Natural Bridge Wildlife Ranch is a 500-acre drive-through safari with over 500 animals. Landa Park provides free access to playgrounds, a miniature train, paddle boats, and swimming. The Cliff Carver Alpine Coaster offers a gravity-propelled sled ride through the Hill Country hillside.</p>
          </details>
          <details class="faq-item">
            <summary>What festivals and seasonal events does New Braunfels host?</summary>
            <p>New Braunfels has one of the most active event calendars in the Hill Country. Wurstfest, held every November, is a 10-day celebration of German culture drawing over 240,000 visitors for live music, food, beer, and carnival rides. The Gruene Music and Wine Festival in the fall features 50-plus Texas wineries with four days of live music. Other major events include Wassailfest in December, the Comal County Fair, Fourth of July celebrations, and Folkfest in the spring. Gruene Hall hosts live music every night year-round, and downtown New Braunfels offers seasonal markets, art walks, and community gatherings throughout the year.</p>
          </details>
        </div>
      </div>
    </section>

    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What are the best outdoor activities in New Braunfels?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "New Braunfels is best known for its river recreation. Tubing the spring-fed Comal River is the most popular activity, offering a relaxing two-to-three-hour float through town in crystal-clear, 72-degree water. The Guadalupe River provides longer kayaking and tubing trips through scenic Hill Country terrain. Landa Park offers a free 51-acre green space with a spring-fed pool, walking trails, disc golf, and paddle boats. Guadalupe River State Park is a short drive away with nearly 1,900 acres of hiking, swimming, and fishing. Cycling, birdwatching, and golf round out the outdoor options available to residents year-round."
          }
        },
        {
          "@type": "Question",
          "name": "What family-friendly attractions are in New Braunfels?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "New Braunfels offers some of the best family attractions in Texas. Schlitterbahn Waterpark, powered by natural spring water, is consistently ranked among the top water parks in the country and features rides for all ages. Natural Bridge Caverns takes visitors 180 feet underground through massive geological formations, with zip lines and a maze above ground. Natural Bridge Wildlife Ranch is a 500-acre drive-through safari with over 500 animals. Landa Park provides free access to playgrounds, a miniature train, paddle boats, and swimming. The Cliff Carver Alpine Coaster offers a gravity-propelled sled ride through the Hill Country hillside."
          }
        },
        {
          "@type": "Question",
          "name": "What festivals and seasonal events does New Braunfels host?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "New Braunfels has one of the most active event calendars in the Hill Country. Wurstfest, held every November, is a 10-day celebration of German culture drawing over 240,000 visitors for live music, food, beer, and carnival rides. The Gruene Music and Wine Festival in the fall features 50-plus Texas wineries with four days of live music. Other major events include Wassailfest in December, the Comal County Fair, Fourth of July celebrations, and Folkfest in the spring. Gruene Hall hosts live music every night year-round, and downtown New Braunfels offers seasonal markets, art walks, and community gatherings throughout the year."
          }
        }
      ]
    }
    </script>

  <ContactForm context="I'd like to find homes near the best things to do in NB..." />
  <Footer />
</Layout>

<style>
  .act-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/comal-river.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .act-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .act-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .act-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 0.75rem;
  }

  .act-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover { color: #FF1616; }
  .breadcrumb span { margin: 0 0.3rem; }

  .act-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
    text-align: center;
    margin: 0 auto;
    font-weight: 600;
  }

  /* Filters */
  .act-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    padding-bottom: 2rem;
  }

  .act-filter {
    padding: 0.5rem 1.25rem;
    border: 2px solid #ddd;
    border-radius: 25px;
    background: #fff;
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    cursor: pointer;
    transition: all 0.2s;
    color: #333;
  }

  .act-filter:hover {
    border-color: #FF1616;
    color: #FF1616;
  }

  .act-filter--active {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }

  .act-filter--active:hover { color: #fff; }

  /* Cards */
  .act-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .act-card {
    background: #fff;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    text-align: center;
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .act-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  }

  .act-card__category {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #FF1616;
    margin-bottom: 0.5rem;
  }

  .act-card h3 {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    transition: color 0.2s;
  }

  .act-card:hover h3 {
    color: #FF1616;
  }

  .act-card p {
    color: var(--gray);
    font-size: 0.85rem;
    line-height: 1.7;
  }

  /* CTA */
  .act-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .act-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
  }

  .act-cta h2 { color: #fff; }

  .nb-expanded-content {
    max-width: 800px;
    margin: 2rem auto 0;
    text-align: left;
  }

  .nb-expanded-content p {
    color: var(--gray);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .nb-expanded-content h3 {
    font-family: var(--font-heading);
    font-size: 1.15rem;
    margin: 2rem 0 0.75rem;
    text-transform: uppercase;
  }

  /* FAQ */
  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }

  @media (max-width: 900px) {
    .act-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .act-grid { grid-template-columns: 1fr; }
    .act-cta { background-attachment: scroll; }
  }
</style>

<script is:inline>
  const filters = document.querySelectorAll('.act-filter');
  const cards = document.querySelectorAll('.act-card');

  filters.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;

      filters.forEach(f => f.classList.remove('act-filter--active'));
      btn.classList.add('act-filter--active');

      cards.forEach(card => {
        if (filter === 'all' || card.dataset.category === filter) {
          card.style.display = 'block';
        } else {
          card.style.display = 'none';
        }
      });
    });
  });
</script>
