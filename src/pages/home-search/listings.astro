---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Home Search | Browse All Listings | Cody Posey Real Estate"
  description="Search all homes for sale in the New Braunfels, TX area. Use our advanced search, map search, or browse by area."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="hs-hero">
      <div class="hs-hero__overlay"></div>
      <div class="hs-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <span>Home Search</span>
        </nav>
        <h1>Home <span style="color:#FF1616;">Search</span></h1>
        <p>Find your next home in the Texas Hill Country</p>
      </div>
    </div>

    <!-- Tabbed Search -->
    <section class="section hs-search-section">
      <div class="container">
        <div class="hs-tabs" id="hsTabs">
          <button class="hs-tab hs-tab--active" data-tab="map">Map Search</button>
          <button class="hs-tab" data-tab="advanced">Advanced Search</button>
        </div>

        <div class="hs-tab-panel hs-tab-panel--active" id="panel-map">
          <div class="idx-embed idx-embed--map">
            <iframe
              src="https://cposeyrealestate.idxbroker.com/idx/map/mapsearch"
              allowtransparency="true"
              frameBorder="0"
              title="Map Property Search"
            ></iframe>
          </div>
        </div>

        <div class="hs-tab-panel" id="panel-advanced">
          <div class="idx-embed">
            <iframe
              src=""
              data-src="https://cposeyrealestate.idxbroker.com/idx/search/advanced"
              allowtransparency="true"
              frameBorder="0"
              title="Advanced Property Search"
            ></iframe>
          </div>
        </div>
      </div>
    </section>

    <!-- Browse by Area -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>Browse by <span class="accent">Area</span></h2>
          <p>Jump directly to listings in a specific community</p>
        </div>
        <div class="hs-area-grid">
          <a href="/search" class="hs-area-card">
            <span class="hs-area-card__name">New Braunfels</span>
            <span class="hs-area-card__count">1,600+ homes</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/search" class="hs-area-card">
            <span class="hs-area-card__name">Canyon Lake</span>
            <span class="hs-area-card__count">430+ homes</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/search" class="hs-area-card">
            <span class="hs-area-card__name">Seguin</span>
            <span class="hs-area-card__count">620+ homes</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/search" class="hs-area-card">
            <span class="hs-area-card__name">Cibolo / Schertz</span>
            <span class="hs-area-card__count">760+ homes</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/search" class="hs-area-card">
            <span class="hs-area-card__name">Bulverde / Spring Branch</span>
            <span class="hs-area-card__count">230+ homes</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" style="background: #000; color: #fff; text-align: center;">
      <div class="container">
        <h2>Need Help <span class="accent">Finding a Home</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Tell me what you're looking for and I'll send you a curated list of properties that match your criteria.</p>
        <a href="#contact" class="btn btn-primary">Get a Custom List</a>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/hill-country-home-1.png" />

  <ContactForm context="I'm looking for a home in..." />
  <Footer />
</Layout>

<style>
  .hs-hero {
    position: relative;
    height: 260px;
    background: url('/images/generated/hill-country-sunset.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .hs-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .hs-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .hs-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .hs-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #FF1616;
  }

  .breadcrumb span {
    margin: 0 0.3rem;
  }

  /* Search Section - minimal padding to maximize map */
  .hs-search-section {
    padding-top: 1.5rem;
    padding-bottom: 2rem;
  }

  /* Tabs */
  .hs-tabs {
    display: flex;
    gap: 0;
    margin-bottom: 1rem;
    border-bottom: 2px solid #ddd;
  }

  .hs-tab {
    padding: 0.75rem 2rem;
    background: none;
    border: none;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray);
    cursor: pointer;
    position: relative;
    transition: color 0.2s;
  }

  .hs-tab::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    right: 0;
    height: 2px;
    background: transparent;
    transition: background 0.2s;
  }

  .hs-tab:hover {
    color: #000;
  }

  .hs-tab--active {
    color: #FF1616;
  }

  .hs-tab--active::after {
    background: #FF1616;
  }

  /* Tab Panels */
  .hs-tab-panel {
    display: none;
  }

  .hs-tab-panel--active {
    display: block;
  }

  /* IDX Embed */
  .idx-embed {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .idx-embed iframe {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }

  /* Map embed - taller for better experience */
  .idx-embed--map iframe {
    height: calc(100vh - 200px);
    min-height: 600px;
    max-height: 900px;
  }

  /* Area Grid */
  .hs-area-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .hs-area-card {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #fff;
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    text-decoration: none;
    color: #111;
    font-family: 'Poppins', sans-serif;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .hs-area-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  }

  .hs-area-card__name {
    font-weight: 700;
    font-size: 0.9rem;
  }

  .hs-area-card__count {
    font-size: 0.75rem;
    color: #FF1616;
    font-weight: 600;
    margin-left: auto;
  }

  .hs-area-card__arrow {
    color: #FF1616;
    font-size: 1.25rem;
    transition: transform 0.2s;
    flex-shrink: 0;
  }

  .hs-area-card:hover .hs-area-card__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 600px) {
    .hs-tab {
      padding: 0.75rem 1.25rem;
      font-size: 0.78rem;
    }

    .idx-embed--map iframe {
      height: 500px;
      min-height: 400px;
    }
  }
</style>

<script is:inline>
  const tabs = document.querySelectorAll('.hs-tab');
  const panels = document.querySelectorAll('.hs-tab-panel');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      const target = tab.dataset.tab;

      tabs.forEach(t => t.classList.remove('hs-tab--active'));
      tab.classList.add('hs-tab--active');

      panels.forEach(p => p.classList.remove('hs-tab-panel--active'));
      const panel = document.getElementById('panel-' + target);
      if (panel) {
        panel.classList.add('hs-tab-panel--active');

        // Lazy-load iframe if it has data-src
        const iframe = panel.querySelector('iframe[data-src]');
        if (iframe && iframe.getAttribute('src') !== iframe.dataset.src) {
          iframe.src = iframe.dataset.src;
        }
      }
    });
  });
</script>
