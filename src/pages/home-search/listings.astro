---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import IDXSearchBar from '../../components/IDXSearchBar.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Home Search | Browse All Listings | Cody Posey Real Estate"
  description="Search all homes for sale in the New Braunfels, TX area. Use our advanced search, map search, or browse by area."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="hs-hero">
      <div class="hs-hero__overlay"></div>
      <div class="hs-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <span>Home Search</span>
        </nav>
        <h1>Home <span style="color:#FF1616;">Search</span></h1>
        <p>Find your next home in the Texas Hill Country</p>
      </div>
    </div>

    <!-- Quick Search Widget -->
    <section class="section">
      <div class="container">
        <div class="section-title">
          <h2>Quick <span class="accent">Search</span></h2>
          <p>Start your home search here</p>
        </div>
        <IDXSearchBar />
      </div>
    </section>

    <!-- Advanced Search -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>Advanced <span class="accent">Search</span></h2>
          <p>Narrow results by price, beds, baths, property type, and more</p>
        </div>
        <div class="idx-embed">
          <iframe
            src="https://cposeyrealestate.idxbroker.com/idx/search/advanced"
            allowtransparency="true"
            frameBorder="0"
            title="Advanced Property Search"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Map Search -->
    <section class="section">
      <div class="container">
        <div class="section-title">
          <h2>Map <span class="accent">Search</span></h2>
          <p>Draw on the map to find homes in a specific area</p>
        </div>
        <div class="idx-embed">
          <iframe
            src="https://cposeyrealestate.idxbroker.com/idx/map/mapsearch"
            allowtransparency="true"
            frameBorder="0"
            title="Map Property Search"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- Browse by Area -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>Browse by <span class="accent">Area</span></h2>
          <p>Jump directly to listings in a specific community</p>
        </div>
        <div class="hs-area-grid">
          <a href="/new-braunfels/homes-for-sale/" class="hs-area-card">
            <span class="hs-area-card__name">New Braunfels</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/canyon-lake/homes-for-sale/" class="hs-area-card">
            <span class="hs-area-card__name">Canyon Lake</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/seguin/homes-for-sale/" class="hs-area-card">
            <span class="hs-area-card__name">Seguin</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/cibolo-schertz/homes-for-sale/" class="hs-area-card">
            <span class="hs-area-card__name">Cibolo / Schertz</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
          <a href="/bulverde/homes-for-sale/" class="hs-area-card">
            <span class="hs-area-card__name">Bulverde / Spring Branch</span>
            <span class="hs-area-card__arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" style="background: #000; color: #fff; text-align: center;">
      <div class="container">
        <h2>Need Help <span class="accent">Finding a Home</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Tell me what you're looking for and I'll send you a curated list of properties that match your criteria.</p>
        <a href="#contact" class="btn btn-primary">Get a Custom List</a>
      </div>
    </section>

  </main>
  <ContactForm context="I'm looking for a home in..." />
  <Footer />
</Layout>

<style>
  .hs-hero {
    position: relative;
    height: 280px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .hs-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #000 0%, #1a0000 100%);
    opacity: 0.9;
  }

  .hs-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .hs-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .hs-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #FF1616;
  }

  .breadcrumb span {
    margin: 0 0.3rem;
  }

  /* IDX Embed */
  .idx-embed {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .idx-embed iframe {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }

  /* Area Grid */
  .hs-area-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .hs-area-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: #fff;
    padding: 1.25rem 1.5rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    text-decoration: none;
    color: #111;
    font-weight: 600;
    font-family: 'Poppins', sans-serif;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .hs-area-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.12);
  }

  .hs-area-card__arrow {
    color: #FF1616;
    font-size: 1.25rem;
    transition: transform 0.2s;
  }

  .hs-area-card:hover .hs-area-card__arrow {
    transform: translateX(4px);
  }
</style>
