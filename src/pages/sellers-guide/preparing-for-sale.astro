---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';

const exterior = [
  'Creating great curb appeal is essential — first impressions are everything.',
  'Manicure your landscaping. Mow, edge, trim bushes and trees so they don\'t obstruct the home.',
  'Pressure wash hard surfaces including driveways, walkways, and patios.',
  'Sweep porches and patios. Remove cobwebs and dirt from corners, shutters, and outdoor furniture.',
  'Repair any rotten wood on trim, fascia, fencing, or decking.',
  'Paint exterior, fascia, and shutters if necessary.',
  'Front door appeal — clean, re-stain, and add new hardware if needed.',
  'Check that address numbers and letters look good and are visible from the street.',
  'If you have a pool, make sure it\'s functioning (lights, fountains, spa) and looking great. Add colorful pots around the pool if necessary.',
  'Ensure the roof and gutters are clean and clear of debris.',
  'Playscapes, trampolines, basketball hoops, and soccer goals — can they be removed? If not, are they looking good and inconspicuous?',
];

const interior = [
  'Clean, clutter-free, neutral, light, and open is the goal. Open drapes and blinds to let in natural light.',
  'Change bold wall colors to light and neutral tones. Usually a warm white or cream works great.',
  'Remove personal items such as mounted family photos. Buyers need to imagine themselves living there.',
  'Diplomas, articles, religious items, and political statements can negatively affect sales — remove them.',
  'Replace any fogged or cracked windows.',
  'Have windows professionally cleaned. Remove window screens to let more light in and store them in the garage.',
  'Kitchen: Are appliances and counters appropriate for the price range? Touch up paint on cabinets and trim if needed.',
  'Clear kitchen counters — remove extra cookbooks, bowls, and appliances. Counters should have almost nothing on them.',
  'Replace any worn or dirty carpet. This turns a huge negative into a positive. Providing an allowance to buyers instead is not as effective.',
  'Closets should be well organized to look as large as possible. Matching coat hangers (not white) and no plastic dry cleaner bags helps a lot.',
  'Use a "Magic Eraser" to remove scuff marks on walls.',
  'Bathrooms: Check tile grout — is it dirty or cracked? Are countertops, fixtures, and shower glass appropriate for the price range?',
  'Put away lotions, shampoo, electric toothbrushes, and bath toys from bathroom counters.',
  'Pay close attention to baseboards — they often show wear and collect dust.',
  'Check corners and mouldings for small separation gaps. These are from normal settling and easily fixed with caulk.',
  'Lightbulbs matter: Are they all working? Soft white LED bulbs over 1000 lumens give the best quality of light. Don\'t have mismatched bulbs (some yellow, some white).',
  'Garage: Clean and clutter-free if possible. Items should be well organized. Consider epoxy on the floor.',
  'Ensure all pets are out of the house during showings, and food dishes and pet beds are put away.',
];

const systems = [
  'HVAC — Replace air filters and consider having units professionally serviced.',
  'Audio/Visual systems — Confirm everything is working properly.',
  'Hot Water Heater — Check for leaks and ensure it\'s functioning.',
  'Fireplaces — Clean and confirm they\'re operational.',
  'Water Softener — Verify it\'s maintained and working.',
  'Central Vacuum — Test and confirm it works.',
];
---

<Layout
  title="Preparing Your Home for Sale | Seller's Guide | Popby Realty"
  description="A comprehensive guide to getting your home market-ready. Curb appeal, interior staging, systems checks, and more."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <div class="sp-hero">
      <div class="sp-hero__overlay"></div>
      <div class="sp-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/sellers-guide">Seller's Guide</a> <span>/</span> <span>Preparing for Sale</span>
        </nav>
        <h1>Preparing Your Home for <span style="color:#FF1616;">Sale</span></h1>
        <p>Make the clear impression that you are a diligent homeowner who has maintained and improved the home</p>
      </div>
    </div>

    <section class="section">
      <div class="container">
        <div class="sp-content">
          <p class="sp-lead">Use these suggestions to showcase the features of your home that will attract more qualified buyers. Consider providing a list of features and amenities you enjoy about the house and neighborhood — buyers love to hear what makes a home special from the people who lived there.</p>

          <h2>Exterior</h2>
          <ul class="sp-list">
            {exterior.map((item) => <li>{item}</li>)}
          </ul>

          <h2>Interior</h2>
          <ul class="sp-list">
            {interior.map((item) => <li>{item}</li>)}
          </ul>

          <h2>Systems</h2>
          <p style="color: var(--gray); margin-bottom: 1rem;">Are all of your home's systems in good working condition?</p>
          <ul class="sp-list">
            {systems.map((item) => <li>{item}</li>)}
          </ul>

          <h2>Why Preparation Matters in the Hill Country Market</h2>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">The New Braunfels and Texas Hill Country real estate market attracts buyers from across the state and beyond. Many are relocating from Austin, San Antonio, or out of state entirely. These buyers are comparing your home not just to others in the neighborhood, but to every listing they have seen online. When your home is well-prepared, it immediately separates itself from the competition and creates the emotional connection that drives offers.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">In my experience working with sellers across New Braunfels, Canyon Lake, Seguin, and Bulverde, the homes that sell fastest and for the highest price share common traits. They are clean, decluttered, well-lit, and free of obvious maintenance issues. They smell fresh and feel inviting. The sellers who put in the work before listing almost always see that effort reflected in stronger offers and smoother transactions.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">One area that often gets overlooked is the garage. Buyers in Texas expect functional garage space, and a cluttered or disorganized garage can leave a negative impression. If your garage is being used primarily for storage, consider renting a temporary storage unit to clear it out before showings begin. The same applies to closets — organized, spacious-looking closets are a major selling point.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">Another consideration specific to the Hill Country is outdoor living space. Patios, porches, decks, and outdoor kitchens are highly valued in this market. If you have outdoor living areas, make sure they are clean, furnished simply, and staged to show their full potential. A pressure-washed patio with a small seating arrangement can make a big difference in how buyers perceive your home.</p>

          <div class="sp-cta">
            <p>Need help deciding what to prioritize before listing? I can walk through your home and help you focus on the improvements that will make the biggest impact.</p>
            <a href="#contact" class="btn btn-primary">Get Personalized Advice</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About Preparing Your Home for Sale</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>How far in advance should I start preparing my home for sale?</summary>
            <p>Ideally, begin preparing your home at least four to six weeks before you plan to list. This gives you time to address repairs, declutter, deep clean, and handle any cosmetic updates like painting or carpet replacement. If you are dealing with larger projects such as roof repairs or HVAC servicing, you may want even more lead time. I offer a complimentary pre-listing walkthrough to help you create a timeline.</p>
          </details>
          <details class="faq-item">
            <summary>Should I repaint my home before selling?</summary>
            <p>If your walls have bold or highly personalized colors, repainting in neutral tones is one of the best investments you can make. Warm whites, light grays, and soft creams appeal to the widest range of buyers and make rooms feel larger and brighter. You do not need to repaint every room — focus on the main living areas, kitchen, and primary bedroom. Touch-up paint on trim and baseboards also goes a long way.</p>
          </details>
          <details class="faq-item">
            <summary>Is it worth replacing carpet before listing?</summary>
            <p>In most cases, yes. Worn, stained, or dated carpet is one of the biggest turn-offs for buyers, and providing a carpet allowance instead of replacing it is far less effective. New carpet is relatively inexpensive and gives the home a fresh, clean feel that buyers respond to immediately. If your home has hardwood underneath, consider removing the carpet entirely — hardwood floors are a major selling point in the Hill Country market.</p>
          </details>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/comal-river.png" />
  <ContactForm context="I'm preparing my home for sale and would like your advice..." />
  <Footer />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How far in advance should I start preparing my home for sale?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ideally, begin preparing your home at least four to six weeks before you plan to list. This gives you time to address repairs, declutter, deep clean, and handle any cosmetic updates like painting or carpet replacement."
        }
      },
      {
        "@type": "Question",
        "name": "Should I repaint my home before selling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "If your walls have bold or highly personalized colors, repainting in neutral tones is one of the best investments you can make. Warm whites, light grays, and soft creams appeal to the widest range of buyers and make rooms feel larger and brighter."
        }
      },
      {
        "@type": "Question",
        "name": "Is it worth replacing carpet before listing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "In most cases, yes. Worn, stained, or dated carpet is one of the biggest turn-offs for buyers, and providing a carpet allowance instead of replacing it is far less effective. New carpet is relatively inexpensive and gives the home a fresh, clean feel."
        }
      }
    ]
  }
  </script>
</Layout>

<style>
  .sp-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/sellers-guide-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .sp-hero__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .sp-hero__content { position: relative; z-index: 1; padding: 0 1.5rem; }
  .sp-hero__content h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 0.5rem; }
  .sp-hero__content p { color: rgba(255,255,255,0.7); font-size: 0.95rem; max-width: 550px; margin: 0 auto; }

  .breadcrumb { font-size: 0.8rem; margin-bottom: 1rem; color: rgba(255,255,255,0.5); }
  .breadcrumb a { color: rgba(255,255,255,0.5); transition: color 0.2s; }
  .breadcrumb a:hover { color: #FF1616; }
  .breadcrumb span { margin: 0 0.3rem; }

  .sp-content { max-width: 800px; margin: 0 auto; }

  .sp-lead {
    font-size: 1rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    text-align: center;
    font-weight: 600;
  }

  .sp-content h2 {
    font-size: 1.4rem;
    margin: 2.5rem 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #FF1616;
    display: inline-block;
  }

  .sp-list {
    list-style: none;
    padding: 0;
  }

  .sp-list li {
    position: relative;
    padding: 0.65rem 0 0.65rem 1.5rem;
    font-size: 0.92rem;
    color: #555;
    line-height: 1.7;
    border-bottom: 1px solid #eee;
  }

  .sp-list li:last-child { border-bottom: none; }

  .sp-list li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: #FF1616;
    font-weight: 700;
  }

  .sp-cta {
    margin-top: 3rem;
    padding: 2rem;
    background: #111;
    border-radius: 10px;
    text-align: center;
  }

  .sp-cta p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }
</style>
