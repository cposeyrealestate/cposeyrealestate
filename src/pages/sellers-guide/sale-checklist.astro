---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

const pageTitle = "Home Sale Checklist | Seller's Guide | Cody Posey";
const pageDescription = 'A room-by-room home sale checklist for New Braunfels, TX sellers — evaluate exterior, interior, kitchen, bath, and mechanicals to maximize your final sale price.';
const pageSchema = [
  articleSchema({ title: pageTitle, description: pageDescription, url: '/sellers-guide/sale-checklist' }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: "Seller's Guide", url: '/sellers-guide' },
    { name: 'Sale Checklist', url: '/sellers-guide/sale-checklist' },
  ]),
];

const categories = [
  {
    title: 'Exterior',
    items: [
      'Does the house need painting? Are there any holes or cracks?',
      'Are the walks and porches clean and in good repair?',
      'Does the front of the home give a "welcome" appearance?',
    ],
  },
  {
    title: 'Landscaping',
    items: [
      'Does the yard look well-maintained?',
      'Are the trees and bushes trimmed?',
      'Is the lawn mowed and edged?',
      'Is the yard free of weeds?',
      'Are the decks and patios clean?',
    ],
  },
  {
    title: 'Roof',
    items: [
      'Does it leak?',
      'Are there any shingles or tiles missing?',
      'Does it sag?',
      'Is the chimney in good shape?',
    ],
  },
  {
    title: 'Walls',
    items: [
      'Are there any cracks or holes?',
      'Do they need painting?',
      'What about wallpaper — is it dated or peeling?',
    ],
  },
  {
    title: 'Kitchen',
    items: [
      'Are the appliances clean and in working order?',
      'Are the cabinets in good condition and tidy?',
      'Are the countertops in good condition?',
      'Is the tile grout clean?',
      'Is the sink stained, chipped, or in need of recaulking?',
    ],
  },
  {
    title: 'Ceilings',
    items: [
      'Are there any water stains?',
      'Are they cracked or peeling?',
      'Do they need painting?',
    ],
  },
  {
    title: 'Carpets & Flooring',
    items: [
      'Are they clean?',
      'Are they worn?',
      'Do they need stretching?',
      'Are there any spots or faded areas?',
    ],
  },
  {
    title: 'Bathrooms',
    items: [
      'Do the faucets shut off completely?',
      'Do the sinks drain freely?',
      'Are the toilets in good condition?',
      'Are the shower doors shiny?',
      'Do the tubs need caulking?',
      'Is the floor in good condition?',
      'Are the vanities and mirrors in good condition?',
    ],
  },
  {
    title: 'Windows',
    items: [
      'Are the drapes, shutters, and/or shades working properly?',
      'Are they clean and attractive?',
      'Are any screens bent?',
      'Do the windows open and close easily?',
      'Do you need to replace storm windows?',
      'Are the windowsills clean? Is there any rot or rust?',
    ],
  },
  {
    title: 'Doors',
    items: [
      'Are they in good condition?',
      'Are they sagging or sticking?',
      'Do the locks work?',
      'Is the paint in good condition?',
      'Do the doors seal tightly?',
      'Do you need to replace storm doors?',
    ],
  },
  {
    title: 'Fireplace',
    items: [
      'Is it clean?',
      'Is the screen in good shape?',
      'Does it make an attractive display?',
    ],
  },
  {
    title: 'Garage',
    items: [
      'Is it organized?',
      'Is there sufficient lighting?',
      'Is the floor swept?',
      'Are there oil spots or other stains on the concrete?',
    ],
  },
  {
    title: 'Attic',
    items: [
      'Is it organized?',
      'Is there sufficient lighting?',
      'Is it clean?',
      'Are the stairs in good repair?',
      'Do the doors open and close easily?',
      'Are there any signs of insects or rodents?',
    ],
  },
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={pageSchema}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <div class="sp-hero">
      <div class="sp-hero__overlay"></div>
      <div class="sp-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/sellers-guide">Seller's Guide</a> <span>/</span> <span>Sale Checklist</span>
        </nav>
        <h1>Home Sale <span style="color:#FF1616;">Checklist</span></h1>
        <p>A room-by-room evaluation to get your home ready for market</p>
      </div>
    </div>

    <section class="section">
      <div class="container">
        <div class="sp-content">
          <p class="sp-lead">Walk through each area of your home and honestly evaluate its condition. This checklist will help you identify what needs attention before listing so you can present your home in the best possible light and avoid surprises during the buyer's inspection.</p>

          <div class="cl-grid">
            {categories.map((cat) => (
              <div class="cl-card">
                <h3>{cat.title}</h3>
                <ul>
                  {cat.items.map((item) => (
                    <li>
                      <span class="cl-checkbox"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            ))}
          </div>

          <h2 style="font-size:1.4rem;margin:2.5rem 0 1.25rem;padding-bottom:0.5rem;border-bottom:2px solid #FF1616;display:inline-block;">How to Use This Checklist</h2>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">Walk through your home with fresh eyes — as if you were seeing it for the first time as a potential buyer. Start at the curb and work your way through every room, making notes on anything that stands out. Be honest with yourself about what a buyer would notice. Small details like a scuffed baseboard, a dripping faucet, or a closet stuffed to overflowing can shape a buyer's perception of the entire home.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">Not everything on this checklist needs to be perfect before listing. The goal is to identify issues, prioritize them, and address the ones that will have the greatest impact on buyer perception and inspection outcomes. Some items — like a new roof or major foundation work — may be beyond your budget to fix, and that is okay. What matters is that you are aware of the issues and can disclose them appropriately.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">For sellers in the New Braunfels area, there are a few items worth extra attention. Hill Country homes often have limestone features, metal roofs, or pier-and-beam foundations that require specific maintenance. If your home has a septic system, confirm it has been pumped recently and is functioning properly. Water softeners and well systems should also be serviced and documented before listing.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">I recommend going through this checklist and then scheduling a walkthrough with me. I will bring a different perspective — one shaped by working with hundreds of buyers and knowing exactly what they look for. Together we can create a plan that fits your budget and timeline while maximizing your home's appeal to the market.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">Remember, the sellers who invest time in preparation consistently see better results. A clean, well-maintained home sells faster, commands higher offers, and encounters fewer issues during the transaction. The checklist above is your starting point — and I am here to help you every step of the way.</p>

          <div class="sp-cta">
            <p>Want a professional opinion on what to address before listing? I offer a complimentary pre-listing walkthrough to help you prioritize.</p>
            <a href="#contact" class="btn btn-primary">Request a Walkthrough</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About Preparing to Sell</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>What are the most important areas to address before listing?</summary>
            <p>Focus on the areas buyers see first and care about most: the exterior and curb appeal, the kitchen, bathrooms, and flooring. These spaces have the biggest influence on buyer perception and offer price. A clean, well-maintained kitchen and updated bathrooms can offset other minor issues throughout the home. Curb appeal sets the tone before a buyer even walks through the door.</p>
          </details>
          <details class="faq-item">
            <summary>How much should I spend on pre-listing improvements?</summary>
            <p>There is no one-size-fits-all answer, but a good rule of thumb is to focus on cost-effective improvements with a high return. Fresh paint, professional cleaning, new carpet, and landscaping cleanup are among the best investments. Major renovations like a kitchen remodel are rarely worth doing just to sell — you are unlikely to recoup the full cost. I can help you prioritize based on your specific home and price range.</p>
          </details>
          <details class="faq-item">
            <summary>Do you offer a pre-listing walkthrough?</summary>
            <p>Yes. I offer a complimentary pre-listing walkthrough for sellers in the New Braunfels and Hill Country area. During the walkthrough, I will evaluate each room and provide specific recommendations on what to address before listing. This service is designed to help you focus your time and budget on the improvements that will have the biggest impact on your sale price and time on market.</p>
          </details>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/comal-river.png" />
  <ContactForm context="I'd like a pre-listing walkthrough of my home..." />
  <Footer />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What are the most important areas to address before listing?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Focus on the areas buyers see first and care about most: the exterior and curb appeal, the kitchen, bathrooms, and flooring. These spaces have the biggest influence on buyer perception and offer price."
        }
      },
      {
        "@type": "Question",
        "name": "How much should I spend on pre-listing improvements?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "There is no one-size-fits-all answer, but focus on cost-effective improvements with a high return. Fresh paint, professional cleaning, new carpet, and landscaping cleanup are among the best investments. Major renovations like a kitchen remodel are rarely worth doing just to sell."
        }
      },
      {
        "@type": "Question",
        "name": "Do you offer a pre-listing walkthrough?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. I offer a complimentary pre-listing walkthrough for sellers in the New Braunfels and Hill Country area. During the walkthrough, I will evaluate each room and provide specific recommendations on what to address before listing."
        }
      }
    ]
  }
  </script>
</Layout>

<style>
  .sp-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/sellers-guide-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .sp-hero__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .sp-hero__content { position: relative; z-index: 1; padding: 0 1.5rem; }
  .sp-hero__content h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 0.5rem; }
  .sp-hero__content p { color: rgba(255,255,255,0.7); font-size: 0.95rem; max-width: 550px; margin: 0 auto; }

  .breadcrumb { font-size: 0.8rem; margin-bottom: 1rem; color: rgba(255,255,255,0.5); }
  .breadcrumb a { color: rgba(255,255,255,0.5); transition: color 0.2s; }
  .breadcrumb a:hover { color: #FF1616; }
  .breadcrumb span { margin: 0 0.3rem; }

  .sp-content { max-width: 900px; margin: 0 auto; }

  .sp-lead {
    font-size: 1rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    text-align: center;
    font-weight: 600;
  }

  .cl-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .cl-card {
    background: var(--light-gray);
    border-radius: 8px;
    padding: 1.75rem;
  }

  .cl-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: #111;
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #FF1616;
  }

  .cl-card ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cl-card li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.88rem;
    color: #555;
    line-height: 1.6;
    padding: 0.4rem 0;
  }

  .cl-checkbox {
    width: 16px;
    height: 16px;
    border: 2px solid #ccc;
    border-radius: 3px;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .sp-cta {
    margin-top: 3rem;
    padding: 2rem;
    background: #111;
    border-radius: 10px;
    text-align: center;
  }

  .sp-cta p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }

  @media (max-width: 600px) {
    .cl-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
