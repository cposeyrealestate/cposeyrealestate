---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import ContactForm from '../../components/ContactForm.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';
import { articleSchema, breadcrumbSchema } from '../../lib/schema';

const pageTitle = "Preparing Your Home for Listing Photos | Seller's Guide | Cody Posey";
const pageDescription = "Interior and exterior checklists to get your New Braunfels, TX home ready for listing photography — because buyers' first impression comes from the photos.";
const pageSchema = [
  articleSchema({ title: pageTitle, description: pageDescription, url: '/sellers-guide/preparing-for-photos' }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: "Seller's Guide", url: '/sellers-guide' },
    { name: 'Preparing for Photos', url: '/sellers-guide/preparing-for-photos' },
  ]),
];

const exterior = [
  'Move all cars out of the driveway and down the street so they will not be captured in any photos.',
  'Close garage doors.',
  'Move or put away garden hoses and tuck trash and recycle bins out of sight.',
  'Remove any empty flowerpots and consider adding fresh flowers.',
  'Clean the swimming pool if applicable.',
  'Mow the yard, bag leaves, and trim bushes and trees — especially if they obstruct the house.',
  'Do not schedule workmen, landscaping crews, or maintenance to be present on picture day.',
  'Pick up newspapers from the driveway and walkways.',
];

const interior = [
  'Make beds and wash or put away dishes — do not leave them in the sink or drying rack.',
  'Pick up any clothes on the floor and put away robes, slippers, etc.',
  'Clear kitchen counters — remove extra cookbooks, bowls, and small appliances. Counters should have almost nothing on them.',
  'Pick up toys, piles of magazines, and other clutter throughout the house.',
  'Check bathroom counters and put away lotions, shampoo, electric toothbrushes, and bath toys.',
  'Ensure all pets are out of the house and food dishes and pet beds are put away.',
  'Put away mail, magazines, and newspapers so nothing is on a counter or table.',
  'Stow media remote controls out of sight.',
  'If the study or home office will be photographed, remove or neatly stack all paperwork.',
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={pageSchema}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <div class="sp-hero">
      <div class="sp-hero__overlay"></div>
      <div class="sp-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/sellers-guide">Seller's Guide</a> <span>/</span> <span>Preparing for Photos</span>
        </nav>
        <h1>Preparing for <span style="color:#FF1616;">Photographs</span></h1>
        <p>First impressions start online — make your listing photos count</p>
      </div>
    </div>

    <section class="section">
      <div class="container">
        <div class="sp-content">
          <p class="sp-lead">Your listing photos are the first thing most buyers will see. These simple steps will help showcase the features of your home and attract more qualified buyers. A little preparation on picture day goes a long way.</p>

          <h2>Exterior</h2>
          <ul class="sp-list">
            {exterior.map((item) => <li>{item}</li>)}
          </ul>

          <h2>Interior</h2>
          <ul class="sp-list">
            {interior.map((item) => <li>{item}</li>)}
          </ul>

          <h2>Why Professional Photos Matter</h2>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">According to the National Association of REALTORS, the vast majority of home buyers start their search online. That means your listing photos are not just part of the marketing — they are the marketing. A buyer scrolling through listings will spend only a few seconds on each one before deciding whether to click for more details or move on. High-quality photography grabs their attention and draws them in. Poor photos push them away, regardless of how nice the home actually is.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">I coordinate professional photography for every listing I represent. My photographer uses wide-angle lenses, professional lighting, and careful composition to make your home look its best. But the photos can only capture what is there — and that is where your preparation comes in. The checklist above covers the most common issues that affect photo quality, but the general principle is simple: clean, clear, and well-lit wins every time.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">Lighting deserves special attention. Open every blind and curtain to let in natural light. Turn on all interior lights, including under-cabinet lighting, closet lights, and bathroom vanity lights. Replace any burned-out bulbs with soft white LEDs of the same color temperature. Mismatched lighting — some yellow, some white — creates an inconsistent look in photos that buyers notice immediately.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">For outdoor photos, timing matters. Most real estate photographers shoot exterior photos during the golden hour — early morning or late afternoon — when the light is warm and shadows are soft. Make sure your exterior preparation is complete well before the scheduled shoot so nothing is rushed. If you have a pool or water feature, confirm that it is clean and functioning the night before.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">One detail many sellers overlook is the ceiling fan setting. Ceiling fans should be turned off during photography. The blades create a blur in photos and can look messy. The same applies to television screens — turn them off so they do not create a distracting glow or reflection in the images.</p>
          <p style="color: #555; line-height: 1.8; font-size: 0.92rem; margin-bottom: 1rem;">Finally, think about fresh touches that photograph well. A bowl of fresh fruit on the kitchen counter, a simple floral arrangement on the dining table, or neatly folded towels in the bathroom can add warmth and polish to your listing photos without looking staged or artificial.</p>

          <div class="sp-cta">
            <p>I coordinate professional photography for every listing. Let me help you get your home photo-ready.</p>
            <a href="#contact" class="btn btn-primary">Schedule a Consultation</a>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About Listing Photos</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>Do you provide professional photography with your listings?</summary>
            <p>Yes. Professional photography is included with every listing I represent. My photographer uses professional equipment and techniques to showcase your home in its best light. I also offer drone photography and video walkthroughs for properties where aerial views add value, such as homes on acreage or with notable outdoor features.</p>
          </details>
          <details class="faq-item">
            <summary>How long does a typical photo shoot take?</summary>
            <p>Most residential photo shoots take between one and two hours, depending on the size of the home and whether drone or twilight photography is included. I will work with you to schedule the shoot at a time that allows you to complete your preparation without feeling rushed. I recommend having everything ready the evening before so the morning of the shoot is stress-free.</p>
          </details>
          <details class="faq-item">
            <summary>Should I be home during the photo shoot?</summary>
            <p>It is usually best if you are not home during the shoot. This allows the photographer to move freely through the home and make small adjustments to staging without interruption. If you have pets, plan to take them with you. The photographer and I will handle everything — you just need to have the home prepared according to the checklist above.</p>
          </details>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/comal-river.png" />
  <ContactForm context="I'd like help preparing my home for listing photos..." />
  <Footer />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Do you provide professional photography with your listings?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. Professional photography is included with every listing I represent. My photographer uses professional equipment and techniques to showcase your home in its best light. I also offer drone photography and video walkthroughs for properties where aerial views add value."
        }
      },
      {
        "@type": "Question",
        "name": "How long does a typical photo shoot take?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Most residential photo shoots take between one and two hours, depending on the size of the home and whether drone or twilight photography is included."
        }
      },
      {
        "@type": "Question",
        "name": "Should I be home during the photo shoot?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "It is usually best if you are not home during the shoot. This allows the photographer to move freely through the home and make small adjustments to staging without interruption. If you have pets, plan to take them with you."
        }
      }
    ]
  }
  </script>
</Layout>

<style>
  .sp-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/sellers-guide-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .sp-hero__overlay { position: absolute; inset: 0; background: rgba(0,0,0,0.6); }
  .sp-hero__content { position: relative; z-index: 1; padding: 0 1.5rem; }
  .sp-hero__content h1 { font-size: clamp(1.8rem, 4vw, 2.8rem); margin-bottom: 0.5rem; }
  .sp-hero__content p { color: rgba(255,255,255,0.7); font-size: 0.95rem; max-width: 550px; margin: 0 auto; }

  .breadcrumb { font-size: 0.8rem; margin-bottom: 1rem; color: rgba(255,255,255,0.5); }
  .breadcrumb a { color: rgba(255,255,255,0.5); transition: color 0.2s; }
  .breadcrumb a:hover { color: #FF1616; }
  .breadcrumb span { margin: 0 0.3rem; }

  .sp-content { max-width: 800px; margin: 0 auto; }

  .sp-lead {
    font-size: 1rem;
    color: #555;
    line-height: 1.8;
    margin-bottom: 2.5rem;
    text-align: center;
    font-weight: 600;
  }

  .sp-content h2 {
    font-size: 1.4rem;
    margin: 2.5rem 0 1.25rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid #FF1616;
    display: inline-block;
  }

  .sp-list {
    list-style: none;
    padding: 0;
  }

  .sp-list li {
    position: relative;
    padding: 0.65rem 0 0.65rem 1.5rem;
    font-size: 0.92rem;
    color: #555;
    line-height: 1.7;
    border-bottom: 1px solid #eee;
  }

  .sp-list li:last-child { border-bottom: none; }

  .sp-list li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: #FF1616;
    font-weight: 700;
  }

  .sp-cta {
    margin-top: 3rem;
    padding: 2rem;
    background: #111;
    border-radius: 10px;
    text-align: center;
  }

  .sp-cta p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
    line-height: 1.6;
    margin-bottom: 1.25rem;
  }

  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }
</style>
