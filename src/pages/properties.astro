---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';
---

<Layout
  title="Search Homes | Cody Posey Real Estate | New Braunfels, TX"
  description="Search all homes for sale in New Braunfels, TX. Browse MLS listings with Cody Posey Real Estate."
>
  <Navbar />
  <main style="padding-top: 80px;">
    <div class="properties-hero">
      <div class="properties-hero__overlay"></div>
      <div class="properties-hero__content">
        <h1>Search <span style="color:#FF1616;">Properties</span></h1>
        <p>Find homes for sale in New Braunfels and the Texas Hill Country</p>
      </div>
    </div>

    <section class="idx-section section" id="idx-search">
      <div class="container">
        <div class="section-title">
          <h2>Featured <span class="accent">Listings</span></h2>
          <p>Browse our featured homes for sale</p>
        </div>

        <div class="idx-embed">
          <iframe
            src="https://cposeyrealestate.idxbroker.com/idx/featured"
            allowtransparency="true"
            frameBorder="0"
            title="Featured Property Listings"
          ></iframe>
        </div>
      </div>
    </section>
  </main>
  <ParallaxBanner image="/images/generated/nb-neighborhood.png" />
  <Footer />
</Layout>

<style>
  .properties-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/home-nb-modern.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .properties-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .properties-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .properties-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .properties-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .idx-section {
    background: var(--light-gray);
  }

  .idx-embed {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .idx-embed iframe {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }
</style>
