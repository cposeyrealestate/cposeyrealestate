<style>
  .properties-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/home-nb-modern.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .properties-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .properties-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .properties-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .properties-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .idx-section {
    background: var(--light-gray);
  }

  .idx-embed {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .idx-embed iframe {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }

  /* Portfolio */
  .portfolio {
    background: #fff;
  }

  .portfolio__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .portfolio__card {
    background: #fff;
    border: 1px solid #eee;
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .portfolio__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
  }

  .portfolio__img-wrap {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
  }

  .portfolio__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .portfolio__card:hover .portfolio__img-wrap img {
    transform: scale(1.05);
  }

  .portfolio__badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    padding: 0.3rem 0.75rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
  }

  .portfolio__badge--sold {
    background: #FF1616;
  }

  .portfolio__badge--leased {
    background: #333;
  }

  .portfolio__badge--active {
    background: #28a745;
  }

  .portfolio__link {
    display: inline-block;
    margin-top: 0.75rem;
    font-size: 0.8rem;
    font-weight: 600;
    color: #FF1616;
    text-decoration: none;
    transition: color 0.2s;
  }

  .portfolio__link:hover {
    color: #cc0000;
    text-decoration: underline;
  }

  .portfolio__info {
    padding: 1.25rem;
  }

  .portfolio__info h3 {
    font-size: 1rem;
    margin-bottom: 0.25rem;
    color: #111;
  }

  .portfolio__location {
    font-size: 0.85rem;
    color: #777;
    margin-bottom: 0.75rem;
  }

  .portfolio__details {
    display: flex;
    gap: 1rem;
    font-size: 0.8rem;
    color: #555;
    border-top: 1px solid #eee;
    padding-top: 0.75rem;
  }

  /* Pagination */
  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid #eee;
  }

  .pagination__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid #ddd;
    background: #fff;
    color: #555;
    cursor: pointer;
    transition: all 0.2s;
  }

  .pagination__btn:hover:not(:disabled) {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }

  .pagination__btn:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .pagination__pages {
    display: flex;
    gap: 0.25rem;
  }

  :global(.pagination__num) {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid #ddd;
    background: #fff;
    color: #555;
    font-family: 'Poppins', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }

  :global(.pagination__num:hover) {
    border-color: #FF1616;
    color: #FF1616;
  }

  :global(.pagination__num.active) {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }

  @media (max-width: 900px) {
    .portfolio__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 600px) {
    .portfolio__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  (function() {
    const grid = document.querySelector('#portfolio .portfolio__grid');
    if (!grid) return;

    const cards = Array.from(grid.querySelectorAll('.portfolio__card'));
    const perPage = 6;
    const totalPages = Math.ceil(cards.length / perPage);
    let currentPage = 1;

    const prevBtn = document.getElementById('pagePrev');
    const nextBtn = document.getElementById('pageNext');
    const pageNumbers = document.getElementById('pageNumbers');

    // Build page number buttons
    for (let i = 1; i <= totalPages; i++) {
      const btn = document.createElement('button');
      btn.className = 'pagination__num' + (i === 1 ? ' active' : '');
      btn.textContent = i;
      btn.addEventListener('click', () => goToPage(i));
      pageNumbers.appendChild(btn);
    }

    function goToPage(page) {
      currentPage = page;
      const start = (page - 1) * perPage;
      const end = start + perPage;

      cards.forEach((card, i) => {
        card.style.display = (i >= start && i < end) ? '' : 'none';
      });

      // Update active button
      pageNumbers.querySelectorAll('.pagination__num').forEach((btn, i) => {
        btn.classList.toggle('active', i + 1 === page);
      });

      // Update prev/next
      prevBtn.disabled = page === 1;
      nextBtn.disabled = page === totalPages;

      // Scroll to portfolio section
      const section = document.getElementById('portfolio');
      if (section) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    prevBtn.addEventListener('click', () => {
      if (currentPage > 1) goToPage(currentPage - 1);
    });

    nextBtn.addEventListener('click', () => {
      if (currentPage < totalPages) goToPage(currentPage + 1);
    });

    // Initialize — show first page
    goToPage(1);
  })();
</script>
