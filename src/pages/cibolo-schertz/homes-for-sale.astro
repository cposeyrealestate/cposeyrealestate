---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Homes for Sale in Cibolo & Schertz, TX | Cody Posey Real Estate"
  description="Search homes for sale in Cibolo and Schertz, Texas. Browse current MLS listings by price, area, and home type."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="cs-hero">
      <div class="cs-hero__overlay"></div>
      <div class="cs-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/cibolo-schertz/">Cibolo / Schertz</a> <span>/</span> <span>Homes for Sale</span>
        </nav>
        <h1>Homes for <span style="color:#FF1616;">Sale</span></h1>
        <p>Browse current listings in Cibolo, Schertz, and the surrounding area</p>
      </div>
    </div>

    <!-- Intro + Quick Links -->
    <section class="section">
      <div class="container">
        <p class="cs-page-intro">Use the search below to browse active listings in Cibolo and Schertz. You can filter by location, property type, price range, and more. If you'd like a curated list based on your specific criteria, reach out and I'll put one together for you.</p>

        <div class="cs-quick-links">
          <h3>Quick Links</h3>
          <div class="cs-quick-links__grid">
            <a href="/cibolo-schertz/neighborhoods/">Browse by Neighborhood</a>
            <a href="/cibolo-schertz/restaurants/">Local Restaurants</a>
            <a href="/cibolo-schertz/things-to-do/">Things to Do</a>
          </div>
        </div>
      </div>
    </section>

    <!-- IDX Search -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>Search <span class="accent">All Listings</span></h2>
        </div>
        <div class="idx-embed">
          <iframe
            src="https://codyposey.popbyrealty.com/embed.php"
            allowtransparency="true"
            frameBorder="0"
            title="Cibolo Schertz Property Search"
          ></iframe>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" style="background: #000; color: #fff; text-align: center;">
      <div class="container">
        <h2>Want a <span class="accent">Custom List</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Tell me what you're looking for — price range, area, must-haves — and I'll send you a personalized list of homes that match.</p>
        <a href="#contact" class="btn btn-primary">Request a Custom List</a>
      </div>
    </section>

  </main>
  <ContactForm context="I'd like a custom list of homes in Cibolo/Schertz..." />
  <Footer />
</Layout>

<style>
  .cs-hero {
    position: relative;
    height: 280px;
    background: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .cs-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #000 0%, #1a0000 100%);
    opacity: 0.9;
  }

  .cs-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .cs-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .cs-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #FF1616;
  }

  .breadcrumb span {
    margin: 0 0.3rem;
  }

  .cs-page-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
    margin-bottom: 2rem;
  }

  /* Quick Links */
  .cs-quick-links h3 {
    font-family: var(--font-heading);
    font-size: 0.9rem;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
    color: var(--gray);
  }

  .cs-quick-links__grid {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .cs-quick-links__grid a {
    color: #FF1616;
    font-weight: 600;
    font-size: 0.9rem;
    transition: opacity 0.2s;
  }

  .cs-quick-links__grid a:hover {
    opacity: 0.7;
  }

  /* IDX Embed */
  .idx-embed {
    background: #fff;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .idx-embed iframe {
    width: 100%;
    height: 800px;
    border: none;
    display: block;
  }
</style>
