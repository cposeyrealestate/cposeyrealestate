---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import ParallaxBanner from '../../components/ParallaxBanner.astro';
import ContactForm from '../../components/ContactForm.astro';
---

<Layout
  title="Best Restaurants in Cibolo & Schertz, TX | Cody Posey Real Estate"
  description="Discover the best restaurants in Cibolo and Schertz, Texas — from upscale American to authentic Thai and Tex-Mex favorites."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="cs-hero">
      <div class="cs-hero__overlay"></div>
      <div class="cs-hero__content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a> <span>/</span> <a href="/cibolo-schertz/">Cibolo / Schertz</a> <span>/</span> <span>Restaurants</span>
        </nav>
        <h1>Cibolo / Schertz <span style="color:#FF1616;">Restaurants</span></h1>
        <p>Local favorites and go-to spots in the area</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="cs-page-intro cs-page-intro--centered">The Cibolo/Schertz dining scene continues to grow alongside the communities themselves. From upscale casual to quick family-friendly spots, here are some of the local favorites worth checking out.</p>
      </div>
    </section>

    <!-- Restaurant List -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="section-title">
          <h2>Where to <span class="accent">Eat</span></h2>
        </div>

        <div class="cs-restaurant__grid">
          <div class="cs-restaurant">
            <div class="cs-restaurant__header">
              <h3>Kindling Texas Kitchen</h3>
              <div class="cs-restaurant__meta">
                <span class="cs-restaurant__cuisine">Texas Heritage</span>
                <span class="cs-restaurant__price">$$$</span>
              </div>
            </div>
            <p>Regional heritage Texas cuisine cooked over wood fire using local ingredients from farms, ranches, and the Gulf Coast. Housed in a restored 115-year-old home, Kindling brings a refined dining experience to downtown Cibolo.</p>
            <a href="https://www.google.com/maps/search/?api=1&query=Kindling+Texas+Kitchen+209+N+Main+St+Cibolo+TX+78108" target="_blank" rel="noopener" class="cs-restaurant__address">209 N Main St, Cibolo, TX 78108</a>
          </div>

          <div class="cs-restaurant">
            <div class="cs-restaurant__header">
              <h3>Mako's On The Creek</h3>
              <div class="cs-restaurant__meta">
                <span class="cs-restaurant__cuisine">American / Caribbean</span>
                <span class="cs-restaurant__price">$$</span>
              </div>
            </div>
            <p>Family- and veteran-owned restaurant serving elevated American cuisine with Caribbean and Trinidadian influences. A scratch-made, seasonally inspired menu along Cibolo Creek makes this a standout local gem.</p>
            <a href="https://www.google.com/maps/search/?api=1&query=Mako%27s+On+The+Creek+169+Buffalo+Pl+Cibolo+TX+78108" target="_blank" rel="noopener" class="cs-restaurant__address">169 Buffalo Pl, Cibolo, TX 78108</a>
          </div>

          <div class="cs-restaurant">
            <div class="cs-restaurant__header">
              <h3>Harmon's Barbecue</h3>
              <div class="cs-restaurant__meta">
                <span class="cs-restaurant__cuisine">BBQ</span>
                <span class="cs-restaurant__price">$$</span>
              </div>
            </div>
            <p>Authentic Texas barbecue serving brisket, sausage, chicken, pork, turkey, and classic sides. A no-frills spot on Main Street that lets the slow-smoked meat do the talking.</p>
            <a href="https://www.google.com/maps/search/?api=1&query=Harmon%27s+Barbecue+102+S+Main+St+Cibolo+TX+78108" target="_blank" rel="noopener" class="cs-restaurant__address">102 S Main St, Cibolo, TX 78108</a>
          </div>

          <div class="cs-restaurant">
            <div class="cs-restaurant__header">
              <h3>The Rooted Fork</h3>
              <div class="cs-restaurant__meta">
                <span class="cs-restaurant__cuisine">Brunch / American</span>
                <span class="cs-restaurant__price">$$</span>
              </div>
            </div>
            <p>Modern breakfast and brunch spot serving dishes like biscuits and gravy, pancakes, eggs Benedict, and sandwiches with a twist on comfort-food traditions. A go-to for weekend mornings in Cibolo.</p>
            <a href="https://www.google.com/maps/search/?api=1&query=The+Rooted+Fork+201+N+Main+St+Cibolo+TX+78108" target="_blank" rel="noopener" class="cs-restaurant__address">201 N Main St, Cibolo, TX 78108</a>
          </div>

          <div class="cs-restaurant">
            <div class="cs-restaurant__header">
              <h3>The Magnolia Pancake Haus</h3>
              <div class="cs-restaurant__meta">
                <span class="cs-restaurant__cuisine">Breakfast / Brunch</span>
                <span class="cs-restaurant__price">$$</span>
              </div>
            </div>
            <p>Beloved breakfast and brunch restaurant famous for its fluffy pancakes — especially the Banana Foster — waffles, and classic American breakfast plates. A San Antonio-area institution with a Schertz location.</p>
            <a href="https://www.google.com/maps/search/?api=1&query=The+Magnolia+Pancake+Haus+17730+I-35+N+Schertz+TX+78154" target="_blank" rel="noopener" class="cs-restaurant__address">17730 I-35 N, Schertz, TX 78154</a>
          </div>

          <div class="cs-restaurant">
            <div class="cs-restaurant__header">
              <h3>Garcia's Mexican Restaurant</h3>
              <div class="cs-restaurant__meta">
                <span class="cs-restaurant__cuisine">Tex-Mex</span>
                <span class="cs-restaurant__price">$</span>
              </div>
            </div>
            <p>Traditional Tex-Mex and Mexican food including enchiladas, tacos, fajitas, and breakfast plates. A longtime local favorite that's been serving the Schertz community for years.</p>
            <a href="https://www.google.com/maps/search/?api=1&query=Garcia%27s+Mexican+Restaurant+3820+FM+3009+Schertz+TX+78154" target="_blank" rel="noopener" class="cs-restaurant__address">3820 FM 3009, Schertz, TX 78154</a>
          </div>

          <div class="cs-restaurant">
            <div class="cs-restaurant__header">
              <h3>Abel's Diner</h3>
              <div class="cs-restaurant__meta">
                <span class="cs-restaurant__cuisine">American Diner</span>
                <span class="cs-restaurant__price">$</span>
              </div>
            </div>
            <p>Classic American diner established in 1991 serving homestyle breakfasts, chicken fried steak, burgers, and Tex-Mex favorites like migas. A Schertz staple for comfort food.</p>
            <a href="https://www.google.com/maps/search/?api=1&query=Abel%27s+Diner+17327+N+Interstate+35+Frontage+Rd+Schertz+TX+78154" target="_blank" rel="noopener" class="cs-restaurant__address">17327 N I-35 Frontage Rd #200, Schertz, TX 78154</a>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="section" style="background: #000; color: #fff; text-align: center;">
      <div class="container">
        <h2>Thinking About <span class="accent">Moving Here</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Great food is just the start. Let me help you find the right home in the Cibolo/Schertz area so you can enjoy these spots as a local.</p>
        <div class="cs-cta__buttons">
          <a href="/search" class="btn btn-primary">Search Homes</a>
          <a href="#contact" class="btn btn-outline">Ask About the Area</a>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/cibolo-schertz-home.png" />

  <ContactForm context="I'd like to learn more about living in Cibolo/Schertz..." />
  <Footer />
</Layout>

<style>
  .cs-hero {
    position: relative;
    height: 280px;
    background: url('/images/generated/cibolo-schertz-home.png') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .cs-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.55);
  }

  .cs-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .cs-hero__content h1 {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .cs-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 0.95rem;
  }

  .breadcrumb {
    font-size: 0.8rem;
    margin-bottom: 1rem;
    color: rgba(255,255,255,0.5);
  }

  .breadcrumb a {
    color: rgba(255,255,255,0.5);
    transition: color 0.2s;
  }

  .breadcrumb a:hover {
    color: #FF1616;
  }

  .breadcrumb span {
    margin: 0 0.3rem;
  }

  .cs-page-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 800px;
  }

  .cs-page-intro--centered {
    text-align: center;
    font-weight: 700;
    color: var(--black);
    margin: 0 auto;
  }

  /* Restaurant Grid */
  .cs-restaurant__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .cs-restaurant {
    background: #fff;
    padding: 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .cs-restaurant__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .cs-restaurant__header h3 {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    text-transform: uppercase;
  }

  .cs-restaurant__meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .cs-restaurant__cuisine {
    display: inline-block;
    background: var(--light-gray);
    color: var(--gray);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .cs-restaurant__price {
    display: inline-block;
    background: #FF1616;
    color: #fff;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }

  .cs-restaurant p {
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 0.5rem;
  }

  .cs-restaurant__address {
    display: block;
    font-size: 0.82rem;
    color: #FF1616;
    transition: opacity 0.2s;
  }

  .cs-restaurant__address:hover {
    opacity: 0.7;
  }

  /* CTA */
  .cs-cta__buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .cs-restaurant__grid {
      grid-template-columns: 1fr;
    }

    .cs-restaurant__header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
