const REVIEWS_PER_PAGE = 6;
const totalPages = Math.ceil(testimonials.length / REVIEWS_PER_PAGE);
---

<Layout
  title="Testimonials | Cody Posey Real Estate | New Braunfels, TX"
  description="Read what clients say about working with Cody Posey — a New Braunfels REALTOR dedicated to educating, serving, and delivering results. 5.0 stars from 29 Google Reviews."
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="testi-hero">
      <div class="testi-hero__overlay"></div>
      <div class="testi-hero__content">
        <h1>Testimonials</h1>
      </div>
    </div>

    <!-- Reviews with Pagination -->
    <section class="testi-section">
      <div class="container">
        <div class="testi-list" id="testiList">
          {testimonials.map((t, i) => (
            <div class="testi-item" data-review-index={i} style={i >= REVIEWS_PER_PAGE ? 'display:none;' : ''}>
              <div class="testi-item__icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="#fff">
                  <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                </svg>
              </div>
              <blockquote class="testi-item__quote">&ldquo;{t.quote}&rdquo;</blockquote>
              <button class="testi-item__readmore" aria-expanded="false">READ MORE &#9662;</button>
              <div class="testi-item__name">&mdash; {t.name.toUpperCase()}</div>
            </div>
          ))}
        </div>

        <!-- Pagination -->
        <div class="testi-pagination" id="testiPagination">
          {Array.from({ length: totalPages }, (_, i) => (
            <button
              class={`testi-pagination__btn ${i === 0 ? 'testi-pagination__btn--active' : ''}`}
              data-page={i}
            >
              {i + 1}
            </button>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="testi-cta">
      <div class="testi-cta__overlay"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <h2>Ready to Get <span class="accent">Started</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Whether you're buying, selling, or just have questions about the New Braunfels market &mdash; I'm here to help.</p>
        <a href="#contact" class="btn btn-outline">Let's Connect</a>
      </div>
    </section>

  </main>
  <ContactForm context="I'd like to work with Cody..." />
  <Footer />
</Layout>

<style>
  /* Hero */
  .testi-hero {
    position: relative;
    height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
    overflow: hidden;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .testi-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
  }

  .testi-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .testi-hero__content h1 {
    font-family: 'Georgia', 'Times New Roman', serif;
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  /* Testimonials Section */
  .testi-section {
    background: #fff;
    padding: 4rem 0;
  }

  .testi-list {
    max-width: 700px;
    margin: 0 auto;
  }

  .testi-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 3rem 1.5rem;
    border-bottom: 1px solid #e0e0e0;
  }

  .testi-item:last-child {
    border-bottom: none;
  }

  /* Red quote circle */
  .testi-item__icon {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: #FF1616;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 2rem;
  }

  /* Quote text — collapsed by default, show first 200 chars */
  .testi-item__quote {
    font-size: 1rem;
    color: #333;
    line-height: 1.8;
    font-style: normal;
    max-width: 650px;
    overflow: hidden;
    max-height: 5.4em;
    transition: max-height 0.4s ease;
  }

  .testi-item.expanded .testi-item__quote {
    max-height: 1000px;
  }

  /* Read More button */
  .testi-item__readmore {
    background: none;
    border: none;
    border-bottom: 1px solid #333;
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #333;
    cursor: pointer;
    margin-top: 1rem;
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .testi-item__readmore:hover {
    color: #FF1616;
    border-color: #FF1616;
  }

  .testi-item.expanded .testi-item__readmore {
    display: none;
  }

  /* Reviewer name */
  .testi-item__name {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #333;
    margin-top: 1.5rem;
  }

  /* Pagination */
  .testi-pagination {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #e0e0e0;
  }

  .testi-pagination__btn {
    width: 40px;
    height: 40px;
    border: 2px solid #e0e0e0;
    border-radius: 50%;
    background: #fff;
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.2s;
    color: #333;
  }

  .testi-pagination__btn:hover {
    border-color: #FF1616;
    color: #FF1616;
  }

  .testi-pagination__btn--active {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }

  .testi-pagination__btn--active:hover {
    color: #fff;
  }

  /* CTA Parallax */
  .testi-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/testimonials-hero.jpg');
    background-size: cover;
    background-position: center bottom;
    background-attachment: fixed;
    background-color: #333;
  }

  .testi-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
  }

  .testi-cta h2 {
    color: #fff;
  }

  @media (max-width: 600px) {
    .testi-cta {
      background-attachment: scroll;
    }

    .testi-item__icon {
      width: 80px;
      height: 80px;
    }

    .testi-item__icon svg {
      width: 32px;
      height: 32px;
    }

    .testi-hero {
      height: 280px;
    }
  }
</style>

<script is:inline>
  const REVIEWS_PER_PAGE = 6;
  const items = document.querySelectorAll('.testi-item');
  const buttons = document.querySelectorAll('.testi-pagination__btn');

  function showPage(pageIndex) {
    const start = pageIndex * REVIEWS_PER_PAGE;
    const end = start + REVIEWS_PER_PAGE;

    items.forEach((item, i) => {
      if (i >= start && i < end) {
        item.style.display = 'flex';
        item.classList.remove('expanded');
      } else {
        item.style.display = 'none';
      }
    });

    buttons.forEach(btn => {
      const active = parseInt(btn.dataset.page) === pageIndex;
      btn.classList.toggle('testi-pagination__btn--active', active);
    });

    document.querySelector('.testi-section')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Read More toggle
  document.querySelectorAll('.testi-item__readmore').forEach(btn => {
    btn.addEventListener('click', () => {
      btn.closest('.testi-item')?.classList.add('expanded');
    });
  });

  // Pagination
  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      showPage(parseInt(btn.dataset.page));
    });
  });
</script>
