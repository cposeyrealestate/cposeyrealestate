---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';
import { articleSchema, breadcrumbSchema } from '../lib/schema';

const pageTitle = 'Client Testimonials | Cody Posey Real Estate | New Braunfels, TX';
const pageDescription = 'Real client reviews for Cody Posey, a New Braunfels, TX REALTOR dedicated to educating, serving, and delivering results — 5.0 stars from Google Reviews.';
const pageSchema = [
  articleSchema({ title: pageTitle, description: pageDescription, url: '/testimonials' }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Testimonials', url: '/testimonials' },
  ]),
];

const testimonials = [
  {
    name: 'Brian Tilton',
    role: 'Home Buyer',
    quote: "I recently worked with Cody on a home purchase that just closed, and I can confidently say he stands out as one of the best agents I've partnered with in my 30+ years in the mortgage industry. Having spent much of that time in executive roles overseeing large mortgage operations, and now as the owner of a mortgage company, I've seen firsthand what separates good agents from truly exceptional ones — and Cody is definitely in the latter category. He consistently demonstrated genuine care for his clients, always making decisions based on their best interests rather than just getting the deal done. His communication throughout the process was excellent — clear, proactive, and timely — which made navigating this purchase far smoother than it could have been. This transaction did present some challenges along the way, but instead of becoming reactionary, Cody approached every issue thoughtfully and strategically. Working together, we were able to collaborate on effective solutions and ultimately get the homebuyers into their dream home. I strongly recommend Cody to anyone seeking a knowledgeable real estate professional with true integrity. He's someone you can trust to guide you through even the most complex transactions.",
    initials: 'BT',
    date: '6 weeks ago',
  },
  {
    name: 'David Goad',
    role: 'Verified Client',
    quote: 'Cody is exceptional at his craft. He is also very in tune with technology and his local market. If you are looking to buy and sell and he is in your area I highly recommend giving him a call.',
    initials: 'DG',
    date: '10 weeks ago',
  },
  {
    name: 'Michelle Maloney',
    role: 'Google Local Guide',
    quote: "Cody Posey is the most knowledgeable real estate agent in Texas! His knowledge of the market is top notch, but beyond that he knows how to market your home to buyers to get it SOLD! As a US Veteran, he has a servant heart matched only by his precision and attention to detail, which are the qualities I look for and admire in a realtor. I can't recommend Cody enough!! I wish I could give him 10 stars!",
    initials: 'MM',
    date: '11 weeks ago',
  },
  {
    name: 'Kori Dvorak',
    role: 'Home Buyer',
    quote: 'We really enjoyed working with Cody! He was personable, knowledgeable, and to the point. He was honest and realistic about the market while also staying positive. Would definitely recommend!',
