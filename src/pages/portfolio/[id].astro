---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import data from '../../data/portfolio.json';
import { listingSchema, breadcrumbSchema } from '../../lib/schema';

export function getStaticPaths() {
  const internal = (data.currentListings as any[]).filter(
    (l) => l.source === 'internal',
  );
  return internal.map((l) => ({
    params: { id: l.slug },
    props: { listing: l },
  }));
}

interface Listing {
  slug: string;
  mlsId?: string;
  status: string;
  price: string;
  address: string;
  city: string;
  beds?: number;
  baths?: number;
  sqft?: string;
  acres?: string;
  yearBuilt?: number;
  propertyType?: string;
  youtubeId?: string;
  img: string;
  gallery?: string[];
  description?: string;
  features?: Record<string, string[]>;
}

const { listing } = Astro.props as { listing: Listing };

// Gallery defaults to [hero] if none supplied
const photos = listing.gallery && listing.gallery.length > 0 ? listing.gallery : [listing.img];

// Schema.org RealEstateListing + breadcrumb
const pageUrl = `/portfolio/${listing.slug}`;
const pageSchema = [
  listingSchema({ ...listing, url: pageUrl }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: 'Portfolio', url: '/portfolio' },
    { name: listing.address, url: pageUrl },
  ]),
];

// Meta description: either the provided description (truncated to 155)
// or a concise auto-generated fallback.
const metaDescription = (
  listing.description
  || `${listing.propertyType || 'Home'} at ${listing.address}, ${listing.city}. ${listing.acres ? listing.acres + ' acres. ' : ''}Listed by Cody Posey, REALTOR®.`
).replace(/\s+/g, ' ').trim().slice(0, 155);

const featureGroups = listing.features ? Object.entries(listing.features) : [];
---

<Layout
  title={`${listing.address} | ${listing.city}`}
  description={metaDescription}
  image={listing.img}
  schema={pageSchema}
>
  <Navbar />

  <main class="detail">
    <a href="/portfolio" class="detail__back">← Back to Portfolio</a>

    <!-- Hero gallery -->
    <section class="detail__gallery">
      <div class="swiper detail-swiper">
        <div class="swiper-wrapper">
          {photos.map((src, i) => (
            <div class="swiper-slide">
              <img
                src={src}
                alt={`${listing.address} — photo ${i + 1}`}
                class="detail__photo"
                loading={i === 0 ? 'eager' : 'lazy'}
                fetchpriority={i === 0 ? 'high' : 'auto'}
              />
            </div>
          ))}
        </div>
        <div class="swiper-button-next"></div>
        <div class="swiper-button-prev"></div>
        <div class="swiper-pagination"></div>
        {photos.length > 1 && (
          <div class="detail__photo-count">
            <span class="detail__photo-current">1</span> / {photos.length}
          </div>
        )}
      </div>
    </section>

    <!-- Header block -->
    <section class="detail__header">
      <div class="container">
        <div class="detail__header-grid">
          <div>
            <span class={`detail__status ${listing.status.toLowerCase()}`}>{listing.status}</span>
            <h1 class="detail__price">{listing.price}</h1>
            <div class="detail__address">{listing.address}</div>
            <div class="detail__city">{listing.city}</div>
            {listing.mlsId && (
              <div class="detail__mls">MLS #{listing.mlsId}</div>
            )}
          </div>
          <div class="detail__specs">
            {listing.beds && (
              <div class="spec">
                <div class="spec__value">{listing.beds}</div>
                <div class="spec__label">Beds</div>
              </div>
            )}
            {listing.baths && (
              <div class="spec">
                <div class="spec__value">{listing.baths}</div>
                <div class="spec__label">Baths</div>
              </div>
            )}
            {listing.sqft && (
              <div class="spec">
                <div class="spec__value">{listing.sqft}</div>
                <div class="spec__label">Sqft</div>
              </div>
            )}
            {listing.acres && (
              <div class="spec">
                <div class="spec__value">{listing.acres}</div>
                <div class="spec__label">Acres</div>
              </div>
            )}
            {listing.yearBuilt && (
              <div class="spec">
                <div class="spec__value">{listing.yearBuilt}</div>
                <div class="spec__label">Year</div>
              </div>
            )}
            {listing.propertyType && (
              <div class="spec">
                <div class="spec__value spec__value--small">{listing.propertyType}</div>
                <div class="spec__label">Type</div>
              </div>
            )}
          </div>
        </div>
      </div>
    </section>

    <!-- Video tour -->
    {listing.youtubeId && (
      <section class="detail__video">
        <div class="container">
          <div class="detail__video-header">
            <span class="detail__video-eyebrow">Video Tour</span>
            <h2 class="detail__h2">See the property in motion</h2>
          </div>
          <div class="detail__video-frame">
            <iframe
              src={`https://www.youtube-nocookie.com/embed/${listing.youtubeId}?rel=0&modestbranding=1`}
              title={`Video tour of ${listing.address}`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              referrerpolicy="strict-origin-when-cross-origin"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>
        </div>
      </section>
    )}

    <!-- Description -->
    {listing.description && (
      <section class="detail__section">
        <div class="container">
          <h2 class="detail__h2">About This Property</h2>
          <p class="detail__description">{listing.description}</p>
        </div>
      </section>
    )}

    <!-- Features & amenities -->
    {featureGroups.length > 0 && (
      <section class="detail__section detail__section--alt">
        <div class="container">
          <h2 class="detail__h2">Features &amp; Amenities</h2>
          <div class="detail__features-grid">
            {featureGroups.map(([groupName, items]) => (
              <div class="feature-group">
                <h3 class="feature-group__title">{groupName}</h3>
                <ul class="feature-group__list">
                  {items.map((item) => (
                    <li class="feature-group__item">{item}</li>
                  ))}
                </ul>
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- Contact CTA -->
    <section class="detail__cta">
      <div class="container">
        <h2>Interested in this property?</h2>
        <p>Reach out — I'll walk you through a showing or answer any questions.</p>
        <div class="detail__cta-buttons">
          <a href="tel:+18303605569" class="btn btn-primary">Call (830) 360-5569</a>
          <a href={`mailto:codyposey@cposeyrealestate.com?subject=${encodeURIComponent('Inquiry about ' + listing.address)}`} class="btn btn-outline-light">Email Cody</a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .detail {
    padding-top: 76px;
    background: #fafafa;
  }

  .detail__back {
    display: inline-block;
    max-width: 1200px;
    margin: 1rem auto 0.5rem;
    padding: 0 1.5rem;
    color: #555;
    font-size: 0.85rem;
    text-decoration: none;
  }
  .detail__back:hover { color: #FF1616; }
  @media (min-width: 768px) {
    .detail__back { display: block; }
  }

  /* Gallery */
  .detail__gallery {
    background: #000;
    max-width: 1200px;
    margin: 0.5rem auto 0;
    padding: 0 1.5rem;
  }
  .detail-swiper {
    aspect-ratio: 16 / 9;
    max-height: 620px;
    background: #000;
    position: relative;
  }
  .detail__photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .detail__photo-count {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    padding: 0.4rem 0.8rem;
    background: rgba(0, 0, 0, 0.7);
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    z-index: 10;
    border-radius: 2px;
    pointer-events: none;
  }

  /* Header */
  .detail__header {
    background: #fff;
    padding: 2rem 0;
  }
  .detail__header-grid {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    align-items: center;
  }
  @media (max-width: 720px) {
    .detail__header-grid { grid-template-columns: 1fr; }
  }

  .detail__status {
    display: inline-block;
    padding: 0.3rem 0.8rem;
    background: #FF1616;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 0.8rem;
  }
  .detail__status.pending { background: #e07b00; }
  .detail__status.sold { background: #111; }

  .detail__price {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(2rem, 4vw, 2.75rem);
    color: #FF1616;
    margin: 0 0 0.25rem;
    line-height: 1;
  }
  .detail__address {
    font-weight: 600;
    font-size: 1.1rem;
    margin-bottom: 0.2rem;
  }
  .detail__city {
    color: #777;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }
  .detail__mls {
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 0.12em;
  }

  .detail__specs {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .spec { text-align: center; min-width: 60px; }
  .spec__value {
    font-family: 'Poppins', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #111;
    line-height: 1;
  }
  .spec__value--small { font-size: 0.9rem; line-height: 1.3; }
  .spec__label {
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    color: #777;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.25rem;
  }

  /* Video */
  .detail__video {
    background: #111;
    padding: 3.5rem 0 4rem;
  }
  .detail__video-header {
    text-align: center;
    margin-bottom: 2rem;
  }
  .detail__video-eyebrow {
    display: inline-block;
    font-family: 'Poppins', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    color: #FF1616;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 0.6rem;
  }
  .detail__video h2 {
    color: #fff;
    margin: 0;
  }
  .detail__video-frame {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    aspect-ratio: 16 / 9;
    background: #000;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    overflow: hidden;
  }
  .detail__video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /* Section */
  .detail__section {
    padding: 3rem 0;
    background: #f5f5f5;
  }
  .detail__section--alt {
    background: #fff;
  }
  .detail__h2 {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1.3rem, 2.3vw, 1.6rem);
    margin-bottom: 1rem;
    color: #111;
  }
  .detail__description {
    font-size: 1rem;
    line-height: 1.75;
    color: #333;
    max-width: 820px;
  }

  /* Features grid */
  .detail__features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    margin-top: 1.5rem;
  }
  .feature-group {
    padding: 1.5rem;
    background: #fafafa;
    border-top: 3px solid #FF1616;
  }
  .feature-group__title {
    font-family: 'Poppins', sans-serif;
    font-size: 0.85rem;
    font-weight: 700;
    color: #111;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0 0 1rem;
  }
  .feature-group__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .feature-group__item {
    position: relative;
    padding: 0.35rem 0 0.35rem 1.2rem;
    font-size: 0.92rem;
    line-height: 1.5;
    color: #333;
    border-bottom: 1px solid #eee;
  }
  .feature-group__item:last-child { border-bottom: 0; }
  .feature-group__item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85rem;
    width: 6px;
    height: 6px;
    background: #FF1616;
    border-radius: 50%;
  }

  /* CTA */
  .detail__cta {
    background: #000;
    color: #fff;
    padding: 4rem 0;
    text-align: center;
  }
  .detail__cta h2 {
    color: #fff;
    font-size: clamp(1.4rem, 2.5vw, 1.9rem);
    margin-bottom: 0.5rem;
  }
  .detail__cta p {
    color: rgba(255, 255, 255, 0.75);
    margin-bottom: 2rem;
  }
  .detail__cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>

<script>
  import Swiper from 'swiper/bundle';
  const swiper = new Swiper('.detail-swiper', {
    slidesPerView: 1,
    loop: true,
    speed: 500,
    autoplay: {
      delay: 5000,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    navigation: {
      nextEl: '.detail-swiper .swiper-button-next',
      prevEl: '.detail-swiper .swiper-button-prev',
    },
    pagination: {
      el: '.detail-swiper .swiper-pagination',
      clickable: true,
    },
    keyboard: { enabled: true },
  });

  // Live photo counter ("3 / 49")
  const counter = document.querySelector('.detail__photo-current');
  if (counter) {
    swiper.on('slideChange', () => {
      counter.textContent = String(swiper.realIndex + 1);
    });
  }
</script>
