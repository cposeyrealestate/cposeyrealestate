---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
import ParallaxBanner from '../components/ParallaxBanner.astro';
import { collectionPageSchema, breadcrumbSchema } from '../lib/schema';

const sections = [
  {
    title: 'Preparing Your Home for Sale',
    description: 'A comprehensive guide to getting your home market-ready — from curb appeal to interior staging and system checks.',
    href: '/sellers-guide/preparing-for-sale',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>`,
  },
  {
    title: 'Preparing for Photographs',
    description: 'Tips to make your home look its best for listing photos — the first impression most buyers will have of your property.',
    href: '/sellers-guide/preparing-for-photos',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>`,
  },
  {
    title: '10 Ways to Prepare for Inspection',
    description: 'Simple steps to help your home inspection go smoothly and avoid unnecessary delays or surprises.',
    href: '/sellers-guide/inspection-prep',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14,2 14,8 20,8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  },
  {
    title: 'Home Sale Checklist',
    description: 'A room-by-room checklist to evaluate your home\'s condition before listing — identify what needs attention.',
    href: '/sellers-guide/sale-checklist',
    icon: `<svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>`,
  },
];

const pageTitle = "Seller's Guide | Preparing Your Home for Sale | Cody Posey";
const pageDescription = 'The complete guide to selling a home in New Braunfels and the Texas Hill Country — prep your home for sale, photography, inspection, and a room-by-room checklist.';
const pageSchema = [
  collectionPageSchema({
    name: "Texas Hill Country Seller's Guide",
    description: pageDescription,
    url: '/sellers-guide',
    hasPart: [
      { name: 'Preparing Your Home for Sale', url: '/sellers-guide/preparing-for-sale' },
      { name: 'Preparing for Photographs', url: '/sellers-guide/preparing-for-photos' },
      { name: '10 Ways to Prepare for Inspection', url: '/sellers-guide/inspection-prep' },
      { name: 'Home Sale Checklist', url: '/sellers-guide/sale-checklist' },
    ],
  }),
  breadcrumbSchema([
    { name: 'Home', url: '/' },
    { name: "Seller's Guide", url: '/sellers-guide' },
  ]),
];
---

<Layout
  title={pageTitle}
  description={pageDescription}
  schema={pageSchema}
>
  <Navbar />
  <main style="padding-top: 80px;">

    <!-- Hero -->
    <div class="sg-hero">
      <div class="sg-hero__overlay"></div>
      <div class="sg-hero__content">
        <h1>Seller's <span style="color:#FF1616;">Guide</span></h1>
        <p>Everything you need to know to prepare your home for a successful sale in the Texas Hill Country</p>
      </div>
    </div>

    <!-- Intro -->
    <section class="section">
      <div class="container">
        <p class="sg-intro">Selling your home is a major decision, and preparation makes all the difference. From maximizing curb appeal to acing the inspection, these guides will help you get the most value from your home and ensure a smooth transaction from listing to closing.</p>

        <div class="sg-body">
          <p>As a New Braunfels REALTOR and retired Army First Sergeant, I have seen firsthand how proper planning can make or break a home sale. Whether you are selling a starter home in a subdivision along the I-35 corridor or a custom build on acreage in the Hill Country, the fundamentals remain the same: present your home in its best light, price it correctly, and stay ahead of potential issues before they become deal-breakers.</p>

          <p>The Texas Hill Country market moves quickly when a property is priced right and shows well. Buyers today start their search online, which means your listing photos are your first showing. From there, the in-person experience needs to match or exceed what they saw on screen. That is why I put together these detailed guides — to walk you through every stage of the selling process so you feel confident and prepared.</p>

          <h2>What Makes a Successful Home Sale</h2>
          <p>A successful home sale is not just about putting a sign in the yard. It starts weeks or even months before listing day. Homes that sell faster and for more money share a few common traits: they are clean, decluttered, well-maintained, and priced based on real comparable data — not wishful thinking. Sellers who invest time in preparation almost always see a return on that effort.</p>

          <p>The New Braunfels area attracts a wide range of buyers — military families relocating to Joint Base San Antonio, remote workers moving from Austin for a lower cost of living, retirees looking for Hill Country views, and first-time buyers entering the market. Each group has different priorities, but all of them respond to a well-prepared home.</p>

          <h2>How These Guides Help</h2>
          <p>I have organized my seller resources into four focused guides, each covering a critical phase of the selling process. The Preparing Your Home for Sale guide covers everything from curb appeal to interior staging and systems checks. The Preparing for Photographs guide ensures your listing photos make the strongest possible first impression. The Inspection Prep guide helps you avoid surprises and delays during the buyer's inspection. And the Home Sale Checklist provides a room-by-room evaluation so you can identify what needs attention before you list.</p>

          <p>These guides are based on real experience working with sellers in New Braunfels, Canyon Lake, Seguin, Bulverde, and the surrounding Hill Country communities. The advice is practical and specific to this market — not generic tips pulled from a national template. If you have questions about any of these topics or want personalized guidance for your situation, reach out anytime.</p>
        </div>
      </div>
    </section>

    <!-- Section Cards -->
    <section class="section" style="background: var(--light-gray);">
      <div class="container">
        <div class="sg-cards">
          {sections.map((s) => (
            <a href={s.href} class="sg-card">
              <div class="sg-card__icon" set:html={s.icon} />
              <h3>{s.title}</h3>
              <p>{s.description}</p>
              <span class="sg-card__link">Learn More &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="sg-cta">
      <div class="sg-cta__overlay"></div>
      <div class="container" style="position: relative; z-index: 1;">
        <h2>Thinking About <span class="accent">Selling</span>?</h2>
        <p style="color: rgba(255,255,255,0.7); max-width: 600px; margin: 1rem auto 2rem;">Whether you're ready to list or just exploring your options, I'll help you understand your home's value and create a strategy to get the best results.</p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a href="/home-value" class="btn btn-primary">Get Your Home Value</a>
          <a href="#contact" class="btn btn-outline">Let's Connect</a>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <h2>Frequently Asked Questions About Selling a Home</h2>
        <div class="faq-list">
          <details class="faq-item">
            <summary>How long does it take to sell a home in New Braunfels?</summary>
            <p>The timeline varies depending on the price range, location, condition, and current market conditions. Well-prepared homes priced correctly often receive offers within the first two weeks on market. From contract to closing, the process typically takes 30 to 45 days. Homes that need repairs or are overpriced can sit much longer. I can provide a market analysis specific to your property to give you a realistic estimate.</p>
          </details>
          <details class="faq-item">
            <summary>What should I fix before listing my home?</summary>
            <p>Focus on the items that buyers and inspectors will notice first: cosmetic issues like scuffed walls and worn carpet, functional problems like leaky faucets or burned-out bulbs, and safety items like smoke detectors and handrails. Not every repair needs to be made before listing, but addressing obvious issues signals to buyers that the home has been maintained. I can walk through your home and help you prioritize the repairs that will have the biggest impact.</p>
          </details>
          <details class="faq-item">
            <summary>Do I need to stage my home before selling?</summary>
            <p>Staging is not always necessary, but presenting your home in a clean, decluttered, and neutral way is essential. At a minimum, remove personal items, clear countertops, and ensure every room has a clear purpose. Professional staging can help in higher price points or when a home has been sitting on the market. The goal is to help buyers envision themselves living in the space.</p>
          </details>
        </div>
      </div>
    </section>

  </main>
  <ParallaxBanner image="/images/generated/comal-river.png" />

  <ContactForm context="I'm thinking about selling my home in the New Braunfels area..." />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "How long does it take to sell a home in New Braunfels?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The timeline varies depending on the price range, location, condition, and current market conditions. Well-prepared homes priced correctly often receive offers within the first two weeks on market. From contract to closing, the process typically takes 30 to 45 days."
        }
      },
      {
        "@type": "Question",
        "name": "What should I fix before listing my home?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Focus on the items that buyers and inspectors will notice first: cosmetic issues like scuffed walls and worn carpet, functional problems like leaky faucets or burned-out bulbs, and safety items like smoke detectors and handrails. Not every repair needs to be made before listing, but addressing obvious issues signals to buyers that the home has been maintained."
        }
      },
      {
        "@type": "Question",
        "name": "Do I need to stage my home before selling?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Staging is not always necessary, but presenting your home in a clean, decluttered, and neutral way is essential. At a minimum, remove personal items, clear countertops, and ensure every room has a clear purpose. Professional staging can help in higher price points or when a home has been sitting on the market."
        }
      }
    ]
  }
  </script>
  <Footer />
</Layout>

<style>
  .sg-hero {
    position: relative;
    height: 320px;
    background: url('/images/generated/sellers-guide-hero.jpg') center/cover no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #fff;
  }

  .sg-hero__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
  }

  .sg-hero__content {
    position: relative;
    z-index: 1;
    padding: 0 1.5rem;
  }

  .sg-hero__content h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    margin-bottom: 0.75rem;
  }

  .sg-hero__content p {
    color: rgba(255,255,255,0.7);
    font-size: 1rem;
    max-width: 550px;
    margin: 0 auto;
  }

  .sg-intro {
    font-size: 1.05rem;
    color: var(--gray);
    line-height: 1.8;
    max-width: 750px;
    text-align: center;
    margin: 0 auto;
    font-weight: 600;
  }

  .sg-cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .sg-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    padding: 2.5rem 2rem;
    border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
    transition: transform 0.2s, box-shadow 0.2s;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }

  .sg-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.12);
  }

  .sg-card__icon {
    margin: 0 auto 1.25rem;
  }

  .sg-card h3 {
    font-family: var(--font-heading);
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.75rem;
    color: #000;
  }

  .sg-card p {
    color: var(--gray);
    font-size: 0.9rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .sg-card__link {
    display: inline-block;
    margin-top: 1.25rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #FF1616;
    transition: letter-spacing 0.2s;
  }

  .sg-card:hover .sg-card__link {
    letter-spacing: 0.14em;
  }

  .sg-cta {
    position: relative;
    padding: 5rem 0;
    color: #fff;
    text-align: center;
    background-image: url('/images/generated/sellers-guide-hero.jpg');
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    background-color: #333;
  }

  .sg-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
  }

  .sg-cta h2 {
    color: #fff;
  }

  .sg-body {
    max-width: 800px;
    margin: 2rem auto 0;
    text-align: left;
  }

  .sg-body p {
    color: var(--gray);
    line-height: 1.8;
    margin-bottom: 1.25rem;
    font-size: 0.95rem;
  }

  .sg-body h2 {
    font-size: 1.3rem;
    margin: 2rem 0 1rem;
  }

  .faq-section { padding: 4rem 0; background: #f9f9f9; }
  .faq-section h2 { text-align: center; margin-bottom: 2rem; }
  .faq-list { max-width: 800px; margin: 0 auto; }
  .faq-item { background: #fff; border: 1px solid #eee; margin-bottom: 1rem; }
  .faq-item summary { padding: 1.25rem 1.5rem; font-weight: 600; cursor: pointer; font-size: 1rem; list-style: none; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::after { content: '+'; font-size: 1.3rem; color: #FF1616; font-weight: 700; }
  .faq-item[open] summary::after { content: '\2212'; }
  .faq-item p { padding: 0 1.5rem 1.25rem; color: #555; line-height: 1.8; font-size: 0.95rem; }

  @media (max-width: 600px) {
    .sg-cards {
      grid-template-columns: 1fr;
    }

    .sg-cta {
      background-attachment: scroll;
    }
  }
</style>
