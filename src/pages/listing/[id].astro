---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

export const prerender = true;

let allListings = [];
try {
  const data = await import('../../data/idx-all-listings.json');
  allListings = data.default || data;
} catch {}

export async function getStaticPaths() {
  let listings = [];
  try {
    const data = await import('../../data/idx-all-listings.json');
    listings = data.default || data;
  } catch {}
  return listings.map((l) => ({
    params: { id: l.id },
    props: { listing: l },
  }));
}

const { listing } = Astro.props;

function fullPrice(num) {
  return '$' + num.toLocaleString();
}

function pricePerSqft(price, sqft) {
  if (!sqft || !price) return null;
  return '$' + (price / sqft).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

function estimatePayment(price) {
  if (!price) return null;
  const principal = price * 0.8;
  const r = 0.065 / 12;
  const n = 360;
  const mortgage = principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
  return Math.round(mortgage + (price * 0.0175) / 12 + (price * 0.005) / 12);
}

const photos = listing.photos || (listing.photo ? [listing.photo] : []);
const gridPhotos = photos.slice(0, 4);
const estPayment = estimatePayment(listing.price);
const ppsqft = pricePerSqft(listing.price, listing.sqft);

// Haversine distance in miles
function distanceMiles(lat1: number, lng1: number, lat2: number, lng2: number): number {
  const toRad = (d: number) => d * Math.PI / 180;
  const R = 3958.8;
  const dLat = toRad(lat2 - lat1);
  const dLng = toRad(lng2 - lng1);
  const a = Math.sin(dLat / 2) ** 2 + Math.cos(toRad(lat1)) * Math.cos(toRad(lat2)) * Math.sin(dLng / 2) ** 2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
}

// Similar properties: same zip OR within 2 miles, +/- 20% price
const priceLow = listing.price * 0.80;
const priceHigh = listing.price * 1.20;
const hasCoords = listing.lat !== 0 && listing.lng !== 0;
const similar = allListings
  .filter((l) => {
    if (l.id === listing.id) return false;
    if (l.price < priceLow || l.price > priceHigh) return false;
    const sameZip = l.zip === listing.zip;
    const within2mi = hasCoords && l.lat !== 0 && l.lng !== 0 && distanceMiles(listing.lat, listing.lng, l.lat, l.lng) <= 2;
    return sameZip || within2mi;
  })
  .sort((a, b) => {
    const aDist = hasCoords && a.lat ? distanceMiles(listing.lat, listing.lng, a.lat, a.lng) : 999;
    const bDist = hasCoords && b.lat ? distanceMiles(listing.lat, listing.lng, b.lat, b.lng) : 999;
    return aDist - bDist;
  })
  .slice(0, 12);

const today = new Date();
const disclaimerDate = today.toLocaleString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'UTC' }) + ' UTC, ' + (today.getMonth() + 1) + '/' + today.getDate() + '/' + today.getFullYear();

const pageTitle = `${listing.address}, ${listing.city} ${listing.zip} | Popby Realty`;
const pageDesc = `${listing.propType} for sale — ${listing.beds} bed, ${listing.baths} bath, ${listing.sqft.toLocaleString()} sqft at ${listing.address}, ${listing.city}, TX ${listing.zip}. Listed at ${fullPrice(listing.price)}.`;
---

<Layout title={pageTitle} description={pageDesc}>
  <Navbar />

  <!-- Sub-header: Breadcrumb + Section Tabs -->
  <div class="detail-subheader">
    <div class="detail-subheader__inner">
      <nav class="detail-breadcrumb">
        <a href="/search">Home search</a>
        <span>&gt;</span>
        <span>{listing.address}, {listing.city} {listing.state}, {listing.zip}</span>
      </nav>
      <nav class="detail-tabs">
        <a href="#listing-header" class="detail-tab active">Overview</a>
        <a href="#map" class="detail-tab">Location</a>
        <a href="#features" class="detail-tab">Features</a>
        {similar.length > 0 && <a href="#similar-listings" class="detail-tab">Similar Properties</a>}
      </nav>
    </div>
  </div>

  <main class="detail-page">
    <!-- Photo Grid -->
    <div class="photo-grid" data-photos={JSON.stringify(photos)} data-listing-id={listing.id}>
      {gridPhotos.length >= 4 && (
        <div class="photo-grid__main" data-idx="0">
          <img src={gridPhotos[0]} alt={listing.address} />
        </div>
      )}
      {gridPhotos.length >= 4 && (
        <div class="photo-grid__side">
          <div class="photo-grid__wide" data-idx="1">
            <img src={gridPhotos[1]} alt="" />
          </div>
          <div class="photo-grid__bottom">
            <div class="photo-grid__thumb" data-idx="2"><img src={gridPhotos[2]} alt="" /></div>
            <div class="photo-grid__thumb photo-grid__thumb--last" data-idx="3">
              <img src={gridPhotos[3]} alt="" />
              <button class="photo-grid__all-btn" data-action="open-lightbox">All photos</button>
            </div>
          </div>
        </div>
      )}
      {gridPhotos.length > 0 && gridPhotos.length < 4 && (
        <div class="photo-grid__main photo-grid__main--solo" data-idx="0">
          <img src={gridPhotos[0]} alt={listing.address} />
          {photos.length > 1 && (
            <button class="photo-grid__all-btn photo-grid__all-btn--overlay" data-action="open-lightbox">
              View All {photos.length} Photos
            </button>
          )}
        </div>
      )}
      {gridPhotos.length === 0 && (
        <div class="photo-grid__main photo-grid__main--solo">
          <div class="detail-hero__noimg">No Photo Available</div>
        </div>
      )}
      <div class="photo-grid__actions">
        <button class="photo-grid__action-btn" title="Save Property">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
        <button class="photo-grid__action-btn" title="Share Property">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/></svg>
        </button>
      </div>
    </div>

    <!-- Lightbox -->
    <div class="lightbox" id="lightbox" style="display:none;">
      <div class="lightbox__header">
        <button class="lightbox__close" id="lbClose">Close</button>
        <span class="lightbox__counter" id="lbCounter">1 / 1</span>
      </div>
      <button class="lightbox__nav lightbox__nav--prev" id="lbPrev">&#10094;</button>
      <button class="lightbox__nav lightbox__nav--next" id="lbNext">&#10095;</button>
      <div class="lightbox__img-wrap">
        <img class="lightbox__img" id="lbImg" src="" alt="" />
      </div>
    </div>

    <!-- Main Content: Two-column layout -->
    <div class="detail-content" id="listing-header">
      <div class="detail-main">
        <!-- Quick Stats -->
        <div class="detail-quick-stats">
          {listing.beds > 0 && (
            <span class="detail-quick-stat">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 7v11a2 2 0 002 2h14a2 2 0 002-2V7"/><path d="M3 11h18"/><path d="M7 11V7a2 2 0 012-2h6a2 2 0 012 2v4"/></svg>
              {listing.beds} Beds
            </span>
          )}
          {listing.baths > 0 && (
            <span class="detail-quick-stat">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 12h16a1 1 0 011 1v3a4 4 0 01-4 4H7a4 4 0 01-4-4v-3a1 1 0 011-1z"/><path d="M6 12V5a2 2 0 012-2h1"/></svg>
              {listing.baths} Baths
            </span>
          )}
          {listing.sqft > 0 && (
            <span class="detail-quick-stat">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>
              {listing.sqft.toLocaleString()} sqft
            </span>
          )}
        </div>

        <h1 class="detail-price">{fullPrice(listing.price)}</h1>
        <p class="detail-address">{listing.address} {listing.city} {listing.state}, {listing.zip}</p>

        {estPayment && (
          <div class="detail-est-payment">
            Est. payment: ${estPayment.toLocaleString()}/mo
            <span class="detail-est-payment__info" title="Estimated based on 20% down, 6.5% rate, 30yr fixed, including taxes and insurance">&#9432;</span>
          </div>
        )}

        <!-- Stat Cards -->
        <div class="detail-stats">
          {ppsqft && (
            <div class="detail-stat">
              <svg class="detail-stat__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
              <span class="detail-stat__label">Price per sqft</span>
              <span class="detail-stat__value">{ppsqft}</span>
            </div>
          )}
          {listing.yearBuilt > 0 && (
            <div class="detail-stat">
              <svg class="detail-stat__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span class="detail-stat__label">Built in</span>
              <span class="detail-stat__value">{listing.yearBuilt}</span>
            </div>
          )}
          {listing.sqft > 0 && (
            <div class="detail-stat">
              <svg class="detail-stat__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18"/><path d="M9 3v18"/></svg>
              <span class="detail-stat__label">Property size</span>
              <span class="detail-stat__value">{listing.sqft.toLocaleString()} sqft</span>
            </div>
          )}
          {listing.propType && (
            <div class="detail-stat">
              <svg class="detail-stat__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
              <span class="detail-stat__label">Property type</span>
              <span class="detail-stat__value">{listing.propType}</span>
            </div>
          )}
          {listing.acres > 0 && (
            <div class="detail-stat">
              <svg class="detail-stat__icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
              <span class="detail-stat__label">Lot size</span>
              <span class="detail-stat__value">{listing.acres} acres</span>
            </div>
          )}
        </div>

        <!-- Overview / Description -->
        <section id="description" class="detail-section">
          <h4>Overview</h4>
          <div class="detail-badges">
            <span class="detail-badge detail-badge--active">{listing.status || 'Active'}</span>
            {listing.dateAdded && (
              <span class="detail-badge detail-badge--date">Listed {new Date(listing.dateAdded).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
            )}
          </div>
          {listing.description && (
            <p class="detail-description-text" id="listing-description">{listing.description}</p>
          )}
          {!listing.description && (
            <p class="detail-description-text" id="listing-description" data-placeholder="true">Loading property description...</p>
          )}
        </section>

        <!-- Location / Map -->
        {listing.lat !== 0 && listing.lng !== 0 && (
          <section id="map" class="detail-section">
            <h4>Location</h4>
            <p class="detail-map-address">{listing.address} {listing.city} {listing.state}, {listing.zip}</p>
            <div id="detailMap" class="detail-map"></div>
          </section>
        )}

        <!-- Mortgage Calculator -->
        {estPayment && (
          <section id="mortgage-calculator" class="detail-section">
            <h4>${estPayment.toLocaleString()}/mo</h4>
            <p class="detail-mortgage-sub">Est. mortgage payment based on a {fullPrice(listing.price)} home price.</p>
            <div class="detail-mortgage-breakdown">
              <div class="detail-mortgage-item">
                <span class="detail-mortgage-label">Down payment</span>
                <span class="detail-mortgage-value">{fullPrice(Math.round(listing.price * 0.20))} (20%)</span>
              </div>
              <div class="detail-mortgage-item">
                <span class="detail-mortgage-label">Loan details</span>
                <span class="detail-mortgage-value">30-year fixed, 6.5%</span>
              </div>
              <div class="detail-mortgage-item">
                <span class="detail-mortgage-label">Property tax</span>
                <span class="detail-mortgage-value">{fullPrice(Math.round((listing.price * 0.0175) / 12))}/month</span>
              </div>
              <div class="detail-mortgage-item">
                <span class="detail-mortgage-label">Homeowners insurance</span>
                <span class="detail-mortgage-value">{fullPrice(Math.round((listing.price * 0.005) / 12))}/month</span>
              </div>
            </div>
          </section>
        )}

        <!-- School Information (populated by API) -->
        <section id="schools" class="detail-section" style="display:none;">
          <h4>School Information</h4>
          <dl class="detail-features-dl" id="school-list"></dl>
        </section>

        <!-- Property Details / Features -->
        <section id="features" class="detail-section">
          <h3>Additional information</h3>
          <dl class="detail-features-dl">
            <div class="detail-features-row"><dt>MLS ID</dt><dd>{listing.id}</dd></div>
            <div class="detail-features-row"><dt>Status</dt><dd>{listing.status || 'Active'}</dd></div>
            {listing.county && <div class="detail-features-row"><dt>County</dt><dd>{listing.county}</dd></div>}
            {listing.subdivision && <div class="detail-features-row"><dt>Subdivision</dt><dd>{listing.subdivision}</dd></div>}
            {listing.listingAgent && <div class="detail-features-row"><dt>Listing Agent</dt><dd>{listing.listingAgent}</dd></div>}
            {listing.listingOffice && <div class="detail-features-row"><dt>Listing Office</dt><dd>{listing.listingOffice}</dd></div>}
          </dl>

          <h3>Interior features</h3>
          <dl class="detail-features-dl" id="interior-features">
            {listing.beds > 0 && <div class="detail-features-row"><dt>Bedrooms</dt><dd>{listing.beds}</dd></div>}
            {listing.baths > 0 && <div class="detail-features-row"><dt>Total Bathrooms</dt><dd>{listing.baths}</dd></div>}
            {listing.fullBaths > 0 && <div class="detail-features-row"><dt>Full Bathrooms</dt><dd>{listing.fullBaths}</dd></div>}
            {listing.halfBaths > 0 && <div class="detail-features-row"><dt>Half Bathrooms</dt><dd>{listing.halfBaths}</dd></div>}
            {listing.sqft > 0 && <div class="detail-features-row"><dt>Total Sqft</dt><dd>{listing.sqft.toLocaleString()}</dd></div>}
            {listing.stories > 0 && <div class="detail-features-row"><dt>Stories</dt><dd>{listing.stories}</dd></div>}
            {listing.garage > 0 && <div class="detail-features-row"><dt>Garages</dt><dd>{listing.garage}</dd></div>}
          </dl>

          <h3>Exterior features</h3>
          <dl class="detail-features-dl" id="exterior-features">
            {listing.acres > 0 && <div class="detail-features-row"><dt>Lot Size</dt><dd>{listing.acres} Acres</dd></div>}
            {listing.yearBuilt > 0 && <div class="detail-features-row"><dt>Year Built</dt><dd>{listing.yearBuilt}</dd></div>}
            {listing.propType && <div class="detail-features-row"><dt>Property Type</dt><dd>{listing.propType}</dd></div>}
          </dl>

          <!-- Enhanced features populated by API -->
          <div id="enhanced-features"></div>
        </section>

        <!-- Similar Properties -->
        {similar.length > 0 && (
          <section id="similar-listings" class="detail-section">
            <h4>Similar properties</h4>
            <div class="similar-scroll">
              {similar.map((s) => (
                <a href={`/listing/${s.id}`} class="similar-card">
                  <div class="similar-card__img-wrap">
                    {s.photo ? (
                      <img src={s.photo} alt={s.address} loading="lazy" />
                    ) : (
                      <div class="similar-card__noimg">No Photo</div>
                    )}
                    <span class="similar-card__badge">{s.status || 'Active'}</span>
                  </div>
                  <div class="similar-card__info">
                    <div class="similar-card__price">{fullPrice(s.price)}</div>
                    <div class="similar-card__meta">
                      {s.beds > 0 && <span>{s.beds} bd</span>}
                      {s.baths > 0 && <span>{s.baths} ba</span>}
                      {s.sqft > 0 && <span>{s.sqft.toLocaleString()} sqft</span>}
                    </div>
                    <div class="similar-card__address">{s.address}, {s.city} {s.state}, {s.zip}</div>
                    <div class="similar-card__mls">MLS: {s.id}</div>
                  </div>
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- MLS Disclaimer -->
        <section class="detail-disclaimer">
          <div class="detail-disclaimer__agent">
            {listing.listingAgent && <span>Listing Agent: {listing.listingAgent}</span>}
            {listing.listingOffice && <span>Brokerage: {listing.listingOffice}</span>}
            <span>Source: LERA (Local Expertise Regional Access)</span>
          </div>
          <p class="detail-disclaimer__text">
            The data relating to real estate for sale on this website comes in part from the Internet Data Exchange (IDX) program of the Local Expertise Regional Access&reg;. IDX information is provided exclusively for consumers' personal, non-commercial use and may not be used for any purpose other than to identify prospective properties consumers may be interested in purchasing. Real estate listings held by brokerage firms other than Popby Realty, are indicated by detailed information about them such as the name of the listing firms. Information deemed reliable but not guaranteed. The MLS may, at its discretion, require use of other disclaimers as necessary to protect participants and/or the MLS from liability. Copyright &copy; {today.getFullYear()} Local Expertise Regional Access&reg;. All Rights Reserved.
          </p>
          <p class="detail-disclaimer__date">Data last updated {disclaimerDate}</p>
        </section>
      </div>

      <!-- Sidebar -->
      <aside class="detail-sidebar">
        <div class="detail-agent-card">
          <img src="/images/cody-posey.jpg" alt="Cody Posey" class="detail-agent-photo" />
          <div class="detail-agent-name">Cody Posey</div>
          <div class="detail-agent-brokerage">Popby Realty</div>
          <a href="/contact" class="detail-cta-btn detail-cta-btn--tour">Request a tour</a>
          <a href="tel:+18303605569" class="detail-cta-btn detail-cta-btn--contact">
            <svg width="16" height="16" viewBox="0 0 20 20" fill="currentColor"><path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/></svg>
            Contact agent
          </a>
        </div>
        <a href={listing.detailUrl} target="_blank" rel="noopener" class="detail-idx-link">
          View Full MLS Listing
          <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor"><path d="M11 3a1 1 0 100 2h2.586l-6.293 6.293a1 1 0 101.414 1.414L15 6.414V9a1 1 0 102 0V4a1 1 0 00-1-1h-5z"/><path d="M5 5a2 2 0 00-2 2v8a2 2 0 002 2h8a2 2 0 002-2v-3a1 1 0 10-2 0v3H5V7h3a1 1 0 000-2H5z"/></svg>
        </a>
        <a href="/search" class="detail-back-link">&larr; Back to Search</a>
      </aside>
    </div>
  </main>

  <!-- Lightbox + Photo/Details Fetch Script -->
  <script is:inline>
  (function() {
    var lightbox = document.getElementById('lightbox');
    var lbImg = document.getElementById('lbImg');
    var lbCounter = document.getElementById('lbCounter');
    var grid = document.querySelector('.photo-grid');
    if (!grid || !lightbox) return;

    var photos = [];
    try { photos = JSON.parse(grid.getAttribute('data-photos') || '[]'); } catch(e) {}
    var currentIdx = 0;

    var listingId = grid.getAttribute('data-listing-id');
    if (listingId) {
      fetch('/api/photos/' + listingId)
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.photos && data.photos.length > 1) {
            photos = data.photos;
            grid.setAttribute('data-photos', JSON.stringify(photos));
            updatePhotoGrid(photos);
          }

          // Update description if we got a longer one from API
          if (data.description) {
            var descEl = document.getElementById('listing-description');
            if (descEl && (descEl.getAttribute('data-placeholder') === 'true' || data.description.length > (descEl.textContent || '').length)) {
              descEl.textContent = data.description;
              descEl.removeAttribute('data-placeholder');
            }
          }

          // Populate enhanced features
          populateEnhancedFeatures(data);

          // Populate school info
          populateSchools(data);
        })
        .catch(function() {});
    }

    function addFeatureRow(dl, label, value) {
      if (!value) return;
      var row = document.createElement('div');
      row.className = 'detail-features-row';
      var dt = document.createElement('dt');
      dt.textContent = label;
      var dd = document.createElement('dd');
      dd.textContent = value;
      row.appendChild(dt);
      row.appendChild(dd);
      dl.appendChild(row);
    }

    function populateEnhancedFeatures(data) {
      // Add to interior features
      var interior = document.getElementById('interior-features');
      if (interior) {
        addFeatureRow(interior, 'Interior Features', data.interior);
        addFeatureRow(interior, 'Appliances', data.appliances);
        addFeatureRow(interior, 'Flooring', data.flooring);
        addFeatureRow(interior, 'Cooling', data.cooling);
        addFeatureRow(interior, 'Heating', data.heating);
        addFeatureRow(interior, 'Fireplace', data.fireplace);
        addFeatureRow(interior, 'Laundry', data.laundry);
        addFeatureRow(interior, 'Basement', data.basement);
        addFeatureRow(interior, 'Windows', data.windows);
      }

      // Add to exterior features
      var exterior = document.getElementById('exterior-features');
      if (exterior) {
        addFeatureRow(exterior, 'Exterior Features', data.exterior);
        addFeatureRow(exterior, 'Architectural Style', data.style);
        addFeatureRow(exterior, 'Roof', data.roof);
        addFeatureRow(exterior, 'Construction', data.construction);
        addFeatureRow(exterior, 'Foundation', data.foundation);
        addFeatureRow(exterior, 'Parking', data.parking);
        addFeatureRow(exterior, 'Pool', data.pool);
        addFeatureRow(exterior, 'Patio & Porch', data.patioAndPorch);
        addFeatureRow(exterior, 'Lot Features', data.lotFeatures);
        addFeatureRow(exterior, 'Water Source', data.waterSource);
        addFeatureRow(exterior, 'Sewer', data.sewer);
        addFeatureRow(exterior, 'Utilities', data.utilities);
      }

      // HOA info
      if (data.hoa) {
        var enhanced = document.getElementById('enhanced-features');
        if (enhanced) {
          var h3 = document.createElement('h3');
          h3.textContent = 'HOA Information';
          enhanced.appendChild(h3);
          var dl = document.createElement('dl');
          dl.className = 'detail-features-dl';
          addFeatureRow(dl, 'HOA Fee', data.hoa);
          if (data.hoaFreq) addFeatureRow(dl, 'HOA Frequency', data.hoaFreq);
          enhanced.appendChild(dl);
        }
      }

      // Listing agent from API (if not already shown)
      if (data.listingAgent || data.listingOffice) {
        var disclaimer = document.querySelector('.detail-disclaimer__agent');
        if (disclaimer) {
          var spans = disclaimer.querySelectorAll('span');
          var hasAgent = false;
          spans.forEach(function(s) { if (s.textContent.indexOf('Listing Agent') >= 0) hasAgent = true; });
          if (!hasAgent && data.listingAgent) {
            var span = document.createElement('span');
            span.textContent = 'Listing Agent: ' + data.listingAgent;
            disclaimer.insertBefore(span, disclaimer.firstChild);
          }
          var hasOffice = false;
          spans.forEach(function(s) { if (s.textContent.indexOf('Brokerage') >= 0 && s.textContent.length < 15) hasOffice = true; });
          if (!hasOffice && data.listingOffice) {
            var span2 = document.createElement('span');
            span2.textContent = 'Brokerage: ' + data.listingOffice;
            disclaimer.insertBefore(span2, disclaimer.children[1] || null);
          }
        }
      }
    }

    function populateSchools(data) {
      var hasSchool = data.schoolElementary || data.schoolMiddle || data.schoolHigh || data.schoolDistrict;
      if (!hasSchool) return;
      var section = document.getElementById('schools');
      var dl = document.getElementById('school-list');
      if (!section || !dl) return;
      section.style.display = '';
      addFeatureRow(dl, 'School District', data.schoolDistrict);
      addFeatureRow(dl, 'Elementary School', data.schoolElementary);
      addFeatureRow(dl, 'Middle School', data.schoolMiddle);
      addFeatureRow(dl, 'High School', data.schoolHigh);
    }

    function updatePhotoGrid(allPhotos) {
      var main = grid.querySelector('.photo-grid__main');
      var side = grid.querySelector('.photo-grid__side');
      if (!side && allPhotos.length >= 4) {
        if (main) main.classList.remove('photo-grid__main--solo');
        side = document.createElement('div');
        side.className = 'photo-grid__side';
        var wide = document.createElement('div');
        wide.className = 'photo-grid__wide';
        wide.setAttribute('data-idx', '1');
        wide.style.cursor = 'pointer';
        var wideImg = document.createElement('img');
        wideImg.src = allPhotos[1];
        wideImg.alt = '';
        wide.appendChild(wideImg);
        wide.addEventListener('click', function() { openLightbox(1); });
        var bottom = document.createElement('div');
        bottom.className = 'photo-grid__bottom';
        for (var i = 2; i <= 3; i++) {
          var thumb = document.createElement('div');
          thumb.className = 'photo-grid__thumb' + (i === 3 ? ' photo-grid__thumb--last' : '');
          thumb.setAttribute('data-idx', i);
          thumb.style.cursor = 'pointer';
          var img = document.createElement('img');
          img.src = allPhotos[i];
          img.alt = '';
          thumb.appendChild(img);
          if (i === 3 && allPhotos.length > 4) {
            var btn = document.createElement('button');
            btn.className = 'photo-grid__all-btn';
            btn.setAttribute('data-action', 'open-lightbox');
            btn.textContent = 'All photos';
            thumb.appendChild(btn);
          }
          thumb.addEventListener('click', (function(idx) {
            return function(e) {
              if (e.target.closest('[data-action="open-lightbox"]')) { openLightbox(0); }
              else { openLightbox(idx); }
            };
          })(i));
          bottom.appendChild(thumb);
        }
        side.appendChild(wide);
        side.appendChild(bottom);
        grid.appendChild(side);
        var oldBtn = main && main.querySelector('.photo-grid__all-btn--overlay');
        if (oldBtn) oldBtn.remove();
      } else if (side && allPhotos.length >= 4) {
        var imgs = side.querySelectorAll('img');
        for (var j = 0; j < imgs.length && j < allPhotos.length - 1; j++) {
          imgs[j].src = allPhotos[j + 1];
        }
      }
    }

    function openLightbox(idx) {
      if (photos.length === 0) return;
      currentIdx = idx || 0;
      showPhoto();
      lightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }
    function closeLightbox() {
      lightbox.style.display = 'none';
      document.body.style.overflow = '';
    }
    function showPhoto() {
      lbImg.src = photos[currentIdx];
      lbCounter.textContent = (currentIdx + 1) + ' / ' + photos.length;
    }
    function nextPhoto() { currentIdx = (currentIdx + 1) % photos.length; showPhoto(); }
    function prevPhoto() { currentIdx = (currentIdx - 1 + photos.length) % photos.length; showPhoto(); }

    grid.querySelectorAll('[data-idx]').forEach(function(el) {
      el.style.cursor = 'pointer';
      el.addEventListener('click', function(e) {
        if (e.target.closest('[data-action="open-lightbox"]')) { openLightbox(0); }
        else { openLightbox(parseInt(el.getAttribute('data-idx')) || 0); }
      });
    });
    grid.querySelectorAll('[data-action="open-lightbox"]').forEach(function(btn) {
      btn.addEventListener('click', function(e) { e.stopPropagation(); openLightbox(0); });
    });
    document.getElementById('lbClose').addEventListener('click', closeLightbox);
    document.getElementById('lbNext').addEventListener('click', nextPhoto);
    document.getElementById('lbPrev').addEventListener('click', prevPhoto);
    lightbox.addEventListener('click', function(e) {
      if (e.target === lightbox || e.target.classList.contains('lightbox__img-wrap')) closeLightbox();
    });
    document.addEventListener('keydown', function(e) {
      if (lightbox.style.display === 'none') return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') nextPhoto();
      if (e.key === 'ArrowLeft') prevPhoto();
    });
  })();
  </script>

  <!-- Section tab highlighting -->
  <script is:inline>
  (function() {
    var tabs = document.querySelectorAll('.detail-tab');
    var sections = ['listing-header', 'map', 'features', 'similar-listings'];
    function updateActiveTab() {
      var scrollY = window.scrollY + 160;
      var active = 0;
      for (var i = sections.length - 1; i >= 0; i--) {
        var el = document.getElementById(sections[i]);
        if (el && el.offsetTop <= scrollY) { active = i; break; }
      }
      tabs.forEach(function(t, j) { t.classList.toggle('active', j === active); });
    }
    window.addEventListener('scroll', updateActiveTab);
  })();
  </script>

  <!-- Leaflet -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script is:inline src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  {listing.lat !== 0 && listing.lng !== 0 && (
    <script is:inline define:vars={{ lat: listing.lat, lng: listing.lng, address: listing.address }}>
      (function() {
        var mapEl = document.getElementById('detailMap');
        if (!mapEl) return;
        var map = L.map(mapEl, { scrollWheelZoom: false }).setView([lat, lng], 15);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
          maxZoom: 19, subdomains: 'abcd',
        }).addTo(map);
        L.marker([lat, lng]).addTo(map).bindPopup(address).openPopup();
      })();
    </script>
  )}
</Layout>

