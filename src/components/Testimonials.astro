---
// Reviews sourced from Google Business Profile (29 reviews, all 5-star)
const testimonials = [
  {
    name: 'Brian Tilton',
    role: 'Home Buyer — Mortgage Industry Executive',
    quote: 'I recently worked with Cody on a home purchase that just closed, and I can confidently say he stands out as one of the best agents I\'ve partnered with in my 30+ years in the mortgage industry.',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=BT',
  },
  {
    name: 'Michelle Maloney',
    role: 'Google Local Guide',
    quote: 'Cody Posey is the most knowledgeable real estate agent in Texas! His knowledge of the market is top notch, but beyond that he knows how to market your home to buyers to get it SOLD! As a US Veteran, he has a servant heart matched only by his work ethic.',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=MM',
  },
  {
    name: 'Shannon Cheatham',
    role: 'Home Buyer & Seller',
    quote: 'Cody was a pleasure to work with. He went above and beyond and exemplifies true customer service! We would highly recommend him if you are selling or buying a home! He helped in many different ways to ensure EVERYTHING was perfect. Thank you Cody for going above and beyond expectations!',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=SC',
  },
  {
    name: 'Mara',
    role: 'Home Buyer',
    quote: 'We had the best experience with Cody! He took his time, even spontaneously on the same day to help us find our home. Everything went smoothly and he took care of the whole process — and still after everything was signed and we moved in, he\'s still there to help us with any questions. We can highly recommend him.',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=M',
  },
  {
    name: 'David Goad',
    role: 'Verified Client',
    quote: 'Cody is exceptional at his craft. He is also very in tune with technology and his local market. If you are looking to buy or sell and he is in your area, I highly recommend giving him a call.',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=DG',
  },
  {
    name: 'Ferrol Bell',
    role: 'New Construction Buyer',
    quote: 'Cody was phenomenal from start to finish. Our home buying process went extremely fast and felt like a whirlwind but Cody handled it all knowing how hectic our schedules. He even caught that the builder\'s gutter crew had installed the gutters incorrectly — his attention to detail is unmatched.',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=FB',
  },
  {
    name: 'Greg Van Leer',
    role: 'Home Buyer',
    quote: 'Cody has always been a pleasure to work with. He has outstanding knowledge of the home buying process and will go above and beyond for anyone who works with him. He will not only inspect the home thoroughly but will tell you everything you need to know.',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=GV',
  },
  {
    name: 'Donna Davi',
    role: 'Verified Client',
    quote: 'I had several real estate questions which gave me a lot of anxiety. I saw one of Cody\'s videos which I found very informative and easy to understand. I reached out and Cody responded immediately. He was selfless with his time and truly put my mind at ease.',
    avatar: 'https://placehold.co/100x100/FF1616/fff?text=DD',
  },
];
---

<section class="testimonials section" id="testimonials"
  style="background-image: url('https://media-production.lp-cdn.com/cdn-cgi/image/format=auto,quality=85,fit=scale-down,width=1280/https://media-production.lp-cdn.com/media/28b62a24-fd1c-4443-9e1b-dcc7e4069f64');">
  <div class="testimonials__overlay"></div>

  <div class="container" style="position:relative;z-index:2;">
    <div class="section-title">
      <h2 style="color:#fff;">What <span class="accent">Clients</span> Say</h2>
      <p style="color:rgba(255,255,255,0.7);">Real stories from real people I've helped find their home</p>
    </div>

    <div class="swiper testimonials-swiper">
      <div class="swiper-wrapper">
        {testimonials.map(t => (
          <div class="swiper-slide">
            <div class="testi-card">
              <div class="testi-card__stars">★★★★★</div>
              <blockquote class="testi-card__quote">
                "{t.quote}"
              </blockquote>
              <div class="testi-card__author">
                <img src={t.avatar} alt={t.name} class="testi-card__avatar" />
                <div>
                  <div class="testi-card__name">{t.name}</div>
                  <div class="testi-card__role">{t.role}</div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="swiper-button-next"></div>
      <div class="swiper-button-prev"></div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<style>
  .testimonials {
    position: relative;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
  }

  .testimonials__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.75);
  }

  .testimonials-swiper {
    padding-bottom: 3.5rem !important;
    max-width: 800px;
    margin: 0 auto;
  }

  .testi-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.1);
    backdrop-filter: blur(8px);
    padding: 2.5rem;
    text-align: center;
  }

  .testi-card__stars {
    color: #FF1616;
    font-size: 1.2rem;
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
  }

  .testi-card__quote {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: rgba(255,255,255,0.9);
    line-height: 1.8;
    margin-bottom: 2rem;
    font-style: italic;
  }

  .testi-card__author {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }

  .testi-card__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #FF1616;
  }

  .testi-card__name {
    font-weight: 700;
    font-size: 0.9rem;
    color: #fff;
    text-align: left;
  }

  .testi-card__role {
    font-size: 0.75rem;
    color: #FF1616;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: left;
  }

  .testimonials-swiper .swiper-button-next,
  .testimonials-swiper .swiper-button-prev {
    color: #FF1616 !important;
  }

  .testimonials-swiper .swiper-pagination-bullet-active {
    background: #FF1616 !important;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    new (window as any).Swiper('.testimonials-swiper', {
      slidesPerView: 1,
      spaceBetween: 24,
      loop: true,
      autoplay: { delay: 5000, disableOnInteraction: false },
      navigation: {
        nextEl: '.testimonials-swiper .swiper-button-next',
        prevEl: '.testimonials-swiper .swiper-button-prev',
      },
      pagination: {
        el: '.testimonials-swiper .swiper-pagination',
        clickable: true,
      },
    });
  });
</script>
