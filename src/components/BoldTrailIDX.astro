<!--
  ============================================================
  BOLDTRAIL IDX INTEGRATION
  ============================================================
  To connect your BoldTrail IDX:

  1. Log into your BoldTrail account
  2. Go to Settings > IDX / Website Integration
  3. Copy your IDX embed code or iframe URL
  4. Replace the placeholder below with your actual embed code

  BoldTrail typically provides one of these:
    a) A JavaScript snippet (paste into the <script> tag area)
    b) An iframe embed URL
    c) A search widget script

  Contact BoldTrail support if you need help finding your embed code.
  ============================================================
-->

<section class="idx-section section" id="idx-search">
  <div class="container">
    <div class="section-title">
      <h2>Search <span class="accent">All Listings</span></h2>
      <p>Browse homes for sale and lease in New Braunfels and surrounding areas</p>
    </div>

    <!-- ============================================================
         REPLACE THIS BLOCK WITH YOUR BOLDTRAIL IDX EMBED CODE
         ============================================================ -->
    <div class="idx-placeholder">
      <div class="idx-placeholder__inner">
        <div class="idx-placeholder__icon">🏠</div>
        <h3>BoldTrail IDX — Coming Soon</h3>
        <p>
          Your live MLS property search will appear here once your<br />
          BoldTrail IDX embed code is connected.
        </p>
        <a href="https://boldtrail.com" target="_blank" rel="noopener" class="btn btn-primary">
          Go to BoldTrail Dashboard
        </a>
      </div>
    </div>
    <!-- ============================================================
         END IDX PLACEHOLDER
         ============================================================ -->

    <!--
    Example iframe embed (uncomment and update with your URL):
    <iframe
      src="https://YOUR-BOLDTRAIL-IDX-URL.com/search"
      width="100%"
      height="800px"
      frameborder="0"
      allowfullscreen
      title="Property Search"
    ></iframe>
    -->

  </div>
</section>

<style>
  .idx-section {
    background: var(--light-gray);
  }

  .idx-placeholder {
    border: 2px dashed #ccc;
    background: #fff;
    padding: 4rem 2rem;
    text-align: center;
  }

  .idx-placeholder__icon {
    font-size: 3rem;
    margin-bottom: 1rem;
  }

  .idx-placeholder h3 {
    font-family: 'Abhaya Libre', serif;
    font-size: 1.6rem;
    text-transform: uppercase;
    margin-bottom: 1rem;
    color: #333;
  }

  .idx-placeholder p {
    color: #777;
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }
</style>
