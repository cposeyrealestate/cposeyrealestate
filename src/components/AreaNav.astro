---
interface Props {
  areaSlug: string;
  areaName: string;
  currentPage: string;
}

const { areaSlug, areaName, currentPage } = Astro.props;

const pages = [
  { label: 'Overview', slug: '' },
  { label: 'Neighborhoods', slug: 'neighborhoods' },
  { label: 'Homes for Sale', slug: 'homes-for-sale' },
  { label: 'Restaurants', slug: 'restaurants' },
  { label: 'Things to Do', slug: 'things-to-do' },
];
---

<nav class="area-nav" aria-label={`${areaName} pages`}>
  <div class="area-nav__inner container">
    {pages.map((page) => {
      const href = page.slug ? `/${areaSlug}/${page.slug}/` : `/${areaSlug}/`;
      const isActive = currentPage === page.slug || (currentPage === 'overview' && page.slug === '');
      return (
        <a
          href={href}
          class:list={['area-nav__pill', { 'area-nav__pill--active': isActive }]}
        >
          {page.label}
        </a>
      );
    })}
  </div>
</nav>

<style>
  .area-nav {
    position: sticky;
    top: 80px;
    z-index: 50;
    background: #fff;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    padding: 0.75rem 1.5rem;
  }

  .area-nav__inner {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }

  .area-nav__inner::-webkit-scrollbar {
    display: none;
  }

  .area-nav__pill {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.5rem 1.2rem;
    border-radius: 999px;
    border: 2px solid #ddd;
    color: #333;
    white-space: nowrap;
    transition: all 0.2s;
  }

  .area-nav__pill:hover {
    border-color: #FF1616;
    color: #FF1616;
  }

  .area-nav__pill--active {
    background: #FF1616;
    border-color: #FF1616;
    color: #fff;
  }

  .area-nav__pill--active:hover {
    background: #cc0000;
    border-color: #cc0000;
    color: #fff;
  }

  @media (max-width: 768px) {
    .area-nav {
      top: 60px;
    }

    .area-nav__pill {
      font-size: 0.7rem;
      padding: 0.4rem 1rem;
    }
  }
</style>
