<style>
  .footer {
    background: var(--black);
    color: var(--white);
    padding-top: 4rem;
  }

  .footer__main {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #222;
  }

  .footer__logo-img {
    height: 50px;
    width: auto;
    margin-bottom: 1rem;
  }

  .footer__tagline {
    font-size: 0.85rem;
    color: #aaa;
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .footer__social {
    display: flex;
    gap: 1rem;
  }

  .footer__social-link {
    color: #aaa;
    transition: color 0.3s;
  }

  .footer__social-link:hover {
    color: #FF1616;
  }

  .footer__nav h4,
  .footer__contact h4 {
    font-family: 'Poppins', sans-serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.2rem;
    color: #FF1616;
  }

  .footer__nav ul li,
  .footer__contact ul li {
    margin-bottom: 0.7rem;
  }

  .footer__nav ul li a,
  .footer__contact ul li a,
  .footer__contact ul li {
    font-size: 0.85rem;
    color: #aaa;
    transition: color 0.3s;
  }

  .footer__nav ul li a:hover,
  .footer__contact ul li a:hover {
    color: #fff;
  }

  .footer__bottom {
    padding: 1.5rem 0;
    text-align: center;
  }

  .footer__disclaimer {
    font-size: 0.7rem;
    color: #666;
    max-width: 800px;
    margin: 0 auto 0.8rem;
    line-height: 1.6;
  }

  .footer__copy {
    font-size: 0.75rem;
    color: #555;
  }

  @media (max-width: 768px) {
    .footer__main {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
