---
interface Props {
  name: string;
  cuisine: string;
  description: string;
  priceRange: string;
  tags: string[];
}

const { name, cuisine, description, priceRange, tags } = Astro.props;

const maxDollars = 4;
const activeDollars = priceRange.length;
---

<div class="resto-card">
  <div class="resto-card__header">
    <div>
      <h3 class="resto-card__name">{name}</h3>
      <span class="resto-card__cuisine">{cuisine}</span>
    </div>
    <span class="resto-card__price">
      {Array.from({ length: maxDollars }).map((_, i) => (
        <span class={i < activeDollars ? 'resto-card__dollar--active' : 'resto-card__dollar'}>$</span>
      ))}
    </span>
  </div>
  <p class="resto-card__desc">{description}</p>
  {tags.length > 0 && (
    <div class="resto-card__tags">
      {tags.map((tag) => (
        <span class="resto-card__tag">{tag}</span>
      ))}
    </div>
  )}
</div>

<style>
  .resto-card {
    background: #fff;
    border-left: 3px solid #FF1616;
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .resto-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);
  }

  .resto-card__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }

  .resto-card__name {
    font-size: 1.05rem;
    color: #000;
    margin-bottom: 0.2rem;
  }

  .resto-card__cuisine {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gray);
  }

  .resto-card__price {
    white-space: nowrap;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .resto-card__dollar--active {
    color: #FF1616;
  }

  .resto-card__dollar {
    color: #ddd;
  }

  .resto-card__desc {
    font-size: 0.88rem;
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .resto-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .resto-card__tag {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    background: #f5f5f5;
    border-radius: 999px;
    color: #555;
  }
</style>
