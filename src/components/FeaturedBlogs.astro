---

<section class="blogs section" id="blog">
  <div class="container">
    <div class="section-title">
      <h2>Featured <span class="accent">Blogs</span></h2>
      <p>Insights on buying, selling, and living in the New Braunfels area</p>
    </div>

    <div class="blogs__grid">
      {blogs.slice(0, 3).map(post => (
        <article class="blog-card blog-card--featured">
          <a href={`/blog/${post.slug}`} class="blog-card__img-link">
            <img src={post.img} alt={post.title} class="blog-card__img" loading="lazy" />
          </a>
          <div class="blog-card__body">
            <span class="blog-card__cat">{post.category}</span>
            <h3 class="blog-card__title">
              <a href={`/blog/${post.slug}`}>{post.title}</a>
            </h3>
            <p class="blog-card__meta">Cody Posey &nbsp;|&nbsp; {post.date}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="blogs__list">
      {blogs.slice(3).map(post => (
        <article class="blog-row">
          <span class="blog-row__cat">{post.category}</span>
          <h4 class="blog-row__title">
            <a href={`/blog/${post.slug}`}>{post.title}</a>
          </h4>
          <span class="blog-row__date">{post.date}</span>
        </article>
      ))}
    </div>

    <div class="blogs__cta">
      <a href="/blog" class="btn btn-outline-dark">View All Posts</a>
    </div>
  </div>
</section>

<style>
  .blogs {
    background: #fff;
  }

  .blogs__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-bottom: 2rem;
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.07);
    overflow: hidden;
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .blog-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.13);
  }

  .blog-card__img-link {
    display: block;
    overflow: hidden;
    aspect-ratio: 16/9;
  }

  .blog-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s;
  }

  .blog-card:hover .blog-card__img {
    transform: scale(1.05);
  }

  .blog-card__body {
    padding: 1.25rem;
    flex: 1;
  }

  .blog-card__cat {
    display: inline-block;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #FF1616;
    margin-bottom: 0.6rem;
  }

  .blog-card__title {
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.5;
    margin-bottom: 0.75rem;
  }

  .blog-card__title a {
    color: #000;
    transition: color 0.2s;
  }

  .blog-card__title a:hover {
    color: #FF1616;
  }

  .blog-card__meta {
    font-size: 0.75rem;
    color: #999;
  }

  /* List rows */
  .blogs__list {
    border-top: 1px solid #eee;
    margin-bottom: 2rem;
  }

  .blog-row {
    display: grid;
    grid-template-columns: 120px 1fr 140px;
    gap: 1rem;
    align-items: center;
    padding: 1rem 0;
    border-bottom: 1px solid #eee;
  }

  .blog-row__cat {
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #FF1616;
  }

  .blog-row__title a {
    font-size: 0.9rem;
    font-weight: 600;
    color: #000;
    transition: color 0.2s;
  }

  .blog-row__title a:hover {
    color: #FF1616;
  }

  .blog-row__date {
    font-size: 0.75rem;
    color: #999;
    text-align: right;
  }

  .blogs__cta {
    text-align: center;
  }

  @media (max-width: 900px) {
    .blogs__grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  @media (max-width: 600px) {
    .blogs__grid {
      grid-template-columns: 1fr;
    }

    .blog-row {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }

    .blog-row__date {
      text-align: left;
    }
  }
</style>
