<style>
  .idx-search-bar {
    background: #111;
    padding: 2rem 1.5rem;
    border-radius: 12px;
    margin-bottom: 2rem;
  }

  .idx-search-bar__inner {
    max-width: 900px;
    margin: 0 auto;
  }

  /* Override IDX widget defaults to match site theme */
  .idx-search-bar :global(input),
  .idx-search-bar :global(select) {
    font-family: 'Poppins', sans-serif;
    border-radius: 6px;
  }

  .idx-search-bar :global(button),
  .idx-search-bar :global(input[type="submit"]) {
    font-family: 'Poppins', sans-serif;
    background: #FF1616;
    border: none;
    border-radius: 6px;
    color: #fff;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .idx-search-bar :global(button:hover),
  .idx-search-bar :global(input[type="submit"]:hover) {
    opacity: 0.85;
  }
</style>
