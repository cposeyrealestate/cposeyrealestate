        </a>
        <a href="https://www.linkedin.com/in/cposeyrealestate/" target="_blank" rel="noopener" aria-label="LinkedIn">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
      </div>

      <div class="work-with-us__actions">
        <a href="#contact" class="btn btn-primary">Let's Connect</a>
        <a href="/explorearea" class="btn btn-outline-dark">Explore the Area</a>
      </div>
    </div>
  </div>
</section>

<!-- Contact Section -->
<section class="contact section" id="contact" style="background:#000;color:#fff;">
  <div class="container">
    <div class="section-title">
      <h2 style="color:#fff;">Let's <span class="accent">Connect</span></h2>
      <p style="color:#aaa;">Ready to buy, sell, or just have questions? Reach out — I'd love to help.</p>
    </div>

    <div class="contact__inner">
      <form class="contact-form" id="contactForm">
        <div class="form-row">
          <div class="form-group">
            <label>First Name *</label>
            <input type="text" name="firstName" required placeholder="First name" />
          </div>
          <div class="form-group">
            <label>Last Name *</label>
            <input type="text" name="lastName" required placeholder="Last name" />
          </div>
        </div>
        <div class="form-group">
          <label>Email Address *</label>
          <input type="email" name="email" required placeholder="your@email.com" />
        </div>
        <div class="form-group">
          <label>Phone Number</label>
          <input type="tel" name="phone" placeholder="(555) 555-5555" />
        </div>
        <div class="form-group">
          <label>I'm interested in...</label>
          <select name="interest">
            <option value="">Select one</option>
            <option>Buying a Home</option>
            <option>Selling My Home</option>
            <option>Home Valuation</option>
            <option>Investment Property</option>
            <option>Relocating to New Braunfels</option>
            <option>Just Browsing</option>
          </select>
        </div>
        <div class="form-group">
          <label>Message</label>
          <textarea name="message" rows="4" placeholder="Tell me how I can help..."></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;">Send Message</button>
      </form>

      <div class="contact__info">
        <div class="contact__info-item">
          <div class="contact__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <div class="contact__info-label">Call or Text</div>
            <a href="tel:+18303605569" class="contact__info-value">(830) 360-5569</a>
          </div>
        </div>
        <div class="contact__info-item">
          <div class="contact__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <div class="contact__info-label">Email</div>
            <a href="mailto:codyposey@cposeyrealestate.com" class="contact__info-value">codyposey@cposeyrealestate.com</a>
          </div>
        </div>
        <div class="contact__info-item">
          <div class="contact__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <div class="contact__info-label">Serving</div>
            <div class="contact__info-value">New Braunfels &amp; surrounding Hill Country</div>
          </div>
        </div>
        <div class="contact__info-item">
          <div class="contact__info-icon">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          </div>
          <div>
            <div class="contact__info-label">Availability</div>
            <div class="contact__info-value">Mon–Sat, 9am–9pm CT<br/>Sunday, 12pm–8pm CT</div>
          </div>
        </div>

        <div class="contact__brand">
          <img src="/images/popby-logo.png" alt="Popby Realty" class="contact__brand-logo" />
          <p class="contact__brand-tagline">Your New Braunfels Real Estate Expert</p>
          <div class="contact__brand-social">
            <a href="https://www.facebook.com/cposeyrealestate" target="_blank" rel="noopener" aria-label="Facebook">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </a>
            <a href="https://www.instagram.com/cposeyrealestate/" target="_blank" rel="noopener" aria-label="Instagram">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </a>
            <a href="https://www.youtube.com/@cposeyrealestate" target="_blank" rel="noopener" aria-label="YouTube">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20.05 12 20.05 12 20.05s6.88 0 8.59-.45a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="#000"/></svg>
            </a>
            <a href="https://www.tiktok.com/@cposeyrealestate" target="_blank" rel="noopener" aria-label="TikTok">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.18 8.18 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>
            </a>
            <a href="https://www.linkedin.com/in/cposeyrealestate/" target="_blank" rel="noopener" aria-label="LinkedIn">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  /* Work With Us */
  .work-with-us {
    background: var(--white);
  }

  .work-with-us__inner {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 5rem;
    align-items: center;
  }

  .work-with-us__image-wrap {
    position: relative;
  }

  .work-with-us__img {
    width: 100%;
    object-fit: cover;
    aspect-ratio: 5/6;
  }

  .work-with-us__badge {
    position: absolute;
    bottom: -1.5rem;
    right: -1.5rem;
    background: #FF1616;
    color: #fff;
    padding: 1.5rem;
    text-align: center;
    min-width: 110px;
  }

  .work-with-us__badge-num {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    line-height: 1;
  }

  .work-with-us__badge-label {
    display: block;
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 0.3rem;
  }

  .work-with-us__eyebrow {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: #FF1616;
    margin-bottom: 0.5rem;
  }

  .work-with-us__content h2 {
    margin-bottom: 1.5rem;
  }

  .work-with-us__tagline {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--gray);
    line-height: 1.5;
    margin-bottom: 2rem;
    padding-bottom: 2rem;
    border-bottom: 2px solid var(--light-gray);
  }

  .work-with-us__bio {
    color: #555;
    font-size: 0.95rem;
    line-height: 1.8;
    margin-bottom: 1.25rem;
  }

  .work-with-us__motto {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #FF1616;
    margin: 1.5rem 0;
    padding-top: 1.5rem;
    border-top: 2px solid var(--light-gray);
  }

  .work-with-us__details {
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin: 1.5rem 0 2rem;
  }

  .work-with-us__detail {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .work-with-us__detail a,
  .work-with-us__detail span {
    font-size: 0.9rem;
    color: var(--gray);
    transition: color 0.2s;
  }

  .work-with-us__detail a:hover {
    color: #FF1616;
  }

  .work-with-us__social {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .work-with-us__social a {
    color: #555;
    transition: color 0.2s, transform 0.2s;
  }

  .work-with-us__social a:hover {
    color: #FF1616;
    transform: translateY(-2px);
  }

  .work-with-us__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* Contact */
  .contact__inner {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  .contact-form .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .contact-form .form-group {
    margin-bottom: 1rem;
  }

  .contact-form label {
    display: block;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #aaa;
    margin-bottom: 0.4rem;
  }

  .contact-form input,
  .contact-form select,
  .contact-form textarea {
    width: 100%;
    padding: 0.8rem 1rem;
    background: #111;
    border: 1px solid #333;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus {
    border-color: #FF1616;
  }

  .contact-form select option {
    background: #111;
  }

  .contact__info {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 0.5rem;
  }

  .contact__info-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .contact__info-icon {
    font-size: 1.4rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
  }

  .contact__info-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #666;
    margin-bottom: 0.3rem;
  }

  .contact__info-value {
    font-size: 0.95rem;
    color: #fff;
    transition: color 0.2s;
  }

  a.contact__info-value:hover {
    color: #FF1616;
  }

  .contact__brand {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid #222;
    text-align: center;
  }

  .contact__brand-logo {
    height: 45px;
    width: auto;
    margin-bottom: 0.75rem;
  }

  .contact__brand-tagline {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.3);
    margin-bottom: 1rem;
  }

  .contact__brand-social {
    display: flex;
    gap: 1rem;
    justify-content: center;
  }

  .contact__brand-social a {
    color: #aaa;
    transition: color 0.3s;
  }

  .contact__brand-social a:hover {
    color: #FF1616;
  }

  @media (max-width: 900px) {
    .work-with-us__inner {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .work-with-us__badge {
      right: 0;
    }
    .contact__inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .contact-form .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  document.getElementById('contactForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target;
    const data = new FormData(form);
    const btn = form.querySelector('button[type="submit"]');
    if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }

    var interest = data.get('interest') || '';
    var userMessage = (data.get('message') || '').toString().trim();
    var combinedMessage = interest
      ? (userMessage ? 'Interested in: ' + interest + '\n\n' + userMessage : 'Interested in: ' + interest)
      : userMessage;

    fetch('/api/lead', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        firstName: data.get('firstName'),
        lastName: data.get('lastName'),
        email: data.get('email'),
        phone: data.get('phone'),
        message: combinedMessage,
        source: 'Lets Connect Form'
      })
    })
    .then(function() {
      alert('Thank you! Cody will be in touch with you shortly.');
      form.reset();
      if (btn) { btn.disabled = false; btn.textContent = 'Send Message'; }
    })
    .catch(function() {
      alert('Thank you! Cody will be in touch with you shortly.');
      form.reset();
      if (btn) { btn.disabled = false; btn.textContent = 'Send Message'; }
    });
  });
</script>
