<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    padding: 1rem 1.5rem;
    background: #000;
    transition: background 0.3s ease, box-shadow 0.3s ease;
  }

  .navbar.scrolled {
    background: #000;
    box-shadow: 0 2px 20px rgba(0,0,0,0.4);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .navbar__logo {
    display: flex;
    flex-direction: column;
    line-height: 1;
    color: #fff;
  }

  .navbar__logo-img {
    height: 44px;
    width: auto;
    display: block;
  }

  .navbar__links {
    display: flex;
    gap: 1.8rem;
    align-items: center;
  }

  .navbar__link {
    font-family: 'Poppins', sans-serif;
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #fff;
    transition: color 0.3s;
    position: relative;
  }

  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: #FF1616;
    transition: width 0.3s;
  }

  .navbar__link:hover::after {
    width: 100%;
  }

  .navbar__link:hover {
    color: #FF1616;
  }

  /* Standard Dropdown */
  .navbar__dropdown {
    position: relative;
  }

  .navbar__sub {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    background: #000;
    min-width: 200px;
    padding: 0.5rem 0;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5);
    border-top: 2px solid #FF1616;
  }

  .navbar__dropdown:hover .navbar__sub {
    display: block;
  }

  .navbar__sub li a {
    display: block;
    padding: 0.6rem 1.2rem;
    font-family: 'Poppins', sans-serif;
    font-size: 0.72rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    transition: color 0.2s, padding-left 0.2s;
  }

  .navbar__sub li a:hover {
    color: #FF1616;
    padding-left: 1.6rem;
  }

  /* Mega Dropdown */
  .navbar__mega {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: #000;
    padding: 1.5rem 2rem;
    box-shadow: 0 12px 40px rgba(0,0,0,0.6);
    border-top: 2px solid #FF1616;
    min-width: 700px;
    gap: 0;
  }

  .navbar__dropdown--mega:hover .navbar__mega {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
  }

  .navbar__mega-col {
    padding: 0 0.75rem;
    border-right: 1px solid rgba(255,255,255,0.08);
  }

  .navbar__mega-col:last-child {
    border-right: none;
  }

  .navbar__mega-col h4 {
    margin-bottom: 0.75rem;
  }

  .navbar__mega-col h4 a {
    font-family: 'Poppins', sans-serif;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #FF1616;
    transition: color 0.2s;
  }

  .navbar__mega-col h4 a:hover {
    color: #fff;
  }

  .navbar__mega-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .navbar__mega-col ul li a {
    font-family: 'Poppins', sans-serif;
    font-size: 0.68rem;
    font-weight: 400;
    color: rgba(255,255,255,0.65);
    transition: color 0.2s;
    padding: 0.25rem 0;
    display: block;
  }

  .navbar__mega-col ul li a:hover {
    color: #fff;
  }

  .navbar__cta {
    font-size: 0.75rem;
    padding: 0.6rem 1.4rem;
    white-space: nowrap;
  }

  .navbar__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .navbar__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: #fff;
    transition: 0.3s;
  }

  @media (max-width: 1100px) {
    .navbar__links {
      gap: 1.2rem;
    }

    .navbar__link {
      font-size: 0.72rem;
    }

    .navbar__mega {
      min-width: 600px;
    }
  }

  @media (max-width: 900px) {
    .navbar__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: #000;
      padding: 1.5rem;
      max-height: 80vh;
      overflow-y: auto;
    }

    .navbar__nav.open {
      display: block;
    }

    .navbar__links {
      flex-direction: column;
      align-items: flex-start;
      gap: 1rem;
    }

    .navbar__sub {
      position: static;
      display: block;
      box-shadow: none;
      padding-left: 1rem;
      margin-top: 0.5rem;
      border-top: none;
    }

    .navbar__mega {
      position: static;
      display: block !important;
      transform: none;
      min-width: auto;
      box-shadow: none;
      padding: 0.5rem 0 0 1rem;
      border-top: none;
    }

    .navbar__dropdown--mega:hover .navbar__mega {
      display: block;
      grid-template-columns: 1fr;
    }

    .navbar__mega-col {
      padding: 0.5rem 0;
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.08);
    }

    .navbar__mega-col:last-child {
      border-bottom: none;
    }

    .navbar__cta {
      display: none;
    }

    .navbar__hamburger {
      display: flex;
    }
  }
</style>

<script is:inline>
  // Scroll effect
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      navbar?.classList.add('scrolled');
    } else {
      navbar?.classList.remove('scrolled');
    }
  });

  // Hamburger toggle
  const hamburger = document.getElementById('hamburger');
  const navMenu = document.getElementById('navMenu');
  hamburger?.addEventListener('click', () => {
    navMenu?.classList.toggle('open');
  });
</script>
