---
---

<section class="valuation section" id="home-valuation"
  style="background-image: url('https://media-production.lp-cdn.com/cdn-cgi/image/format=auto,quality=85,fit=scale-down,width=1280/https://media-production.lp-cdn.com/media/af3a9c82-49c6-45e8-b435-55b84d7549c2');">
  <div class="valuation__overlay"></div>

  <div class="container valuation__inner">
    <div class="valuation__content">
      <h2>What Is Your Home <span class="accent">Worth?</span></h2>
      <p>Get an instant, accurate estimate of your home's value — backed by real local market data.</p>

      <ul class="valuation__benefits">
        <li>
          <span class="valuation__check">✓</span>
          Instant market analysis based on recent sales
        </li>
        <li>
          <span class="valuation__check">✓</span>
          No obligation, 100% free
        </li>
        <li>
          <span class="valuation__check">✓</span>
          Expert local insight included
        </li>
        <li>
          <span class="valuation__check">✓</span>
          Personalized report delivered to your inbox
        </li>
      </ul>

      <div class="valuation__search-bar">
        <input
          type="text"
          id="valuationAddress"
          class="valuation__input"
          placeholder="Enter your home address..."
          autocomplete="off"
        />
        <button class="btn btn-primary" id="valuationBtn">Get My Value</button>
      </div>
    </div>
  </div>
</section>

<!-- Valuation Modal -->
<div class="modal-backdrop" id="valuationModal" style="display:none;">
  <div class="modal">
    <button class="modal__close" id="modalClose">&times;</button>
    <h3>Get Your Free Home Valuation</h3>
    <p>Tell us a bit about your home and we'll get back to you with a detailed report.</p>
    <form class="valuation-form" id="valuationForm">
      <input type="hidden" id="formAddress" />
      <div class="form-group">
        <label>Full Name *</label>
        <input type="text" name="name" required placeholder="Your name" />
      </div>
      <div class="form-group">
        <label>Email Address *</label>
        <input type="email" name="email" required placeholder="your@email.com" />
      </div>
      <div class="form-group">
        <label>Phone Number</label>
        <input type="tel" name="phone" placeholder="(555) 555-5555" />
      </div>
      <div class="form-group">
        <label>Property Address *</label>
        <input type="text" name="address" id="formAddressField" required placeholder="123 Main St, New Braunfels, TX" />
      </div>
      <div class="form-group form-group--half">
        <div>
          <label>Bedrooms</label>
          <select name="beds">
            <option value="">Select</option>
            <option>1</option><option>2</option><option>3</option>
            <option>4</option><option>5</option><option>6+</option>
          </select>
        </div>
        <div>
          <label>Bathrooms</label>
          <select name="baths">
            <option value="">Select</option>
            <option>1</option><option>1.5</option><option>2</option>
            <option>2.5</option><option>3</option><option>3.5</option><option>4+</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label>Approximate Sq Ft</label>
        <input type="text" name="sqft" placeholder="e.g. 2,000" />
      </div>
      <button type="submit" class="btn btn-primary" style="width:100%;">
        Request My Free Valuation
      </button>
      <p class="form-disclaimer">
        By submitting you agree to be contacted by Cody Posey Real Estate. We respect your privacy.
      </p>
    </form>
  </div>
</div>

<style>
  .valuation {
    position: relative;
    background-size: cover;
    background-position: center;
    background-attachment: fixed;
    color: #fff;
  }

  .valuation__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.7);
  }

  .valuation__inner {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: flex-start;
  }

  .valuation__content {
    max-width: 580px;
  }

  .valuation__content h2 {
    color: #fff;
    margin-bottom: 1rem;
  }

  .valuation__content > p {
    color: rgba(255,255,255,0.8);
    margin-bottom: 2rem;
    font-size: 0.95rem;
  }

  .valuation__benefits {
    margin-bottom: 2rem;
  }

  .valuation__benefits li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.85);
    margin-bottom: 0.8rem;
  }

  .valuation__check {
    color: #FF1616;
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .valuation__search-bar {
    display: flex;
    gap: 0;
    background: #fff;
    overflow: hidden;
  }

  .valuation__input {
    flex: 1;
    border: none;
    outline: none;
    padding: 1rem 1.25rem;
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
    color: #000;
    background: transparent;
  }

  .valuation__input::placeholder { color: #999; }

  .valuation__search-bar .btn {
    border-radius: 0;
    white-space: nowrap;
  }

  /* Modal */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .modal {
    background: #fff;
    max-width: 560px;
    width: 100%;
    padding: 2.5rem;
    position: relative;
    max-height: 90vh;
    overflow-y: auto;
  }

  .modal__close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 1.8rem;
    cursor: pointer;
    color: #555;
    line-height: 1;
  }

  .modal__close:hover { color: #FF1616; }

  .modal h3 {
    font-family: 'Poppins', sans-serif;
    font-size: 1.6rem;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .modal > p {
    color: #666;
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
    color: #333;
  }

  .form-group input,
  .form-group select {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #ddd;
    font-family: 'Poppins', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.2s;
    background: #fff;
  }

  .form-group input:focus,
  .form-group select:focus {
    border-color: #FF1616;
  }

  .form-group--half {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group--half input,
  .form-group--half select {
    width: 100%;
  }

  .form-disclaimer {
    font-size: 0.7rem;
    color: #999;
    text-align: center;
    margin-top: 0.75rem;
  }

  @media (max-width: 600px) {
    .valuation__search-bar {
      flex-direction: column;
    }
    .valuation__search-bar .btn {
      width: 100%;
    }
    .form-group--half {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline>
  const modal = document.getElementById('valuationModal');
  const openBtn = document.getElementById('valuationBtn');
  const closeBtn = document.getElementById('modalClose');
  const addressInput = document.getElementById('valuationAddress');
  const formAddressField = document.getElementById('formAddressField');

  openBtn?.addEventListener('click', () => {
    if (formAddressField && addressInput && addressInput.value) {
      formAddressField.value = addressInput.value;
    }
    if (modal) modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
  });

  closeBtn?.addEventListener('click', () => {
    if (modal) modal.style.display = 'none';
    document.body.style.overflow = '';
  });

  modal?.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal.style.display = 'none';
      document.body.style.overflow = '';
    }
  });

  document.getElementById('valuationForm')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const form = e.target;
    const data = new FormData(form);
    // TODO: Connect to your CRM / email service / n8n webhook
    console.log('Valuation form submitted:', Object.fromEntries(data));
    alert('Thank you! Cody will be in touch shortly with your home valuation.');
    if (modal) modal.style.display = 'none';
    document.body.style.overflow = '';
    form.reset();
  });
</script>
