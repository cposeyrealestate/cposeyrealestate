---
interface Props {
  name: string;
  category: string;
  description: string;
  tags: string[];
}

const { name, category, description, tags } = Astro.props;

const categoryIcons: Record<string, string> = {
  outdoor: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 18a5 5 0 00-10 0"/><line x1="12" y1="2" x2="12" y2="13"/><polyline points="7 7 12 2 17 7"/></svg>`,
  family: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>`,
  nightlife: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>`,
  culture: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="22" x2="21" y2="22"/><line x1="6" y1="18" x2="6" y2="11"/><line x1="10" y1="18" x2="10" y2="11"/><line x1="14" y1="18" x2="14" y2="11"/><line x1="18" y1="18" x2="18" y2="11"/><polygon points="12 2 20 7 4 7"/><line x1="2" y1="18" x2="22" y2="18"/></svg>`,
  seasonal: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  entertainment: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF1616" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
};

const icon = categoryIcons[category.toLowerCase()] || categoryIcons.entertainment;
---

<div class="activity-card">
  <div class="activity-card__icon" set:html={icon} />
  <span class="activity-card__category">{category}</span>
  <h3 class="activity-card__name">{name}</h3>
  <p class="activity-card__desc">{description}</p>
  {tags.length > 0 && (
    <div class="activity-card__tags">
      {tags.map((tag) => (
        <span class="activity-card__tag">{tag}</span>
      ))}
    </div>
  )}
</div>

<style>
  .activity-card {
    background: #fff;
    border-radius: 8px;
    padding: 1.5rem;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s, box-shadow 0.3s;
  }

  .activity-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.13);
  }

  .activity-card__icon {
    margin-bottom: 0.75rem;
  }

  .activity-card__category {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #FF1616;
    margin-bottom: 0.5rem;
  }

  .activity-card__name {
    font-size: 1.05rem;
    color: #000;
    margin-bottom: 0.5rem;
  }

  .activity-card__desc {
    font-size: 0.88rem;
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .activity-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .activity-card__tag {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 0.25rem 0.6rem;
    background: #f5f5f5;
    border-radius: 999px;
    color: #555;
  }
</style>
