---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Cody Posey | New Braunfels, Texas Real Estate Agent',
  description = 'Cody Posey is a top real estate agent in New Braunfels, Texas. Search homes for sale, get a free home valuation, and connect with a local expert.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Swiper CSS -->
    <link rel="stylesheet" href="/swiper-bundle.min.css" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
